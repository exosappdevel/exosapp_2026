	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){	
			$("#agregar_set_form").trigger("reset");		
			llenar_tabla_escanear(); 
			$('#loading').hide();			 
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
} 
   
function escanear_producto_set(){  
	
	var id_cirugia 		= $("#id_cirugia").val();	
	var codigo 			= $("#escanear_set_codigo").val();	
	 
	var continua = 1;    

	if(codigo == ""){
		continua = 0;
	}
	 
	if(continua == 1){
		$('#loading').show();  
		$.post("controller.php", 
			{ 	action 			: "escanear_producto_set",
				id_cirugia		: id_cirugia,  
				codigo			: codigo
			}, end_escanear_producto_set);  		  
	}else{
		swal("Ocurrio un error","Escanea un código o escribe referencia y cantidad","error");
	}
 
}
function end_escanear_producto_set(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){	
			$("#agregar_set_form").trigger("reset");		
			$("#escanear_set_codigo").val("");	
			$("#escanear_set_codigo").focus();	
			
			setTimeout(function(){  
				llenar_tabla_escanear(); 
				$('#loading').hide();	
			}, 1000);	 
			

			
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
} 


function valida_fecha_meter_producto_set_cirugia(codigo){ 
	var caducidad 		= $("#nuevo_entrada_caducidad").val();

	var fechaInicio = new Date().getTime();
	var fechaFin    = new Date(caducidad).getTime();

	var diff = fechaFin - fechaInicio;
	var dias_transcurridos = (diff/(1000*60*60*24) );
	
	if(dias_transcurridos < 365){
		swal({ 
			title: "Alerta",
			text: "La fecha de caducidad es menor a 1 año. Desea Continuar?",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, continuar",
			cancelButtonText: "No, Regresar",
			closeOnConfirm: true,
			closeOnCancel: true
		}, 
		function(isConfirm) {
			if (isConfirm) {
				registrar_entrada_inventario();
			} else {
				return false;
			} 
		});
	}else{
		registrar_entrada_inventario();
	}

	
}


function meter_producto_set_cirugia(){ 
	
	var id_set 		= $("#id_minialmacen").val();	
	var id_cirugia 	= $("#id_cirugia").val();
	var codigo 		= $("#agrega_producto_set_codigo").val();
	
	$.post("controller.php", 
		{ 	action 		: "meter_producto_set_cirugia_valida_fecha",
			id_set		: id_set, 
			id_cirugia	: id_cirugia, 
			codigo		: codigo  
		}, end_meter_producto_set_cirugia_valida_fecha);  	
}
function end_meter_producto_set_cirugia_valida_fecha(xml){ 
	$(xml).find("response").each(function(i){
		
		
		var id_set 		= $(this).find("id_set").text();
			var id_cirugia 	= $(this).find("id_cirugia").text();
			var codigo 		= $(this).find("codigo").text();
			
		if ($(this).find("result").text()=="ok"){	
		
			

			$('#loading').show();  
	
			$.post("controller.php", 
			{ 	action 		: "meter_producto_set_cirugia",
				id_set		: id_set, 
				id_cirugia	: id_cirugia,
				codigo		: codigo  
			}, end_meter_producto_set_cirugia);  		  
		}else{
			swal({  
				title: "Alerta",
				text: "La fecha de caducidad es menor a 1 mes o ya esta vencida. Desea Continuar?",
				type: "warning",
				showCancelButton: true,
				confirmButtonClass: "btn-danger",
				confirmButtonText: "Si, continuar",
				cancelButtonText: "No, Regresar",
				closeOnConfirm: true,
				closeOnCancel: true 
			},  
			function(isConfirm) {
				if (isConfirm) {
					
					$('#loading').show();
					
					$.post("controller.php", 
						{ 	action 		: "meter_producto_set_cirugia",
							id_set		: id_set, 
							id_cirugia	: id_cirugia,
							codigo		: codigo  
						}, end_meter_producto_set_cirugia);  		
				} else {
					return false;
				} 
			});
		}
	});
  
} 
