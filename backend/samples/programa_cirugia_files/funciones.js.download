/* busqueda de productos con filtro*/
function filtrar_producto(e){ 
	e.preventDefault();
	/* aqui van las variables de busqueda */
	var fabricante 	= $("#filtro_producto_fabricante").val();
	var marca 		= $("#filtro_producto_marca").val();
	var categoria 	= $("#filtro_producto_categoria").val();
	var nombre 		= $("#filtro_producto_nombre").val();
	var referencia 	= $("#filtro_producto_referencia").val();

	$.post("controller.php",
		{ 	action :"llenar_tabla_productos_filtro",
			fabricante 	: fabricante,
			marca 		: marca,
			categoria 	: categoria,
			nombre 		: nombre,
			referencia 	: referencia
		}, end_llenar_tabla_productos);
}
