		consumo.push($(this).val());
	});
	var consumo_string = consumo.join(",");
	*/
		
	$( ".div_consumos" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo.push(paso);
		}
		
	}); 
	
	var consumo_string = consumo.join(",");
	
