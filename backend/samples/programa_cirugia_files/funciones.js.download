/*cirugia*/
function llenar_formulario_cirugia(){ 
	var id_cirugia = $("#nuevo_cirugia_id").val();	
		  
	$.post("controller.php", 
		{ 	action 		: "llenar_formulario_cirugia",
			id_cirugia 	: id_cirugia 
		}, end_llenar_formulario_cirugia);
}  
function end_llenar_formulario_cirugia(xml){   
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){  
		
			$("#clave_cirugia").html($(this).find("clave_cirugia").text()); 	
			
			$("#nuevo_cirugia_fecha").val($(this).find("fecha").text()); 					
			$("#nuevo_cirugia_hora").val($(this).find("hora").text()); 			
			$("#nuevo_cirugia_ciudad").val($(this).find("municipio").text()); 		 	
			$("#nuevo_cirugia_subdistribuidor").val($(this).find("subdistribuidor").text()); 			 			
			$("#nuevo_cirugia_subdistribuidor_txt").val($(this).find("subdistribuidor_txt").text()); 			 			
			$("#nuevo_cirugia_notas").val($(this).find("notas").text()); 			
			$("#nuevo_cirugia_vendedor").val($(this).find("vendedor").text()); 			
			$("#nuevo_cirugia_tecnico").val($(this).find("tecnico").text()); 			
			$("#nuevo_cirugia_tecnico_2").val($(this).find("tecnico2").text()); 			
			$("#nuevo_cirugia_medico").val($(this).find("medico").text()); 			
			$("#nuevo_cirugia_hospital").val($(this).find("hospital").text()); 			
			$("#nuevo_cirugia_estado").val($(this).find("estado").text()); 				
			
			$("#nuevo_cirugia_paciente").val($(this).find("paciente").text()); 	 
			$("#nuevo_cirugia_paciente_p").val($(this).find("paciente_p").text()); 	
			$("#nuevo_cirugia_paciente_m").val($(this).find("paciente_m").text());  			
			$("#nuevo_cirugia_orden_pago").val($(this).find("orden_pago").text());  
			
			$("#nuevo_cirugia_esteril").val($(this).find("esteril").text());   	
			

			var minialmacen = $(this).find("minialmacen").text().split(",");
			$.each( minialmacen, function( index, value ) {
				$("#nuevo_cirugia_minialmacenes input[type=checkbox][value= '" + value + "']").prop("checked",true);
			});
			
			var equipo_poder = $(this).find("equipo_poder").text().split(",");
			$.each( equipo_poder, function( index, value ) {
				$("#nuevo_cirugia_equipos_poder input[type=checkbox][value= '" + value + "']").prop("checked",true);
			});
			
			var adicionales = $(this).find("adicionales").text().split(",");
			$.each( adicionales, function( index, value ) {
				$("#nuevo_cirugia_adicionales input[type=checkbox][value= '" + value + "']").prop("checked",true);
			});
			var consumibles = $(this).find("consumibles").text().split(","); 
			$.each( consumibles, function( index, value ) {
				$("#nuevo_cirugia_consumibles input[type=checkbox][value= '" + value + "']").prop("checked",true);
			});
		
		} 
	}); 
}  

