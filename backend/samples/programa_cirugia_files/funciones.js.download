/* cirugias*/ 
function guardar_cirugia(){  	
 
	var nuevo_cirugia_id				= $("#nuevo_cirugia_id").val();  
	var nuevo_cirugia_fecha				= $("#nuevo_cirugia_fecha").val(); 
	var nuevo_cirugia_hora				= $("#nuevo_cirugia_hora").val(); 
	var nuevo_cirugia_estado			= $("#nuevo_cirugia_estado").val(); 
	var nuevo_cirugia_ciudad			= $("#nuevo_cirugia_ciudad").val(); 
	var nuevo_cirugia_vendedor			= $("#nuevo_cirugia_vendedor").val(); 
	var nuevo_cirugia_tecnico			= $("#nuevo_cirugia_tecnico").val(); 
	var nuevo_cirugia_tecnico_2			= $("#nuevo_cirugia_tecnico_2").val(); 
	var nuevo_cirugia_subdistribuidor	= $("#nuevo_cirugia_subdistribuidor").val(); 
	var nuevo_cirugia_subdistribuidor_txt	= $("#nuevo_cirugia_subdistribuidor_txt").val(); 
	var nuevo_cirugia_hospital			= $("#nuevo_cirugia_hospital").val(); 
	var nuevo_cirugia_medico			= $("#nuevo_cirugia_medico").val(); 
	var nuevo_cirugia_notas				= $("#nuevo_cirugia_notas").val(); 
	var nuevo_cirugia_paciente			= $("#nuevo_cirugia_paciente").val(); 
	var nuevo_cirugia_paciente_p		= $("#nuevo_cirugia_paciente_p").val(); 
	var nuevo_cirugia_paciente_m		= $("#nuevo_cirugia_paciente_m").val();  
	
	var nuevo_cirugia_esteril			= $("#nuevo_cirugia_esteril").val();  
	
	var nuevo_cirugia_file_name			= $("#nuevo_cirugia_file_name").val();  
	var nuevo_cirugia_orden_pago		= $("#nuevo_cirugia_orden_pago").val();   
	
	var continua = 1;		
		
	var minialmacen = []; minialmacen_string = "";
	var equipopoder = []; equipopoder_string = "";
	var adicionales = []; adicionales_string = ""; 
	var consumibles = []; consumibles_string = "";  
	
	$("#nuevo_cirugia_minialmacenes input:checkbox[name=minialmacen]:checked").each(function(){     
		minialmacen.push($(this).val());
	});
	var minialmacen_string = minialmacen.join(",");
	
	$("#nuevo_cirugia_equipos_poder input:checkbox[name=equipopoder]:checked").each(function(){     
		equipopoder.push($(this).val());
	});
	var equipopoder_string = equipopoder.join(",");
	
	$("#nuevo_cirugia_adicionales input:checkbox[name=adicionales]:checked").each(function(){     
		adicionales.push($(this).val());
	});
	var adicionales_string = adicionales.join(",");
	
	
	$("#nuevo_cirugia_consumibles input:checkbox[name=consumibles]:checked").each(function(){     
		consumibles.push($(this).val());
	});
	var consumibles_string = consumibles.join(","); 
	
	
	//alert(minialmacen_string);
	
	 
	$("#nuevo_cirugia_form .obligatorio_cirugia").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			//alert(index);
		}else{ 
			$(this).removeClass("form-control-danger");
		}		 
	});	
	$("#nuevo_cirugia_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	}); 
	 
	
	//var today = new Date();
	// obtener la fecha y la hora
	//var now = today.toLocaleString();
	//console.log("NOW" + now + ";;;;;");
 
 
 
	//var currentTime = new Date().toISOString().slice(0, 10);
	var currentTime = new Date();
	var fecha_sql = conviertefechasql(nuevo_cirugia_fecha);
		
	console.log("currentTime::::" + currentTime);
	console.log("fecha_sql::::" + fecha_sql);
	if(tipoguardado != "editar"){
		if(currentTime > fecha_sql){
			swal("Revisa el formulario", "La fecha de cirugía no puede ser menor que hoy", "error");
			continua = 0;
			return false;
		}
	}
	 
	
	if(continua == 1){ 
		$.post("controller.php",   
			{ 	action :"guardar_cirugia",   
				tipo 							: tipoguardado, 
				nuevo_cirugia_id 				: nuevo_cirugia_id, 
				nuevo_cirugia_fecha 			: nuevo_cirugia_fecha,
				nuevo_cirugia_hora 				: nuevo_cirugia_hora,
				nuevo_cirugia_estado 			: nuevo_cirugia_estado,
				nuevo_cirugia_ciudad 			: nuevo_cirugia_ciudad,
				nuevo_cirugia_vendedor 			: nuevo_cirugia_vendedor,
				nuevo_cirugia_tecnico 			: nuevo_cirugia_tecnico,
				nuevo_cirugia_tecnico_2 		: nuevo_cirugia_tecnico_2,
				nuevo_cirugia_subdistribuidor 	: nuevo_cirugia_subdistribuidor,
				nuevo_cirugia_subdistribuidor_txt 	: nuevo_cirugia_subdistribuidor_txt,
				nuevo_cirugia_hospital 			: nuevo_cirugia_hospital, 
				nuevo_cirugia_medico 			: nuevo_cirugia_medico,
				minialmacen_string 				: minialmacen_string,
				equipopoder_string 				: equipopoder_string,
				adicionales_string 				: adicionales_string, 
				consumibles_string 				: consumibles_string,
				nuevo_cirugia_paciente 			: nuevo_cirugia_paciente,
				nuevo_cirugia_paciente_p 		: nuevo_cirugia_paciente_p,
				nuevo_cirugia_paciente_m 		: nuevo_cirugia_paciente_m,
				nuevo_cirugia_esteril 			: nuevo_cirugia_esteril,
				nuevo_cirugia_file_name 		: nuevo_cirugia_file_name, 
				nuevo_cirugia_orden_pago 		: nuevo_cirugia_orden_pago,
				nuevo_cirugia_notas				: nuevo_cirugia_notas					 
			},end_guardar_cirugia);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
	
} 
function end_guardar_cirugia(xml){	    
	$(xml).find("response").each(function(i){	
		if ($(this).find("result").text()=="ok"){
			$("#respuesta_cirugia").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			if(tipoguardado == "nuevo"){ 
				$("#nuevo_cirugia_nombre").removeAttr("readonly"); 
				
				$('#nuevo_cirugia_form').trigger("reset");
				$("#nuevo_cirugia_id").val("0"); 
				$(".obligatorio_select").val("0").trigger('change');
				
				//$(".obligatorio_select").val("0");
				
			}else if(tipoguardado == "editar"){ 
				//$("#nuevo__nombre").attr("readonly", "readonly");  // se utiliza cuando algun campo NO puede ser modificado al editar
				$("#nuevo_cirugia_id").val($(this).find("nuevo_cirugia_id").text()); 
			}else if(tipoguardado == "nuevo_salir"){
				location.href ="ver_cirugias.php";
			}
			
			cargar_notificaciones();
			
		}else{
			$("#respuesta_cirugia").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta_cirugia").html("");   
		}, 5000);		
	});
} 


 
/* productos*/
function guardar_producto(){ 	
	var nuevo_producto_id				= $("#nuevo_producto_id").val(); 
	var nuevo_producto_fabricante		= $("#nuevo_producto_fabricante").val();
	var nuevo_producto_marca			= $("#nuevo_producto_marca").val();
	var nuevo_producto_categoria		= $("#nuevo_producto_categoria").val(); 
	var nuevo_producto_subcategoria		= $("#nuevo_producto_subcategoria").val(); 
	var nuevo_producto_nombre			= $("#nuevo_producto_nombre").val(); 
	var nuevo_producto_referencia		= $("#nuevo_producto_referencia").val();
	var nuevo_producto_codigo_barras	= $("#nuevo_producto_codigo_barras").val();
	var nuevo_producto_stock_minimo		= $("#nuevo_producto_stock_minimo").val();
	var continua = 1;		
	
	$("#nuevo_producto_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{  
			$(this).removeClass("form-control-danger");
		}		
	});	
	$("#nuevo_producto_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});
	
	if(continua == 1){
		$.post("controller.php", 
			{ 	action :"guardar_producto", 
				tipo 							: tipoguardado, /*global*/  
				nuevo_producto_id 				: nuevo_producto_id,  
				nuevo_producto_fabricante 		: nuevo_producto_fabricante,  
				nuevo_producto_marca 			: nuevo_producto_marca,  
				nuevo_producto_categoria 		: nuevo_producto_categoria,  
				nuevo_producto_subcategoria 	: nuevo_producto_subcategoria,  
				nuevo_producto_nombre 			: nuevo_producto_nombre,  
				nuevo_producto_referencia 		: nuevo_producto_referencia,  
				nuevo_producto_codigo_barras 	: nuevo_producto_codigo_barras,
				nuevo_producto_stock_minimo 	: nuevo_producto_stock_minimo
			},end_guardar_producto);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
}  
function end_guardar_producto(xml){	  
	$(xml).find("response").each(function(i){		
