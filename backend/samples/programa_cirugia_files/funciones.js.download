function leer_csv_entrada(){       
	var archivo_csv 	= $("#csv_file").val();	
	var id_fabricante 	= $("#cargar_csv_fabricante").val();	
	var id_almacen 		= $("#cargar_csv_bodega").val();	
	var id_area			= $("#cargar_csv_area").val();	
	var id_subarea 		= $("#cargar_csv_subarea").val();	
	var nivel 			= $("#cargar_csv_nivel").val();	
	var formato 		= $("#cargar_csv_formato").val();	
	
	//	alert(formato);
	
	var ruta = "";
	var continua = 1;
	
	switch(formato){   
		case "1":
			ruta = "leer_csv_entrada";
			break;
		case "2":
			ruta = "leer_csv_entrada_formato_2";
			break;
		case "3":
			ruta = "leer_csv_entrada_formato_3";
			break;
		case "4":
			ruta = "leer_csv_entrada_formato_4";
			break;
		default:
			ruta = "leer_csv_entrada";
	}
		
		
	//	alert(ruta);
	
	$("#leer_csv_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});	
	$("#leer_csv_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	}); 
	 	 
	if(archivo_csv == ""){
		continua = 0;
	} 
	 
	if(continua == 1){
		
		$("#btn-leer_csv_entrada").hide();
		$("#loading").show();
		
		$.post("controller2.php",   
			{ 	action 			: ruta, 
				archivo_csv 	: archivo_csv,
				id_fabricante 	: id_fabricante,
				id_almacen 		: id_almacen,
				id_area 		: id_area,
				id_subarea 		: id_subarea,
				nivel 			: nivel
			}, end_leer_csv_entrada); 		
		
	}else{
		swal("Selecciona todas las opciones y sube un archivo CSV");
	}
}   
function end_leer_csv_entrada(xml){   
	//swal.close()
	$(xml).find("response").each(function(i){  
	
		$("#btn-leer_csv_entrada").show();
		$("#loading").hide();
		$("#fileupload").val("");
		$("#files").html("");
		$("#nuevo_salida_form").trigger("reset"); 
		
		if ($(this).find("result").text()=="ok"){			 
			swal("carga exitosa");
			
			window.open(
				$(this).find("filepath").text(),
				'_blank'
			);			
			$("#respuesta_2").html("PRODUCTOS NO ENCONTRADOS:<br>" + $(this).find("productos_no_encontrados").text());			
		}
	});
}
  
function leer_csv_entrada_inventario_codigo2(){       
	var archivo_csv 		= $("#csv_file").val();	
	var id_entrada_almacen 	= $("#id_entrada_almacen").val();	
	
	var continua = 1;
		
	if(archivo_csv == ""){
		continua = 0;
		motivo_error = "Por favor carga un archivo CSV";
	}
	if(id_entrada_almacen == "" || id_entrada_almacen == "0"){
		continua = 0;
		motivo_error = "Por favor inicia un registro primero";
	}
	 
	if(continua == 1){
		$.post("controller2.php",   
			{ 	action 				: "leer_csv_entrada_inventario_codigo2", 
				archivo_csv 		: archivo_csv,
				id_entrada_almacen 	: id_entrada_almacen
			}, end_leer_csv_entrada_inventario_codigo2); 
	}else{
		$("#respuesta_2").html("");   
		$("#respuesta_2").html('<div class="alert alert-danger">' + motivo_error + '</div>');			
		setTimeout(function(){  
			$("#respuesta_2").html("");  
		}, 4000);	
	}
}   
function end_leer_csv_entrada_inventario_codigo2(xml){   
	//swal.close()
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){	
			llenar_tabla_entrada_almacen_inventariotmp();		
			swal("carga exitosa"); 
		}
	});
}
   
function leer_csv_productos(){      
	var archivo_csv = $("#csv_file").val();	
	
	var marca 			= $("#nuevo_producto_marca").val();	
	var categoria 		= $("#nuevo_producto_categoria").val();	
	var subcategoria 	= $("#nuevo_producto_subcategoria").val();	
	var continua = 1;
	
	if(marca == "0" || categoria == "0" || subcategoria == "0"){
		continua = 0;
	}
	
	
	if(continua == 1 && archivo_csv != ""){
		$.post("controller.php", 
			{ 	action 			: "leer_csv_productos", 
				archivo_csv 	: archivo_csv ,
				marca 			: marca ,
				categoria 		: categoria, 
				subcategoria 	: subcategoria 
			}, end_leer_csv_productos); 
	}	
}   
function end_leer_csv_productos(xml){    
	swal.close()
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			 
			swal("carga exitosa");
			
			window.open(
				$(this).find("filepath").text(),
				'_blank'
			);		 
			
		}
	});
}
  
function leer_csv_referencias(){      
	var archivo_csv 	= $("#csv_file").val();	
	var id_fabricante 	= $("#cargar_csv_fabricante").val();	
	var id_almacen 		= $("#cargar_csv_bodega").val();	
	var id_area			= $("#cargar_csv_area").val();	
	var id_subarea 		= $("#cargar_csv_subarea").val();	
	var nivel 			= $("#cargar_csv_nivel").val();	

	var continua = 1;
	
	$("#leer_csv_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});	
	$("#leer_csv_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	}); 
	
	
	if(archivo_csv == ""){
		continua = 0;
	}
	
	if(continua == 1){
		$.post("controller.php", 
			{ 	action 			: "leer_csv_referencias", 
				archivo_csv 	: archivo_csv,
				id_fabricante 	: id_fabricante,
				id_almacen 		: id_almacen,
				id_area 		: id_area,
				id_subarea 		: id_subarea,
				nivel 			: nivel
			}, end_leer_csv_referencias); 
	}else{
		swal("Selecciona todas las opciones y sube un archivo CSV");
	}
}  
function end_leer_csv_referencias(xml){   
	swal.close()
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			 
			swal("carga exitosa");
		}
	});
}
 

  
