/* FUNCIONALIDAD AGREGAR MEDICOS VENDEDORES */
function agrega_medico_vendedor(){ 
	
	var id_vendedor 	= $("#id_vendedor").val();	
	var id_medico 		= $("#nuevo_medico_vendedor").val();
	 
	var continua = 1;  

	if(id_vendedor == 0 || id_vendedor == ""){
		continua = 0;
		return false;
	}
	if(id_medico == 0 || id_medico == ""){
		continua = 0;
		return false;
	}
	
	if(continua == 1){  
		$('#loading').show();  
		$.post("controller.php", 
			{ 	action 		: "agrega_medico_vendedor",
				id_vendedor	: id_vendedor, 
				id_medico	: id_medico
			}, end_agrega_medico_vendedor);   		  
	}
 
}
function end_agrega_medico_vendedor(xml){ 
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	 
				
			llenar_tabla_medicos_vendedor();
			$('#loading').hide();			 
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
			
	});
}


/* Cambia estatus de cirugia a CANCELADA */
function aceptar_cirugia(id_cirugia){ 
	swal({   
		title: "¿Aceptar y programar?",   
		text: "Si acepta la cirugía quedará programada",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "#008000",   
		confirmButtonText: "Si, aceptar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 		  
		$.post("controller.php",
			{ 	action 		: "aceptar_cirugia", 
				id_cirugia 	: id_cirugia
			}, end_aceptar_cirugia);
	});  	
}   
function end_aceptar_cirugia(xml){  
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){ 
			//$('[data-toggle="tooltip"]').tooltip("dispose"); 
			llenar_tabla_cirugias();	

			//alert($(this).find("enviar_whatsapp").text());
			var nueva_pagina = $(this).find("enviar_whatsapp").text();
			setTimeout(function(){
				window.open(nueva_pagina,'_blank' );		
			}, 500);	

			
		}else{		
			var mensaje = $(this).find("result_text").text();
			setTimeout(function(){
				swal("Error", "" + mensaje + "", "error");
				$('[data-toggle="tooltip"]').tooltip("dispose"); 
			}, 500);	
		}  
	});
} 
 
/* SOLICITAR APOYO PARA CIRUGIA */
function solicitar_apoyo_antes(id_cirugia){ 
	swal({   
		title: "Solicitud de Apoyo a Matriz",   
		text: "Por favor escriba qué apoyo necesita",   
		type: "input",   
		showCancelButton: true,   
		closeOnConfirm: false,   
		animation: "slide-from-top",   
		inputPlaceholder: "Por favor escribe tu solicitud." 
	}, function(inputValue){   
		if (inputValue === false) return false;      
		if (inputValue === "") {     
			swal.showInputError("Escribe algo");     
			return false   
		}       
		$.post("controller3.php",
			{ 	action 			: "solicitar_apoyo", 
				id_cirugia 		: id_cirugia,
				texto_solicitud : inputValue
			}, end_solicitar_apoyo);
		//swal("Nice!", "You wrote: " + inputValue, "success"); 
	});

}   
function end_solicitar_apoyo_antes(xml){  
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){ 
			swal("Correcto", "Tu solicitud ha sido enviada", "success"); 
		}else{		
			swal("Cuidado", "Tu solicitud no pudo ser enviada. Vuelve a intentar.", "error"); 
		}  
	});
} 
/* SOLICITAR APOYO PARA CIRUGIA */
function solicitar_apoyo(){ 

	var id_cirugia 			= $("#apoyo_id_cirugia").val();
	var texto_solicitud 	= $("#apoyo_texto").val(); 
	var id_sucursal 		= $("#apoyo_sucursal").val();
	
	
	
	$.post("controller3.php",  
			{ 	action 			: "solicitar_apoyo", 
				id_cirugia 		: id_cirugia,
				id_sucursal 	: id_sucursal,
				texto_solicitud : texto_solicitud
			}, end_solicitar_apoyo);


}   
function end_solicitar_apoyo(xml){  
	$(xml).find("response").each(function(i){	

		$(".btn-close").trigger("click");
	
		if ($(this).find("result").text()=="ok"){ 
			swal("Correcto", "Tu solicitud ha sido enviada", "success"); 
		}else{		
			swal("Cuidado", "Tu solicitud no pudo ser enviada. Vuelve a intentar.", "error"); 
		}  
	});
} 

