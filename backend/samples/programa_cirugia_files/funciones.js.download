function end_reportar_consumos_manual_recibir(xml){  
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){
			llenar_tabla_consumos_manual_recibir();
			swal("CORRECTO", "El producto se ha sumado como consumo", "success" );
			setTimeout(function(){
				swal.close();
			}, 1000);		
		}else{
