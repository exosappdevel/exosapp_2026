function buscar_producto(){
	var codigo_1 = $("#buscar_producto_codigo").val();
	var codigo_2 = $("#buscar_producto_codigo_2").val();
	var continua = 1; 
	var doscaracteres = "";
	
	if(codigo_1 == "" && codigo_2 == ""){
		continua = 0;
		//swal("Cuidado", "Por favor ingresa un codigo", "error");
		return false;
	}
	
	if(continua == 1){   	
		$.post("controller.php", 
				{ 	action : "buscar_producto",   
					codigo_1: codigo_1,
					codigo_2: codigo_2 
				}, end_buscar_producto);  	
	} 
	

} 
function end_buscar_producto(xml){
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){
			  
			/*altas de almacen*/ 
			$("#id_producto").val($(this).find("id_producto").text());  
			$("#nuevo_entrada_nombre").val($(this).find("nombre").text()); 
			$("#nuevo_entrada_referencia").val($(this).find("referencia").text());
			
			
			/*busqueda*/ 
			$("#buscar_producto_nombre").val($(this).find("nombre").text()); 
			$("#buscar_producto_referencia").val($(this).find("referencia").text());
			$("#buscar_producto_categoria").val($(this).find("categoria").text());
			$("#buscar_producto_subcategoria").val($(this).find("subcategoria").text());
			$("#buscar_producto_marca").val($(this).find("marca").text());
			
			$("#buscar_producto_lote").val($(this).find("lote").text());
			$("#buscar_producto_caducidad").val($(this).find("caducidad").text());
			$("#buscar_producto_area").val($(this).find("area").text());
			$("#buscar_producto_subarea").val($(this).find("subarea").text());
			$("#buscar_producto_nivel").val($(this).find("nivel").text());
			$("#buscar_producto_cantidad").val($(this).find("cantidad").text());
			 
			
			/* hace focus a la cantidad*/
			//$("#nuevo_entrada_cantidad").focus();				
			$("#buscar_producto_codigo_2").focus();				 
			$("#nuevo_entrada_area").val($(this).find("area").text());				
			$("#nuevo_entrada_subarea").val($(this).find("subarea").text());				
			$("#nuevo_entrada_nivel").val($(this).find("nivel").text());				
			$("#nuevo_entrada_precio").val($(this).find("precio").text());				
			
			
		}else{
			$("#id_producto").val("0");  
			$("#nuevo_entrada_nombre").val(""); 
			$("#nuevo_entrada_referencia").val("");
			//swal("Error",$(this).find("result_text").text(),"error");
			
			$("#buscar_producto_codigo").focus();	

			$("#respuesta").html("");   
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');			
			setTimeout(function(){  
				$("#respuesta").html("");  
			}, 2000);				
		}
	});
} 

function buscar_producto_por_referencia(){
	var referencia = $("#nuevo_entrada_referencia").val();
	var continua = 1; 
	 
	if(referencia == ""){
		continua = 0;
		//swal("Cuidado", "Por favor ingresa un codigo", "error");
		return false;
	}
	 
	if(continua == 1){   
		$.post("controller.php", 
			{ 	action : "buscar_producto_por_referencia",  
				referencia: referencia
			}, end_buscar_producto_por_referencia);  		 
	} 

} 
function end_buscar_producto_por_referencia(xml){ 
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){
			 
			/*altas de almacen*/ 
			$("#id_producto").val($(this).find("id_producto").text());  
			$("#nuevo_entrada_nombre").val($(this).find("nombre").text()); 
			$("#nuevo_entrada_codigo_1").val($(this).find("codigo_1").text());
			
			
			/*busqueda*/ 
			$("#buscar_producto_nombre").val($(this).find("nombre").text()); 
			$("#buscar_producto_codigo_1").val($(this).find("codigo_1").text());
			$("#buscar_producto_categoria").val($(this).find("categoria").text());
			$("#buscar_producto_subcategoria").val($(this).find("subcategoria").text());
			$("#buscar_producto_marca").val($(this).find("marca").text());
			
			$("#buscar_producto_lote").val($(this).find("lote").text());
			$("#buscar_producto_caducidad").val($(this).find("caducidad").text());
			$("#buscar_producto_area").val($(this).find("area").text());
			$("#buscar_producto_subarea").val($(this).find("subarea").text());
			$("#buscar_producto_nivel").val($(this).find("nivel").text());
			$("#buscar_producto_cantidad").val($(this).find("cantidad").text());
			
			
			/* hace focus a la cantidad*/
			$("#nuevo_entrada_cantidad").focus();	
 
			
		}else{
			$("#id_producto").val("0");  
			$("#nuevo_entrada_nombre").val("");  
			$("#nuevo_entrada_codigo_1").val("");
			//swal("Error",$(this).find("result_text").text(),"error");
			
			$("#buscar_producto_codigo").focus();	 
		}
	});
}

