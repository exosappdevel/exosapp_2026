/* FOTOS DE LAS CIRUGIAS */
//function copiar_cirugia_foto_destino(id_cirugia_foto, id_cirugia_destino){     
function copiar_cirugia_foto_destino(id_cirugia_foto){     
	
	var continua = 1; 
	var id_cirugia_destino = $("#traspaso_destino").val();
	//alert(id_cirugia_destino);
	
	//continua = 0;
	
	if(id_cirugia_foto == 0 || id_cirugia_destino == 0 || id_cirugia_destino == ""){
		continua = 0;
		//alert("Por favor escriba una cirugia Destino");
		swal("Cuidado", "Por favor escriba una cirugia Destino", "error"); 
	}
	
	if(continua == 1){
		$.post("controller3.php", 
			{ 	action 				: "copiar_cirugia_foto_destino",  
				id_cirugia_foto 	: id_cirugia_foto,
				id_cirugia_destino 	: id_cirugia_destino 
			}, llenar_div_traspaso_cirugia_fotos);
	}
	
}     
/* FOTOS DE LAS CIRUGIAS */
function eliminar_cirugia_foto(id_cirugia_foto){    

     
	//	swal({    
	//		title: "¿Eliminar?",   
	//		text: "Esta acción es definitiva y no podrá revertirse.",   
	//		/*type: "warning",    */
	//		showCancelButton: true,    
	//		confirmButtonColor: "#DD6B55",    
	//		confirmButtonText: "Si, eliminar",  
	//		cancelButtonText: "Regresar",   
	//		closeOnConfirm: true 
	//	}, function(){ 		  
	//		$.post("controller3.php", 
	//			{ 	action 				: "eliminar_cirugia_foto",  
	//				id_cirugia_foto 	: id_cirugia_foto
	//			}, end_eliminar_cirugia_foto);
	//	});
	
	
	swal({
        title: "¿Estás seguro?",
        text: "Este registro se eliminará permanentemente",
        icon: "warning",
        buttons: {
            cancel: {
                text: "Cancelar",
                visible: true
            }, 
            confirm: {
                text: "Sí, eliminar",
                closeModal: true
            } 
        },
        dangerMode: true,
    })
    .then((confirmado) => {
        if (confirmado) {
            // Acción si el usuario confirma
            // Aquí realizas tu petición AJAX o fetch:
            $.post("controller3.php", 
			{ 	action 				: "eliminar_cirugia_foto",  
				id_cirugia_foto 	: id_cirugia_foto
			}, end_eliminar_cirugia_foto);
        } else {
            // Si cancela
            swal.close();
        }
    });
	
	
}   
function end_eliminar_cirugia_foto(xml){    
	$(xml).find("response").each(function(i){	 	   
		if ($(this).find("result").text()=="ok"){ 
			//$('[data-toggle="tooltip"]').tooltip("dispose"); 
			llenar_div_entregar_material_fotos();	
			llenar_div_traspaso_cirugia_fotos();
		}else{		
			var mensaje = $(this).find("result_text").text();
			setTimeout(function(){
				swal("Error", "" + mensaje + "", "error");
				$('[data-toggle="tooltip"]').tooltip("dispose"); 
			}, 500);	
		}  
	});
}       
