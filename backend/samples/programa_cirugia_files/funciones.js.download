function reportar_consumos_instrumental(){  	    
 
	var id_cirugia = $("#id_cirugia").val();   
	var id_instrumental = $("#id_instrumental").val();  
	
	var continua = 1;	
	var consumo_ins = []; 
	var consumo_ins_string = "";  
