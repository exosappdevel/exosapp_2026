	});
} 

function transferir_producto_instrumental(id_producto_set){
	
	var set_destino = $("#selecciona_set_destino").val();
		
	if(set_destino > 0){
		
		$('#loading').show(); 		
		
		$.post("controller.php", 
			{ 	action 				: "transferir_producto_instrumental",
				set_destino 		: set_destino, 
				id_producto_set 	: id_producto_set 
			}, end_transferir_producto_instrumental);
	}else{
		$('#loading').hide();
		swal("Error", "Seleccione SET destino", "error");
	} 
	
}
