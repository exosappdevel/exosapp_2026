/* Entradas inventario tmp */
function modificar_inventario_tmp(id_inventario){
	
	
	var nuevo_lote 			= $(".nuevo_lote_" + id_inventario).val(); 
	var nuevo_fecha_cad 	= $(".nuevo_fecha_cad_" + id_inventario).val(); 
	var nuevo_cantidad 		= $(".nuevo_cantidad_" + id_inventario).val(); 
	var nuevo_precio		= $(".nuevo_precio_" + id_inventario).val(); 
 
	$.post("controller.php",
			{ 	action 			: "modificar_inventario_tmp", 
				id_inventario 	: id_inventario,
				nuevo_lote 		: nuevo_lote,
				nuevo_fecha_cad : nuevo_fecha_cad,
				nuevo_cantidad  : nuevo_cantidad ,
				nuevo_precio : nuevo_precio 
			}, end_modificar_inventario_tmp);
	
} 
