/* ****************************************************************** */
/* ****************************************************************** */
/* ******   LLENADO DE FORMULARIOS CON DATOS DE LA DATABASE    ****** */
/* ****************************************************************** */
/* ****************************************************************** */
  


/* Tipos de Usuarios */  
function llenar_formulario_registro_entrada(){  
	var id_entrada_almacen = $("#id_entrada_almacen").val();	
		   
	if(id_entrada_almacen > 0){  
		$.post("controller.php",
			{ 	action 		: "llenar_formulario_registro_entrada",
				id_entrada_almacen 	: id_entrada_almacen  
			}, end_llenar_formulario_registro_entrada); 
	} 
	  
}
function end_llenar_formulario_registro_entrada(xml){    
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){    
		
			$("#nuevo_entrada_proveedor").val($(this).find("proveedor").text()); 		 
			$("#nuevo_entrada_factura").val($(this).find("factura").text()); 	 
			
			$("#nuevo_entrada_proveedor").prop('disabled', true); 
			$("#nuevo_entrada_factura").prop('disabled', true); 
		 
		}
	}); 
}  

/* Tipos de Usuarios */  
function llenar_formulario_tipo_usuario(){  
	var nuevo_tipo_usuario_id = $("#nuevo_tipo_usuario_id").val();	
		   
	if(nuevo_tipo_usuario_id > 0){  
		$.post("controller.php",
			{ 	action 		: "llenar_formulario_tipo_usuario",
				nuevo_tipo_usuario_id 	: nuevo_tipo_usuario_id  
			}, end_llenar_formulario_tipo_usuario); 
	} 
	  
}
function end_llenar_formulario_tipo_usuario(xml){    
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){    
		
			//$("#registro_rapido_folio").val($(this).find("folio").text()); 		 
			$("#nuevo_tipo_usuario_tipo").val($(this).find("tipo").text()); 		 
			$("#nuevo_tipo_usuario_pagina").val($(this).find("pagina_inicio").text()); 	 
			
		 
		}
	}); 
}   


/* Registros Rápidos */  
function llenar_formulario_remision(){  
	var remision_id_cirugia = $("#remision_id_cirugia").val();	
		  
	if(remision_id_cirugia > 0){  
		$.post("controller.php",
			{ 	action 		: "llenar_formulario_remision",
				remision_id_cirugia 	: remision_id_cirugia  
			}, end_llenar_formulario_remision); 
	} 
	
}
function end_llenar_formulario_remision(xml){    
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){    
		
			//$("#registro_rapido_folio").val($(this).find("folio").text()); 		 
			$("#remision_fecha_programacion").val($(this).find("fecha_programacion").text()); 		 
			$("#remision_fecha_cirugia").val($(this).find("fecha_cirugia").text()); 		 
			$("#remision_vendedor").val($(this).find("vendedor").text()); 		 
			$("#remision_tecnico").val($(this).find("tecnico").text()); 		 
			$("#remision_medico").val($(this).find("medico").text()); 		 
			$("#remision_hospital").val($(this).find("hospital").text()); 	 	 
			$("#remision_estado").val($(this).find("estado").text()); 		  
			$("#remision_municipio").val($(this).find("municipio").text()); 		 
			$("#remision_paciente").val($(this).find("paciente").text()); 		 
			$("#remision_id_cirugia").val($(this).find("codigo").text()); 		 
			
		 
		}
	}); 
}  


/* Registros Rápidos */ 
function llenar_formulario_registro_rapido(){  
	var registro_rapido_folio = $("#registro_rapido_folio").val();	
		  
	if(registro_rapido_folio > 0){ 
		$.post("controller.php",
			{ 	action 		: "llenar_formulario_registro_rapido",
				registro_rapido_folio 	: registro_rapido_folio  
			}, end_llenar_formulario_registro_rapido); 
	}
	
}
function end_llenar_formulario_registro_rapido(xml){   
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){   
		
			//$("#registro_rapido_folio").val($(this).find("folio").text()); 		 
			$("#registro_rapido_fecha").val($(this).find("fecha").text()); 		 
			$("#registro_rapido_entrega").val($(this).find("entrego").text()); 		 
			$("#registro_rapido_recibe").val($(this).find("recibe").text()); 		 
			$("#registro_rapido_agente").val($(this).find("agente").text()); 		 
			$("#registro_rapido_hospital").val($(this).find("hospital").text()); 		 
			$("#registro_rapido_comentarios").val($(this).find("comentarios").text()); 		 
			$("#registro_rapido_estatus").html($(this).find("estatus").text()); 	
			
			$("#cajas_salida").html($(this).find("cajas_salida").text());  		 
			$("#cajas_entrada").html($(this).find("cajas_entrada").text()); 		 
			
		 
		}
	}); 
}  


/*cirugia*/ 
function llenar_formulario_inventario(){ 
	var id_inventario = $("#id_inventario").val();	
		  
	$.post("controller.php",
		{ 	action 		: "llenar_formulario_inventario",
