function agrega_registro_rapido(){ 
	
	var registro_rapido_folio 		= $("#registro_rapido_folio").val();	
	var registro_rapido_fecha 		= $("#registro_rapido_fecha").val();
	var registro_rapido_entrega 	= $("#registro_rapido_entrega").val();
	var registro_rapido_recibe 		= $("#registro_rapido_recibe").val();
	var registro_rapido_agente 		= $("#registro_rapido_agente").val();
	var registro_rapido_hospital 	= $("#registro_rapido_hospital").val();
	var registro_rapido_comentarios = $("#registro_rapido_comentarios").val();
	 
	var continua = 1;   
	var mensaje_error = "";   
	
	
	$("#registro_rapido_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});	
	
	if(continua == 1){
		$('#loading').show();  
		$.post("controller.php",   
			{ 	action 						: "agrega_registro_rapido",
				registro_rapido_folio		: registro_rapido_folio, 
				registro_rapido_fecha		: registro_rapido_fecha,  
				registro_rapido_entrega		: registro_rapido_entrega,
				registro_rapido_recibe		: registro_rapido_recibe,
				registro_rapido_agente		: registro_rapido_agente,
				registro_rapido_comentarios	: registro_rapido_comentarios,
				registro_rapido_hospital	: registro_rapido_hospital 
			}, end_agrega_registro_rapido);   		  
	}else{
		$("#respuesta_00").html("");   
		$("#respuesta_00").html('<div class="alert alert-danger">' + mensaje_error + '</div>');			
		setTimeout(function(){  
			$("#respuesta_00").html("");   
		}, 5000);
	
	}
