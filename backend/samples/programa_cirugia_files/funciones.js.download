/* ****************************************************************** */
/* *********    FUNCIONES BASICAS DE SESIONES DEL SISTEMA   ********* */
/* ****************************************************************** */
/* ****************************************************************** */

function cerrar_sesion_pruebas(){	 
	$.post("controller.php",
		{ 	action 	: "cerrar_sesion_pruebas"
		});
}

/* cerrar sesion */
function cerrar_sesion(){	 
	$.post("controller.php",
		{ 	action 	: "cerrar_sesion"
		}, end_cerrar_sesion);
}
function end_cerrar_sesion(xml){	   
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){  
			swal("Adios !", $(this).find("alias_usuario").text(), "success");
			window.location.href  = "index.php";
			//valida_sesion();			 
		}else{
			swal("Error !", $(this).find("result_text").text(), "warning"); 
		}
	});
} 

function valida_sesion(){ 

	$.post("controller.php", 
		{ action : "valida_sesion" 
		}, end_valida_sesion);   
} 
function end_valida_sesion(xml){
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){
			$("#nombre_usuario").html($(this).find("usuario").text() + " | " + $(this).find("sucursal").text() );
						
		}else{
				window.location.href  = "index.php";  
			//	alert("sesion no valida");
		}
	});
}


/* ****************************************************************** */
/* ****************************************************************** */
/* *********  IMPRIMIR DIVERSOS PDF DEL SISTEMA   ********* */
/* ****************************************************************** */
/* ****************************************************************** */
  

 
function imprimir_pdf_entregar(id_cirugia){     
	
	if(id_cirugia > 0){ 
		
		$("#loading").show();
	
		$.post("controller.php", 
			{ 	action : "imprimir_pdf_entregar",  
				id_cirugia: id_cirugia 
			}, end_imprimir_pdf_entregar);  		 
	}
} 
function end_imprimir_pdf_entregar(xml){	 
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){

			$("#loading").hide(); 
			 
			window.open(
				$(this).find("filepath").text(),
				'_blank'
			);		
		}else{
			$("#loading").hide();
			swal("Error", "ocurrio un error al intentar imprimir el PDF", "error");
		}			
	});
}

function imprimir_pdf_cirugia(id_cirugia){    
	
	if(id_cirugia > 0){ 
		$.post("controller.php",  
			{ 	action : "valida_imprimir_pdf_cirugia",  
				id_cirugia: id_cirugia 
			}, end_valida_imprimir_pdf_cirugia);  		 
	}
}  
function end_valida_imprimir_pdf_cirugia(xml){	 
	$(xml).find("response").each(function(i){		 
		
		var id_cirugia = $(this).find("id_cirugia").text();
		var historico = $(this).find("historico").text();
		
		if ($(this).find("result").text()=="ok"){
			
				$.post("controller.php", 
					{ 	action : "imprimir_pdf_cirugia",  
						id_cirugia: id_cirugia 
					}, end_imprimir_pdf_cirugia);  		 
			
		}else{
			 
			swal({    
				title: "Esta hoja ya ha sido impresa ¿Desea continuar?",   
				text: "Historico de impresiones \n" + historico,   
				/*type: "warning",    */
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true 
			}, function(){ 		  
			
				$.post("controller.php", 
					{ 	action : "imprimir_pdf_cirugia",  
						id_cirugia: id_cirugia 
					}, end_imprimir_pdf_cirugia); 
					
			}); 		
			
			
			
			
		}			
	});
}

function end_imprimir_pdf_cirugia(xml){	 
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){ 				 
			window.open(
				$(this).find("filepath").text(),
				'_blank'
			);		
		}else{
			swal("Error", "ocurrio un error al intentar imprimir el PDF", "error");
		}			
	});
} 
  
