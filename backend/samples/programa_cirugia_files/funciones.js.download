/* solicitudes de venta directa*/
function iniciar_solicitud_venta(){  
	var cliente 		= $("#nuevo_solicitud_cliente").val();  
	var comentarios 	= $("#nuevo_solicitud_comentarios").val(); 
	
	var id_vendedor 	= $("#id_vendedor").val();  
	var id_estado 		= $("#id_estado").val();  
	var ciudad 			= $("#ciudad").val();  
	var id_hospital 	= $("#id_hospital").val();  
		
	//	var comentarios = "";
	var continua = 1;	
	
	$("#nuevo_venta_directa_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});		 
	
	$("#nuevo_venta_directa_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			$(this).addClass('is-invalid'); 
			continua = 0;
			mensaje_error = "verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
			$(this).removeClass("is-invalid");
		}		
	});		
	
	 
	
	if(continua == 1){
		$.post("controller2.php",    
		{ 	action 		: "iniciar_solicitud_venta",
			cliente 	: cliente , 
			comentarios : comentarios 
		}, end_iniciar_solicitud_venta); 
	}	
}   
function end_iniciar_solicitud_venta(xml){  
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){  
			$("#id_solicitud_venta").val($(this).find("id_solicitud_venta").text()); 			
			$("#btn-guardar_solicitud_venta").removeClass("d-none"); 
			//$("#btn-imprimir_pdf_venta_directa").removeClass("d-none"); 
			$("#btn-iniciar_solicitud_venta").addClass("d-none");	 	
			
			$("#nuevo_solicitud_cliente").prop('disabled', true); 
			$("#nuevo_solicitud_comentarios").prop('disabled', true);		 			
			$("#id_vendedor").prop('disabled', true);		 			
			$("#id_estado").prop('disabled', true);		 			
			$("#ciudad").prop('disabled', true);		 			
			$("#id_hospital").prop('disabled', true);		 			
		}
	});
}   

function registrar_solicitud_venta(){	
		
	var id_solicitud_venta 	= $("#id_solicitud_venta").val(); 
	var referencia 			= $("#nuevo_solicitud_referencia").val();
	var cantidad 			= $("#nuevo_solicitud_cantidad").val(); 
	var continua = 1;   	
	
	if(id_solicitud_venta == "0"){
		continua = 0; 
		//alert("Por favor inicie el registro de Solicitud de Venta Directa");
		$("#respuesta").html('<div class="alert alert-danger">Por favor inicie el registro de Solicitud de Venta Directa</div>');
	}else{
		if(cantidad == "0" || cantidad == ""){
			continua = 0; 
			//alert("Indique una cantidad mayor a cero");
			$("#respuesta").html('<div class="alert alert-danger">Por favor Indique una cantidad mayor a cero</div>');
		}else{
			if(referencia == ""){
				continua = 0; 
				//alert("Por favor registre una REFERENCIA");
				$("#respuesta").html('<div class="alert alert-danger">Por favor registre una REFERENCIA</div>');
			}	
		}
	}
	
	
	if(continua == 1){
		
		$("#respuesta").html("");  
			
		$('#loading').show();   
		$.post("controller2.php",  
			{ 	action 				: "registrar_solicitud_venta",
				id_solicitud_venta	: id_solicitud_venta,
				referencia			: referencia,
				cantidad			: cantidad 
			}, end_registrar_solicitud_venta);  		 
	}  
}
function end_registrar_solicitud_venta(xml){
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){			
			//$('#nuevo_salida_form').trigger("reset"); 
			$('#nuevo_solicitud_referencia').val("");
			$('#nuevo_venta_directa_cantidad').val("1");
			$('#loading').hide();		 

			$("#respuesta").html("");  
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			
			setTimeout(function(){  
				$("#respuesta").html("");  
			}, 5000);	 
  
			/* llena la tabla*/ 
			//llenar_tabla_venta_directa();
			llenar_tabla_solicitud_venta();
			
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});   
} 
function guardar_solicitud_venta(){	
	//	location.reload();
	
	/* Ahora se guarda la solicitud como CX */
	var id_solicitud_venta 	= $("#id_solicitud_venta").val(); 
	
	var id_vendedor 	= $("#id_vendedor").val();  
	var id_estado 		= $("#id_estado").val();  
	var ciudad 			= $("#ciudad").val();  
	var id_hospital 	= $("#id_hospital").val();  
	 
	$.post("controller6.php",   
		{ 	action 				: "guardar_solicitud_venta",
			id_solicitud_venta	: id_solicitud_venta, 
			id_vendedor			: id_vendedor,  
			id_estado			: id_estado, 
			ciudad				: ciudad, 
			id_hospital			: id_hospital
		}, end_guardar_solicitud_venta);  	 
			
} 
function end_guardar_solicitud_venta(xml){
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){			
			
			$('#loading').hide();
			swal("Correcto",$(this).find("result_text").text(),"success");
			setTimeout(function(){  
				location.reload();
			}, 2000);	 
  			
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
}



function leer_csv_solicitud_venta(){      
	var archivo_csv 		= $("#csv_file").val();	
	var id_solicitud_venta 	= $("#id_solicitud_venta").val(); 
	var continua = 1;
	
	if(id_solicitud_venta == "0"){
		continua = 0; 
		$("#respuesta_2").html('<div class="alert alert-danger">Por favor inicie el registro de Solicitud de Venta Directa</div>');
	}
	
	if(archivo_csv == ""){
		continua = 0;
		$("#respuesta_2").html('<div class="alert alert-danger">Por favor seleccione un archivo CSV</div>');
	}
	
	if(continua == 1){
		$.post("controller2.php", 
			{ 	action 					: "leer_csv_solicitud_venta", 
				archivo_csv 			: archivo_csv,
				id_solicitud_venta 		: id_solicitud_venta
			}, end_leer_csv_solicitud_venta);  
	}
}   
function end_leer_csv_solicitud_venta(xml){   
	swal.close() 
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){	
		
			$("#csv_file").val("");
			$("#fileupload").val(""); 
			
			llenar_tabla_solicitud_venta();
			//swal("carga exitosa");
			$("#respuesta_2").html('<div class="alert alert-sucess">Registros cargados exitosamente.</div>');
		}
	});
}



/* venta directa */
function iniciar_venta_directa(){  
	var id_solicitud 	= $("#id_solicitud").val(); 
	var vendedor 		= $("#nuevo_venta_vendedor").val(); 
	var hospital 		= $("#nuevo_venta_hospital").val(); 
	var comentarios 	= $("#nuevo_venta_comentarios").val(); 	 
	var continua = 1;	
	$("#nuevo_venta_directa_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});		
	if(continua == 1){
		$.post("controller2.php",    
		{ 	action : "iniciar_venta_directa",
			id_solicitud : id_solicitud , 
			vendedor : vendedor , 
			hospital : hospital , 
			comentarios : comentarios 
		}, end_iniciar_venta_directa); 
	}	
}  
function end_iniciar_venta_directa(xml){ 
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){ 
			$("#id_venta_directa").val($(this).find("id_venta_directa").text()); 			
			$("#btn-guardar_venta_directa").removeClass("d-none"); 
			$("#btn-imprimir_pdf_venta_directa").removeClass("d-none"); 
			$("#btn-iniciar_venta_directa").addClass("d-none");	 
			$("#nuevo_venta_vendedor").prop('disabled', true);			
			$("#nuevo_venta_hospital").prop('disabled', true);			
			$("#nuevo_venta_comentarios").prop('disabled', true);					
		}
	});
}   

function guardar_venta_directa(){	
	var id_venta_directa 	= $("#id_venta_directa").val();	 		
	
	$("#btn-regresar").click();
	
	$.post("controller2.php",     
		{ 	action : "guardar_venta_directa",
			id_venta_directa : id_venta_directa 
		}, end_guardar_venta_directa); 	
} 
function end_guardar_venta_directa(xml){ 
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){ 
			$("#id_venta_directa").val("0"); 			
			$("#btn-guardar_venta_directa").addClass("d-none");  
			$("#btn-imprimir_pdf_venta_directa").addClass("d-none"); 
			$("#btn-iniciar_venta_directa").removeClass("d-none");		
			$("#nuevo_venta_vendedor").prop('disabled', false);			
			$("#nuevo_venta_hospital").prop('disabled', false);			
			$("#nuevo_venta_comentarios").prop('disabled', false);		  
			$('#nuevo_venta_directa_form').trigger("reset"); 	 
			$("#table_venta_directa").html("");	   
			$("#cant_articulos").html("");	 
			$("#nuevo_venta_directa_codigo").val(""); 
			$("#nuevo_venta_directa_cantidad").val("0"); 	
			swal("Venta correcta","La venta se guardo correctamente","success");
			
			document.getElementById("btn-aceptar_venta_directa").disabled = true;
			$("#btn-aceptar_venta_directa").addClass("d-none");	 
			
		}else{
			//alert($(this).find("result_text").text());
			var morivo_error = $(this).find("result_text").text();
			swal("Ocurrio un error",morivo_error,"error");
			
			
			$("#btn-guardar_venta_directa").removeClass("d-none");	 
			$("#btn-aceptar_venta_directa").addClass("d-none");	 
		}
	});  
}   

function validar_venta_directa(){	

	// $("#disparamodal").click(); 
	document.getElementById("btn-aceptar_venta_directa").disabled = true;
	$("#btn-imprimir_pdf_venta_directa").removeClass("d-none"); 
	$("#btn-iniciar_venta_directa").addClass("d-none");	 
	$("#btn-guardar_venta_directa").addClass("d-none");	 
	$("#btn-aceptar_venta_directa").removeClass("d-none");	 
	
	$(".contador").removeClass("d-none");
	
	var seconds = 8; 
	// Update the count down every 1 second
	xinterval = setInterval(function() { 
		// Display the result in the element with id="demo"
		document.getElementById("contador").innerHTML = seconds;
		
		seconds--;
		// If the count down is finished, write some text
		if (seconds < 0) { 
			clearInterval(xinterval);  
			$("#btn-aceptar_venta_directa").removeClass("d-none");	 
			document.getElementById("contador").innerHTML = "";
			document.getElementById("btn-aceptar_venta_directa").disabled = false;
			$(".contador").addClass("d-none");
		}
	}, 1000);
} 

function registrar_venta_directa(){	
	var id_venta_directa 	= $("#id_venta_directa").val();	 	 
	var codigo 				= $("#nuevo_venta_directa_codigo").val(); 	 
	var referencia 			= $("#nuevo_venta_directa_referencia").val(); 	 
	var lote 				= $("#nuevo_venta_directa_lote").val(); 	 
	var cantidad 			= $("#nuevo_venta_directa_cantidad").val(); 
	var precio 				= "0"; 
	var continua = 1;   	
	
	clearInterval(xinterval);  
	document.getElementById("contador").innerHTML = "";
	document.getElementById("btn-aceptar_venta_directa").disabled = true;
	$("#btn-guardar_venta_directa").removeClass("d-none");	 
	$("#btn-aceptar_venta_directa").addClass("d-none");	 
	$(".contador").addClass("d-none");
	
	if(id_venta_directa == "0"){ 
		continua = 0;  
		swal("Ocurrio un error","Por favor inicie el registro de la venta","error");
	}	
	
	if(codigo == "" && referencia == "" && lote == ""){
		continua = 0; 
		//swal("Ocurrio un error","Escanie codigo o escriba lote o referencia","error");
	}
	
	if(cantidad <= 0){
		continua = 0; 
		swal("Ocurrio un error","La cantidad debe ser mayor a cero","error");
	}
	
	if(continua == 1){ 
		$('#loading').show();    
		$.post("controller2.php",  
			{ 	action 				: "registrar_venta_directa",
				id_venta_directa	: id_venta_directa,    
				codigo				: codigo, 
				referencia			: referencia, 
				lote				: lote, 
				cantidad			: cantidad,  
				precio				: precio 
			}, end_registrar_venta_directa);  		 
	}  
}
function end_registrar_venta_directa(xml){
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){			
			//$('#nuevo_salida_form').trigger("reset"); 
			$('#nuevo_venta_directa_codigo').val("");
			$('#nuevo_venta_directa_cantidad').val("1");
			$('#nuevo_venta_directa_codigo').focus();
			$('#loading').hide();		 

			$("#respuesta").html("");  
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			
			setTimeout(function(){  
				$("#respuesta").html("");   
			}, 5000);	
  
			/* llena la tabla*/ 
			//llenar_tabla_venta_directa();
			llenar_tabla_venta_directa_tmp();
			
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
}

