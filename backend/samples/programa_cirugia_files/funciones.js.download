function prestar_set(){ 
	   
	var id_set 						= $("#nuevo_set_id").val();  	
	var id_sucursal_destino 		= $("#traspasar_set_sucursal_destino").val();  
	var prestamo_set_fecha 			= $("#prestamo_set_fecha").val();  
	var prestamo_set_comentarios 	= $("#prestamo_set_comentarios").val();  
	var continua = 1;
	
	$("#nuevo_prestamo_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "Verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});	
		
	$("#nuevo_prestamo_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "Verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});	
		
	if(continua == 1 && id_sucursal_destino != "0"){
		
		prestamo_set_fecha = conviertefechasql(prestamo_set_fecha); 
		
		$.post("controller2.php",  
			{ 	action 						:"prestar_set",
				id_set 						: id_set,			 
				id_sucursal_destino 		: id_sucursal_destino,					 
				prestamo_set_fecha 			: prestamo_set_fecha,					 
				prestamo_set_comentarios 	: prestamo_set_comentarios			 		 
			},end_prestar_set);		 
	}else{
		$("#respuesta").html('<div class="alert alert-danger">' + mensaje_error + '</div>');		

		setTimeout(function(){
			$("#nuevo_prestamo_form .obligatorio").removeClass("form-control-danger");
			$("#nuevo_prestamo_form .obligatorio_select").removeClass("form-control-danger");
			$("#respuesta").html("");
		}, 3000);	
	}	 
}      
function end_prestar_set(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			swal("Correcto", "El prestamo se guardó correctamente.", "success");
			setTimeout(function(){ 
				llenar_formulario_set();
				llenar_tabla_prestamos_set(); 
				$("#nuevo_prestamo_form").trigger("reset");
			}, 1000);	
		}else{
			swal("Cuidado", $(this).find("result_text").text(), "error");
		}
	});
} 


