	var set_destino = $("#selecciona_set_destino").val();
		
	if(set_destino > 0){
		$.post("controller.php",
			{ 	action 				: "transferir_producto_set",
				set_destino 		: set_destino, 
				id_producto_set 	: id_producto_set 
