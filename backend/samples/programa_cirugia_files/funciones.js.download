function reportar_auditoria_interna(){
 
	var id_auditoria = $("#id_auditoria").val();
	
	var continua 		= 1;		 
	var reporte 		= []; 
	var reporte_string 	= ""; 
	var aidi 			= "";
	var cantidad_paso 	= "";	

	$( ".input_auditoria" ).each(function( index ) {		
		cantidad_paso = $(this).find("input[name=cantidad]").val();		
		aidi = ($(this).find("input[name=aidi]").val()) + "|" + cantidad_paso;
		reporte.push(aidi); 		
	});  
	
	var reporte_string = reporte.join(",");
		
	if(continua == 1){		
		swal({    
			title: "¿Desea enviar esta Auditoria Interna?",   
			text: "Esta accion es definitiva y no podrá volver a realizar la auditoria.",   
			/*type: "warning",    */
			showCancelButton: true,    
			confirmButtonColor: "green",   
			confirmButtonText: "Si, Enviar Auditoria",  
			cancelButtonText: "Modificar cantidades",   
			closeOnConfirm: true 
		}, function(){ 		  
			$.post("controller3.php",  
				{ 	action :"reportar_auditoria_interna", 
					id_auditoria : id_auditoria,
					reporte_string 	: reporte_string			 
				},end_reportar_auditoria_interna);
		}); 
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
}  
