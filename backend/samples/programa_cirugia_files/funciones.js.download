} 
function end_buscar_lavado_codigo(xml){ 
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	
 
			$("#nuevo_set_id").val($(this).find("id_set").text()); 
			$("#nuevo_instrumental_id").val($(this).find("id_instrumental").text()); 
			$("#lavado_nombre_set").val($(this).find("nombre").text()); 
			$("#id_embalaje").val($(this).find("id_embalaje").text());   
			
			var tipo = $(this).find("tipo").text();
			var id_set = $(this).find("id_set").text();
			var id_instrumental = $(this).find("id_instrumental").text();
			//alert(tipo);
			$( "#lavado_codigo_set" ).prop( "disabled", true );
			llenar_tabla_productos_lavado(tipo, id_set, id_instrumental);
			
			$( "#btn-lavado_buscar_set" ).hide();
			$( "#btn-lavado_reiniciar" ).show();
			
			
			/*
			if(tipo == "set"){
				alert("set");
				$("#table_productos_instrumental").html("");
				llenar_tabla_productos_set(); 
			}else if(tipo == "instrumental"){
				alert("instr");
				$("#table_productos_set").html("");
				llenar_tabla_productos_instrumental(); 
			}
			*/
			$('#loading').hide();			 
		}else{
			$('#loading').hide();
			$("#respuesta_01").html("");   
			$("#respuesta_01").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');			
			setTimeout(function(){  
				$("#respuesta_01").html("");   
			}, 2000);	
		}
				
	});
}

