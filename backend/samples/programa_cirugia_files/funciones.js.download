// PROPIEDAD DE EXORTA SET IMPLANTES ADICIONALES ADICIONAL DE HOMBRO 3 CAJA NUMERO 1

function end_valida_caducos_agrega_minialmacen_cirugia(xml){ 
	$(xml).find("response").each(function(i){ 
		var id_set 		= $("#id_set_minialmacen").val();	
		var id_cirugia 	= $("#surtir_cirugia_id").val();
		var alerta_caducidad = $(this).find("alerta").text();
		
		var continua = 1;  
		
		if(id_set == 0 || id_set == ""){
			continua = 0;
			return false;
		}
				
		if($(this).find("result").text()=="ok"){
			/* no hay productos caducos - entra directo */			
			if(continua == 1){ 
				$('#loading').show(); 		
				$.post("controller.php",  
					{ 	action 		: "agrega_minialmacen_cirugia",
						alerta_caducidad	: alerta_caducidad, 
						pin			: "NA", 
						id_set		: id_set, 
						id_cirugia	: id_cirugia
					}, end_agrega_minialmacen_cirugia);   				
			}else{
				swal("Cuidado","Ocurrió un error inesperado. Por favor vuelva a intentar.","error");					
			}
		}else{				
			if(alerta_caducidad > 0){				
				//	swal("Cuidado, los siguiente productos tienen fecha de caducidad proxima o vencida",$(this).find("alertaText").text(),"error");				
				swal({
					title: "¡ ALERTA !",
					text: $(this).find("alertaText").text(),
					content: "input",
					button: { 
						text: "Confirmo de Enterado y Autorizo Continuar",
						closeModal: true, 
					},
				}) 
				.then(pin => {
					if (!pin){
						//	swal("No se especificó un motivo. No se canceló la remisión");
						swal("Error","No se autorizó el surtido de Activo con producto vencido", "error");
					}else{
						$('#loading').show(); 
						$.post("controller.php", 
							{ 	action 		: "agrega_minialmacen_cirugia",
								pin			: pin, 
								alerta_caducidad	: alerta_caducidad, 
								id_set		: id_set, 
								id_cirugia	: id_cirugia
							}, end_agrega_minialmacen_cirugia);   
					}  
				})
			}
		}	
	}); 
}
