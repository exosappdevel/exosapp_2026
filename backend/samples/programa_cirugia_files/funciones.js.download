/* Inventario*/
function guardar_inventario(){ 	

	var id_inventario				= $("#id_inventario").val(); 
	var inventario_codigo_2			= $("#inventario_codigo_2").val(); 
	var inventario_lote				= $("#inventario_lote").val(); 
	var inventario_caducidad		= $("#inventario_caducidad").val(); 
	var inventario_area				= $("#inventario_area").val(); 
	var inventario_subarea			= $("#inventario_subarea").val();  
	var inventario_nivel			= $("#inventario_nivel").val(); 
	var inventario_cantidad			= $("#inventario_cantidad").val(); 
	var inventario_ultimo_costo_id	= $("#inventario_ultimo_costo_id").val(); 
	var inventario_ultimo_costo		= $("#inventario_ultimo_costo").val(); 
	 
	var id_producto					= $("#id_producto").val(); 
	var continua = 1;
	
	if(id_inventario == 0 || id_inventario == "" || id_producto == "0" || id_producto == ""){
		continua = 0;
	}	
	 
	if(continua == 1){ 
		$.post("controller.php", 
			{ 	action :"guardar_inventario",   
				id_producto 				: id_producto,   
				id_inventario 				: id_inventario,   
				inventario_lote 			: inventario_lote,  
				inventario_codigo_2 		: inventario_codigo_2,  
				inventario_caducidad 		: inventario_caducidad,  
				inventario_area 			: inventario_area,  
				inventario_subarea 			: inventario_subarea,  
				inventario_nivel 			: inventario_nivel,   
				inventario_ultimo_costo 	: inventario_ultimo_costo,  
				inventario_ultimo_costo_id 	: inventario_ultimo_costo_id,  
				inventario_cantidad 		: inventario_cantidad
			},end_guardar_inventario);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	} 
} 
function end_guardar_inventario(xml){	   
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){  
			$("#respuesta").html("");  
		}, 5000);		
	});
}  

 
