function traspasar_instrumental_sucursal(){ 
	   
	var id_instrumental = $("#nuevo_instrumental_id").val();  	
	var id_sucursal_destino = $("#traspasar_set_sucursal_destino").val();  
		
	if(id_sucursal_destino != "0"){ 
		$.post("controller2.php",  
			{ 	action 				:"traspasar_instrumental_sucursal",
				id_instrumental 	: id_instrumental,			 
				id_sucursal_destino : id_sucursal_destino					 
			},end_traspasar_set_sucursal);		 
	}	 
}      
function end_traspasar_set_sucursal(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			swal("Correcto", "El traspaso se realizó correctamente.", "success");
			setTimeout(function(){ 
				llenar_formulario_set();
			}, 1000);	
		}else{
			swal("Cuidado", $(this).find("result_text").text(), "error");
		}
	});
} 

	
	
function registrar_traspaso(){ 
	  
	var id_cirugia_origen = $("#id_cirugia").val();  	
	var codigo_cirugia_destino = $("#traspaso_destino").val();  
	var seleccionados = [];	
	var continua = 1;
	$("input:checkbox[name=traspaso]:checked").each(function(){
		seleccionados.push($(this).val());
	});	
	
	if(seleccionados.length == 0){ 
		continua = 0;
		swal("Cuidado", "Seleccione al menos un SET para traspasar", "error");
	}
	if(continua == 1){
		$.post("controller.php",  
			{ 	action :"registrar_traspaso",
				id_cirugia_origen 		: id_cirugia_origen,					 
				codigo_cirugia_destino 	: codigo_cirugia_destino,					 
				seleccionados 			: seleccionados					 
			},end_registrar_traspaso);		
	 
	}
	 
}      
function end_registrar_traspaso(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			swal("Correcto", "El traspaso se realizó correctamente.", "success");
			setTimeout(function(){
				$("#respuesta").html("");  
				window.location.href  = "ver_cirugias.php"; 
			}, 1000);	
		}else{
			swal("Cuidado", $(this).find("result_text").text(), "error");
		}
	});
} 
    
function traspasar_entrada(){ 
	  
	var id_entrada = $("#id_entrada").val();  	
	var sucursal_destino = $("#selecciona_sucursal").val();  
	
	if(id_entrada > 0 && sucursal_destino > 0){

		swal({   
			title: "Desea traspasar estra Entrada?",   
			text: "Esta accion es definitiva",   
			/*type: "warning",    */
			showCancelButton: true,    
			confirmButtonColor: "green",   
			confirmButtonText: "Si, continuar",  
			cancelButtonText: "Cancelar Traspaso",   
			closeOnConfirm: true 
		}, function(){ 		  
			$.post("controller2.php",   
				{ 	action 				: "traspasar_entrada",
					id_entrada 			: id_entrada,					 
					sucursal_destino 	: sucursal_destino				 
				},end_traspasar_entrada);		
		});  		
	}else{
		swal("Cuidado", "Por favor seleccione Sucursal Destino", "error");
	}
}      
function end_traspasar_entrada(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			swal("Correcto", "El traspaso se realizó correctamente.", "success");
			llenar_tabla_entradas_almacen_detalle();
		}else{
			swal("Cuidado", "Ocurrio un error. Por favor verifique", "error");
		}
	});
} 
  
function traspasar_salida(){ 
	  
	var id_salida 			= $("#id_salida").val();  	
	var sucursal_destino 	= $("#selecciona_sucursal").val();  
	 
	if(id_salida > 0 && sucursal_destino > 0){
 
		swal({   
			title: "Deseas traspasar estra Salida?",   
			text: "Esta accion es definitiva",   
			/*type: "warning",    */
			showCancelButton: true,    
			confirmButtonColor: "green",   
			confirmButtonText: "Si, continuar",  
			cancelButtonText: "Cancelar Traspaso",   
			closeOnConfirm: true 
		}, function(){ 		  
