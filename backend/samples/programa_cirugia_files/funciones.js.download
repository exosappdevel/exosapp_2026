			$("#id_inventario").val("0");
			$("#agregar_producto_cirugia_form").trigger("reset");		
			llenar_tabla_producto_cirugia();
			$('#loading').hide();			 
		}else{
			$('#loading').hide();
			$("#id_inventario").val("0");
			swal("Alerta",$(this).find("result_text").text(),"error");
		}
	});
} 

