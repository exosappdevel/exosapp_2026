function agregar_permiso_subsubmenu(){
	
	var id_tipo_usuario 	= $("#id_tipo_usuario").val();	
	var id_almacen 			= $("#id_almacen").val();
	var id_subsubmenu 		= $("#selecciona_submenu").val();
	var continua = 1;    

	if(id_tipo_usuario == "" || id_tipo_usuario < 0 || id_tipo_usuario == "0"){
		continua = 0;
		return false;
	}
	if(id_subsubmenu == "" || id_subsubmenu < 0 || id_subsubmenu == "0"){
		continua = 0;
		return false;
	}
	if(id_almacen == "" || id_almacen < 0 || id_almacen == "0"){
		continua = 0;
		return false;
	}
	 
	if(continua == 1){
		$('#loading').show();   
		$.post("controller.php", 
			{ 	action 		: "agregar_permiso_subsubmenu",
				id_tipo_usuario		: id_tipo_usuario, 
				id_almacen			: id_almacen, 
				id_subsubmenu		: id_subsubmenu
			}, end_agregar_permiso_subsubmenu);  		  
	}
  
} 
function end_agregar_permiso_subsubmenu(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){		
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			setTimeout(function(){  
				$("#respuesta").html("");    
			}, 2000);	 
			llenar_tabla_permisos_subsubmenu();	 	 
		}else{
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	}); 
} 
   
