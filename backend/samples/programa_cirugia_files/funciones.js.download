function imprimir_lavado_qr(){
	
	var id_embalaje 	= $("#id_embalaje").val();
	

	var url = "impresion_tickets/imprimir_lavado_qr.php";
	var imprimir_venta_action = "imprimir_lavado_qr";

	
	if(detectOS() == "Android")
	{	
		$.get(url, {action			: imprimir_venta_action, 
					id_embalaje 	: id_embalaje
					},function(data){
						//alert(data);
						window.location.href = data;
					}).fail(function() {
						//alert( "Error: URL para procesar la impresión no pudo ser alcanzada" );
						swal("Error !", "URL para procesar la impresión no pudo ser alcanzada", "warning");
					})
	}else if(detectOS() == "Windows"){
						
				$.get(url, {action			: imprimir_venta_action, 
							id_embalaje 	: id_embalaje
						},function(data){
							//alert(data);
							//window.location.href = data;
					
							var printerName = $("#printers").val();
							//alert("Print on " + printerName);

							var toprint = data.replace("intent:base64,","");
							toprint = toprint.replace("#Intent;scheme=rawbt;package=ru.a402d.rawbtprinter;end;","");
							var config = qz.configs.create(printerName);       // Create a default config for the found printer
							var printData = [{
								type: 'raw',
								format: 'base64',
								data: toprint
							}];   

							qz.print(config, printData).catch(displayError);
					
							
					
						}).fail(function() {
							//alert( "Error: URL para procesar la impresión no pudo ser alcanzada" );
							swal("Error !", "URL para procesar la impresión no pudo ser alcanzada", "warning");
						})
	}
}
