function iniciar_salida_merma(){  

	var motivos 	= $("#nuevo_salida_comentarios").val(); 	
	var es_venta = 0;
	var continua = 1;
	
	if(motivos == ""){
		swal("Cuidado","Por favor escriba el motivo de traspado","error");
		return false;
		continua = 0;
	}			
	if(continua == 1){
		$.post("controller.php",   
		{ 	action 		: "iniciar_salida_merma",
			motivos 	: motivos
		}, end_iniciar_salida_merma);  
	}	
} 
function end_iniciar_salida_merma(xml){ 
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){ 
			$("#id_salida").val($(this).find("id_salida").text()); 			
			$("#btn-guardar_salida_merma").removeClass("d-none");
			//$("#btn-imprimir_pdf_salida").removeClass("d-none"); 
			$("#btn-iniciar_salida_merma").addClass("d-none");		 
			$("#nuevo_salida_comentarios").prop('disabled', true);			
			//$("#selecciona_sucursal").prop('disabled', true);				
		}
	});
}

function iniciar_salida_rapida(){  

	var motivos 	= $("#nuevo_salida_comentarios").val(); 
	//var es_venta 	= $("#nuevo_salida_esventa").val();
	var sucursal_traspaso = $("#selecciona_sucursal").val();	
	var es_venta = 0;
	var continua = 1;
	
	if(motivos == ""){
		swal("Cuidado","Por favor escriba el motivo de traspado","error");
		return false;
		continua = 0;
	}		
	if(sucursal_traspaso == "0"){
		swal("Cuidado","Por favor seleccione sucursal destino","error");
		return false;
		continua = 0;
	}		
	
	if(continua == 1){
		$.post("controller.php",   
		{ 	action 		: "iniciar_salida_rapida",
			motivos 	: motivos , 
			es_venta 	: es_venta ,  
			sucursal_traspaso : sucursal_traspaso 
		}, end_iniciar_salida_rapida); 
	}	
} 
function end_iniciar_salida_rapida(xml){ 
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){ 
			$("#id_salida").val($(this).find("id_salida").text()); 			
			$("#btn-guardar_salida").removeClass("d-none");
			//$("#btn-imprimir_pdf_salida").removeClass("d-none"); 
			$("#btn-iniciar_salida_rapida").addClass("d-none");		
 
			$("#nuevo_salida_comentarios").prop('disabled', true);			
			$("#selecciona_sucursal").prop('disabled', true);			
			
		}
	});
}

function iniciar_registro_salida(){      	
	var iniciar = $("#iniciar_registro").val();	
	var tecnico = $("#nuevo_salida_tecnico").val();
	var continua = 1;	
	if(tecnico == "0"){ 
		alert("por favor seleccione tecnico");
		continua = 0;
	}			
	if(continua == 1){		
		if(iniciar == 0){  /* va a iniciar el registro */		
			$("#nuevo_salida_tecnico").prop('disabled', true);			
			$("#iniciar_registro").val("1");			
			$("#btn-iniciar_registro").removeClass("btn-primary");
			$("#btn-iniciar_registro").addClass("btn-danger");
			$("#btn-iniciar_registro").html("Guardar Registro de Entrada"); 			
			$("#btn-imprimir_pdf").removeClass("d-none");			
			/*asigna un valor de ID a  id_entrada_almacen */
			$.post("controller.php", 
				{ 	action : "iniciar_registro_salida",  
					tecnico : tecnico
				}, end_iniciar_registro_salida); 				
		}else if(iniciar == 1){  /* va a cerrar el registro */				
			var id_salida = $("#id_salida_almacen").val();			
			$.post("controller.php", 
				{ 	action : "guardar_registro_salida",  
					id_salida : id_salida 
				}, end_guardar_registro_salida); 				
		}	 		
	}	
}  
function end_iniciar_registro_salida(xml){ 
	swal.close()
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			 
			$("#id_salida_almacen").val($(this).find("id_salida").text());
		}
	});
} 
function end_guardar_registro_salida(xml){  
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			
			/* abrir pdf*/ 		
			$("#iniciar_registro").val("0"); 
			$("#id_salida_almacen").val("0"); 			
			$("#btn-imprimir_pdf").addClass("d-none");			
			$("#btn-iniciar_registro").removeClass("btn-danger");
			$("#btn-iniciar_registro").addClass("btn-primary");
			$("#btn-iniciar_registro").html("Iniciar Registro de Salida");				
			//alert($("#id_entrada_almacen").val()); 
			//$("#table_entrada_almacen").html("");		

			$("#nuevo_salida_tecnico").prop('enabled', true);		
			$("#nuevo_salida_tecnico").prop('disabled', false);		
			
		}
	});
}

