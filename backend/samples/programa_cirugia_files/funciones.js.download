function comparar_con_lista_maestra(){ 

	var id_set 	= $("#nuevo_set_id").val();	 
	
	$.post("controller3.php",   
		{ 	action 	: "comparar_con_lista_maestra",
			id_set 	: id_set,
		}, end_comparar_con_lista_maestra); 		
}   
function end_comparar_con_lista_maestra(xml){  
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){   
			$("#aviso_lista_maestra").css('background-color','green');  
			$("#aviso_lista_maestra").html('<h4 class="m-b-0 text-black" style="padding:50px; color:#FFF;">Esta caja cumple con la Lista Maestra</h4>');				
			$("#liga").html($(this).find("liga").text()); 
		}else{
			$("#aviso_lista_maestra").css('background-color','red');
			$("#aviso_lista_maestra").html('<h4 class="m-b-0 text-black" style="padding:50px; color:#FFF;">Esta caja NO cumple con la Lista Maestra</h4>');	
			$("#liga").html($(this).find("liga").text()); 
		}
	});
}

function imprimir_lista_activo_oficial(id_set){ 
	
	$.post("controller3.php",   
		{ 	action 	: "imprimir_lista_activo_oficial",
			id_set 	: id_set,
		}, end_imprimir_lista_activo_oficial); 		 
}   
function end_imprimir_lista_activo_oficial(xml){  
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){ 				
			window.open( $(this).find("filepath").text(), '_blank' );		
		}else{
			swal("Error", "ocurrio un error al intentar imprimir el PDF", "error");
		}		
	});
}
