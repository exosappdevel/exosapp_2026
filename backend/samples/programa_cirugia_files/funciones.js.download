/* *********    FUNCIONES PARA NOTIFICACIONES DEL SISTEMA   ********* */
/* ****************************************************************** */
/* ****************************************************************** */

function carga_avisos_criticos(){
	//alert("carga notificaciones");
	//return false; 
	$.post("controller7.php", 
		{ 	action 	: "carga_avisos_criticos"
		}, end_carga_avisos_criticos);
} 
function end_carga_avisos_criticos(xml){	   
	$(xml).find("response").each(function(i){		  
		if ($(this).find("result").text()=="ok"){  	 
			//	swal("AVISOS IMPORTANTES", $(this).find("aviso").text(), "warning");
		
			var id_aviso 	= $(this).find("id_aviso").text();
			var aviso 		= $(this).find("aviso").text();

			//	swal({
			//		title: "AVISOS IMPORTANTESN",
			//		text: "pruebas",
			//		content: {
			//			element: "input",
			//			attributes: {
			//			placeholder: "Tu nombre aquí",
			//			type: "text", 
			//			},
			//		},  
			//		buttons: ["Cancelar", "Aceptar"],
			//	})
 
			swal({
				title: "AVISOS IMPORTANTES", 
				text: $(this).find("aviso").text(),
				type: "input",
				showCancelButton: true,
				closeOnConfirm: false,
				inputPlaceholder: "CONFIRMA LEIDO CON TU PIN"
			}, function(inputValue) {
				if (inputValue === false) return false; // Si cancela
				if (inputValue === "") {
					swal.showInputError("POR FAVOR ESCRIBE TU PIN");
					return false; 
				}
				//	swal("¡Perfecto!", "Tu nombre es: " + inputValue, "success");
    
				$.post("controller7.php",
					{ 	action 	: "confirma_leido_aviso_critico",
						id_aviso : id_aviso,
						pin : inputValue 
				}, end_confirma_leido_aviso_critico);
		
			});

 
		}
	});
} 
function end_confirma_leido_aviso_critico(xml){	   
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){  	 
			swal("¡Perfecto!", "Has confirmado de Leido", "success");
		}else{
			swal("¡Cuidado!", $(this).find("result_text").text(), "error");
		}
	});
} 
 
 
 
function cargar_notificaciones(){
	//alert("carga notificaciones");
	//return false;
	$.post("controller.php",
		{ 	action 	: "cargar_notificaciones"
		}, end_cargar_notificaciones);
}
function end_cargar_notificaciones(xml){	   
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){  	 
			$("#div_alertas").html($(this).find("result_text").text());
			$("#numero_alertas").html($(this).find("contador").text());
		}
	});
} 
 
function eliminar_obsoletos(){	
	var fecha = new Date();
	var dia = fecha.getDate();
	//alert(dia);
	if(dia == 1){ 
		$.post("controller3.php",
		{ 	action 	: "eliminar_obsoletos"
		});
	}
}


