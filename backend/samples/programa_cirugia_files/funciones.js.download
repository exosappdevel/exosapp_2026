function buscar_entrada_referencia(){	
	var entrada_codigo = $("#entrada_codigo").val();
	var folio = $("#registro_rapido_folio").val();
	var continua = 1; 	
	
	if(entrada_codigo == ""){ 
		continua = 0;
		return false;	 
	}	
 
	if(folio == "0"){
		swal("Cuidado", "Por favor inicie el registro", "error");
		continua = 0;
		return false;
	}
	if(continua == 1){ 
		$.post("controller.php", 
			{ 	action : "buscar_entrada_referencia",
				entrada_codigo: entrada_codigo,
				folio : folio 
			}, end_buscar_entrada_referencia);  		 
	} 
} 
function end_buscar_entrada_referencia(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){ 			
			$("#entrada_referencia").val($(this).find("referencia").text()); 
			
			llenar_tabla_entrada_rapido(); 
			
			setTimeout(function(){  
				$("#entrada_codigo").val("");   
				$("#entrada_referencia").val("");   
				$("#entrada_codigo").focus();   
				
				valida_estatus_registro_rapido();
				
			}, 1000);
			
		}else{ 
			llenar_tabla_entrada_rapido();
			
			$("#respuesta_02").html("");   
			$("#respuesta_02").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');			
			setTimeout(function(){  
				$("#respuesta_02").html("");   
			}, 2000);	
		}
	});
}	   
	  	  
function buscar_salida_referencia(){	
	var salida_codigo = $("#salida_codigo").val();
	var folio = $("#registro_rapido_folio").val();
	var continua = 1; 	
	
	if(salida_codigo == ""){ 
		continua = 0;
		return false;	 
	}	 

	if(folio == "0"){
		swal("Cuidado", "Por favor inicie el registro", "error");
		continua = 0;
		return false;
	}
	if(continua == 1){ 
		$.post("controller.php", 
			{ 	action : "buscar_salida_referencia",
				salida_codigo: salida_codigo,
				folio : folio
			}, end_buscar_salida_referencia);  		 
	} 
} 
function end_buscar_salida_referencia(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){ 			
			$("#salida_referencia").val($(this).find("referencia").text()); 			 
			llenar_tabla_salida_rapido();
			
			setTimeout(function(){  
				$("#salida_codigo").val("");   
				$("#salida_referencia").val("");   
				$("#salida_codigo").focus();   
				
				valida_estatus_registro_rapido();
				
			}, 1000);
			
		}else{ 
			llenar_tabla_salida_rapido();
			
			$("#respuesta_01").html("");   
			$("#respuesta_01").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');			
			setTimeout(function(){  
				$("#respuesta_01").html("");   
			}, 2000);	
		}
	});
}	  



	  
function buscar_minialmacen_referencia(){	
	var codigo_set = $("#agregar_minialmacen_cirugia_codigo").val();
	var continua = 1; 	
	if(codigo_set == ""){ 
		continua = 0;
		//swal("Cuidado", "Por favor ingresa un codigo", "error");
		return false;	}	

	if(continua == 1){ 
		$.post("controller.php", 
			{ 	action : "buscar_minialmacen_referencia",
				codigo_set: codigo_set  
			}, end_buscar_minialmacen_referencia);  		 
	} 
} 
function end_buscar_minialmacen_referencia(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){ 			
			$("#agregar_minialmacen_cirugia_referencia").val($(this).find("referencia").text()); 
			$("#id_set_minialmacen").val($(this).find("id_set").text()); 	
			
			/* trigger click en agregar */
			$("#btn-agrega_minialmacen_cirugia").click(); 
			$("#btn-devolver_minialmacen_cirugia").click(); 
			
			/* trigger click en agregar para jornadas */
			$("#btn-agrega_minialmacen_jornada").click(); 
			//$("#btn-devolver_minialmacen_cirugia").click(); 
			
			
		}else{ 
			$("#agregar_minialmacen_cirugia_referencia").val(""); 
			$("#id_set_minialmacen").val(""); 
			$("#respuesta_01").html("");   
			$("#respuesta_01").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');			
			setTimeout(function(){  
				$("#respuesta_01").html("");   
			}, 2000);	
		}
	});
}
	  
function buscar_producto_inventario(){
	
	var id_producto 	= $("#id_producto").val(); 
	var codigo_2 		= $("#nuevo_entrada_codigo_2").val(); 
	var cantidad 		= $("#nuevo_entrada_cantidad").val();
	var sugerir 		= $("#nuevo_entrada_sugerir").val();
	var caducidad 		= $("#nuevo_entrada_caducidad_automatica").val();
	
	var nuevo_entrada_proveedor 		= $("#nuevo_entrada_proveedor").val();
	
	var continua 		= 1; 
	var doscaracteres 	= ""; 
	
	if(codigo_2 == ""){ 
		continua = 0;
		//swal("Cuidado", "Por favor ingresa un codigo", "error");
		return false;
	}	
	if(cantidad == "0" || cantidad == ""){ 
		continua = 0;
		//swal("Cuidado", "Por favor ingresa una cantidad", "error");
		return false;
	}
	
	
	
	//var codigo2_tam = codigo_2.length;	 
	//alert(codigo2_tam);
	
	if(codigo_2 != "" && codigo_2 != undefined){ 
		doscaracteres = codigo_2.substr(0, 2);
	}
	
	doscaracteres = "NA";
	
	if(continua == 1){  
		if(doscaracteres == "01"){  
			/* de manera general el codigo 1 inicia con "01" y muchas veces el usuario por error escanea el codigo 1 */
			/* entonces si detectamos que el codigo 2 inicia en 01 vamos a avisar al usuario que revise */ 		
			swal({    
				title: "ATENCION",   
				text: "El código 2 inicia con 01  ¿Es correcto? ",   
				type: "warning",
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",    
				confirmButtonText: "Si, es correcto",  
				cancelButtonText: "Modificar",   
				closeOnConfirm: true 
			}, function(){ 		

				swal.close();
				
				
				$.post("controller.php", 
					{ 	action : "buscar_producto_inventario",
						id_producto: id_producto, 
						codigo_2: codigo_2, 
						cantidad: cantidad,  
						sugerir: sugerir,    
						caducidad: caducidad,  
						nuevo_entrada_proveedor: nuevo_entrada_proveedor	  
					}, end_buscar_producto_inventario);  
			});
		}else{
			$.post("controller.php", 
				{ 	action : "buscar_producto_inventario",
					id_producto: id_producto, 
					codigo_2: codigo_2, 
					cantidad: cantidad,  
					sugerir: sugerir,    
					caducidad: caducidad,
					nuevo_entrada_proveedor: nuevo_entrada_proveedor							
				}, end_buscar_producto_inventario);  
		}
	} 
	
	/*
	if(continua == 1){ 
		$.post("controller.php", 
			{ 	action : "buscar_producto_inventario",
				id_producto: id_producto, 
				codigo_2: codigo_2, 
				cantidad: cantidad,  
				sugerir: sugerir,    
				caducidad: caducidad    
			}, end_buscar_producto_inventario);  		 
	}*/
 
}  
function end_buscar_producto_inventario(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){
			 
			/*altas de almacen*/  
			/*$("#nuevo_entrada_nueva_cantidad").val($(this).find("lote").text()); */
			$("#id_producto").val($(this).find("id_producto").text()); 
			 			
			$("#nuevo_entrada_lote").val($(this).find("lote").text()); 
			$("#nuevo_entrada_caducidad").val($(this).find("fecha_cad").text());
			$("#nuevo_entrada_area").val($(this).find("area").text());  
			$("#nuevo_entrada_subarea").val($(this).find("subarea").text());
			$("#nuevo_entrada_nivel").val($(this).find("nivel").text());
			$("#nuevo_entrada_nueva_cantidad").val($(this).find("nueva_cantidad").text());
			$("#nuevo_entrada_precio").val($(this).find("precio").text());  
			
			var id_inventario = $(this).find("id_inventario").text();
			var id_inventario_tmp = $(this).find("id_inventario_tmp").text(); 
			
			//alert(id_inventario);
			//alert(id_inventario_tmp);
			
			if(id_inventario_tmp == "NA" || id_inventario_tmp == "0")  
				$("#nuevo_entrada_id_inventario").val($(this).find("id_inventario").text()); 
			if(id_inventario == "NA" || id_inventario == "0")
				$("#nuevo_entrada_id_inventario").val($(this).find("id_inventario_tmp").text());
			
			
			
			
			
			if($(this).find("guarda_automatico").text() == "1"){				
				//registrar_entrada_inventario(); 
				
				var nuevo_entrada_automatico = $("#nuevo_entrada_automatico").val();
				if(nuevo_entrada_automatico == "1"){
					valida_caducidad(); 
				}
				
			}
			 
		}else{ 
			//$("#nuevo_entrada_lote").val(""); 
			//$("#nuevo_entrada_caducidad").val("");
			
			//$("#nuevo_entrada_area").val("");
			//$("#nuevo_entrada_nivel").val("");
			//$("#nuevo_entrada_subarea").val("");
			//$("#nuevo_entrada_id_inventario").val("0");
			//$("#nuevo_entrada_lote").val($(this).find("lote").text()); 
			//$("#nuevo_entrada_caducidad").val($(this).find("fecha_cad").text());
			//$("#nuevo_entrada_nueva_cantidad").val("0"); 
			
			$("#nuevo_entrada_lote").val($(this).find("lote").text()); 
			$("#nuevo_entrada_caducidad").val($(this).find("fecha_cad").text());
			$("#nuevo_entrada_area").val($(this).find("area").text());  
			$("#nuevo_entrada_subarea").val($(this).find("subarea").text());
			$("#nuevo_entrada_nivel").val($(this).find("nivel").text());
			$("#nuevo_entrada_nueva_cantidad").val($(this).find("nueva_cantidad").text());
			$("#nuevo_entrada_precio").val($(this).find("precio").text());  
			
			$("#respuesta").html("");  
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
			 
			var audio = document.getElementById("audio");
			audio.play();
			
			 
			document.getElementById('btn-registrar_entrada').focus();
			
			
			$("#id_producto").val("0");
			document.getElementById('buscar_producto_codigo').focus();
			 
			$("#buscar_producto_codigo").val("0");
			$("#nuevo_entrada_referencia").val("0");
			$("#nuevo_entrada_nombre").val("0");
			
			swal("Ocurrio un error","Ultimo producto escaneado - codigo 2: " + $(this).find("codigo_2").text(),"error");
			//saltar(event, "btn-registrar_entrada");
			
			
				
			/*
			setTimeout(function(){  
				$("#respuesta").html("");  
			}, 5000);	
			*/
			
			//swal("No hay inventario",$(this).find("result_text").text(),"warning");
		}
	});
}
	 
  
  
