function referencia_producto_set(){ 
	
	var id_minialmacen 	= $("#id_minialmacen").val();	
	var id_cirugia 		= $("#id_cirugia").val();	
	var referencia 		= $("#escanear_set_referencia").val();	
	var cantidad 		= $("#escanear_set_cantidad").val();	
	 
	var continua = 1;    

	if(referencia == "" || (cantidad == "" || cantidad == "0")){
		continua = 0;
	}
	 
	if(continua == 1){ 
		$('#loading').show();  
		$.post("controller.php", 
			{ 	action 		: "referencia_producto_set",
				id_minialmacen	: id_minialmacen, 
				id_cirugia		: id_cirugia,
				referencia		: referencia,
				cantidad		: cantidad
			}, end_referencia_producto_set);  		  
	}else{
		swal("Ocurrio un error","Escanea un código o escribe referencia y cantidad","error");
	}
		
 
} 
