function iniciar_resurtir_activo(){	
	var id_resurtir_historico 	= $("#id_resurtir_historico").val();
	/* si viene de resurtir set o instrumental*/
	var set_id 					= $("#nuevo_set_id").val();	
	var instrumental_id 		= $("#nuevo_instrumental_id").val();	
	
	/*si viene de resurtir para traspasar*/
	var id_cirugia 		= $("#id_cirugia").val();	
	var id_set 			= $("#id_set").val();	
	var id_instrumental = $("#id_instrumental").val();	
	
	$.post("controller3.php",   
			{ 	action 		: "iniciar_resurtir_activo",
				id_resurtir_historico	: id_resurtir_historico,
				set_id					: set_id,
				instrumental_id			: instrumental_id,
				id_cirugia				: id_cirugia,  
				id_set					: id_set,
				id_instrumental			: id_instrumental
			}, end_iniciar_resurtir_activo);  		  
			
}
function end_iniciar_resurtir_activo(xml){
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){	
		
			$("#btn-iniciar_resurtir_activo").hide();		
			$("#btn-guardar_resurtir_activo").show();	
			
			$("#btn-agrega_producto_set").show();		
			$("#btn-agrega_producto_instrumental").show();	
			$("#btn-resurtir_producto_set").show();	
			
			$("#agrega_producto_set_codigo").removeAttr("readonly");
			$("#agrega_producto_set_referencia").removeAttr("readonly");
			$("#agrega_producto_set_cantidad").removeAttr("readonly");
			$("#agrega_producto_set_lote").removeAttr("readonly");
			
			$("#agrega_producto_instrumental_referencia").removeAttr("readonly");
			$("#agrega_producto_instrumental_cantidad").removeAttr("readonly");
			$("#agrega_producto_instrumental_lote").removeAttr("readonly"); 
			
			$("#id_resurtir_historico").val($(this).find("id_resurtir_historico").text());
			
			$("#respuesta_1").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');				
			 				
			
		}else{
			$("#respuesta_1").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');				
				
				
			// $("#agrega_producto_set_codigo").attr("readonly","readonly");
			 
		}
		
		setTimeout(function(){  
				$("#respuesta_1").html("");    
			}, 3000);	 	
			
	});
} 
 
function guardar_resurtir_activo(){	
	var id_resurtir_historico 	= $("#id_resurtir_historico").val();
	
	$.post("controller3.php",   
		{ 	action 					: "guardar_resurtir_activo",
			id_resurtir_historico 	: id_resurtir_historico
		}, end_guardar_resurtir_activo);  		  
			
} 
function end_guardar_resurtir_activo(xml){
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	 
					
			llena_tabla_modal_resurtimientos_guardados();	
			
			llenar_formulario_set(); 
			llenar_tabla_productos_set(); 
			
			$("#btn-iniciar_resurtir_activo").show();		
			$("#btn-guardar_resurtir_activo").hide();	
			
			$("#btn-agrega_producto_set").hide();				
			$("#btn-agrega_producto_instrumental").hide();	
			$("#btn-resurtir_producto_set").hide();	 
			
			$("#agrega_producto_set_codigo").attr("readonly","readonly");
			$("#agrega_producto_set_referencia").attr("readonly","readonly");
			$("#agrega_producto_set_lote").attr("readonly","readonly");
			$("#agrega_producto_set_cantidad").attr("readonly","readonly");
			
			$("#agrega_producto_instrumental_referencia").attr("readonly","readonly");
			$("#agrega_producto_instrumental_cantidad").attr("readonly","readonly");
			
			$("#id_resurtir_historico").val("0");
			
			$("#table_surtir_activo_tmp").html(""); // borra tabla temporal
			
			$("#respuesta_1").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');				
			
			
			window.open(
				$(this).find("filepath").text(),
				'_blank'
			);		
			
			
			
		}else{
			$("#respuesta_1").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');				
				
				
			// $("#agrega_producto_set_codigo").attr("readonly","readonly");
			 
		}
		
		setTimeout(function(){  
				$("#respuesta_1").html("");    
			}, 3000);	 	
			
	});
} 
 
function llena_tabla_modal_resurtimientos_guardados(){	
	var id_set = $("#nuevo_set_id").val();	
	$.post("controller3.php",    
		{ 	action 	: "llena_tabla_modal_resurtimientos_guardados",
			id_set 	: id_set
		}, end_llena_tabla_modal_resurtimientos_guardados);	
} 
function end_llena_tabla_modal_resurtimientos_guardados(xml){
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	 					
			$("#tabla_resurtimientos_guardados").html($(this).find("tabla").text());			
		}
	});
}   
 
function eliminar_resurtimiento_guardado(id_resurtir){	
	$.post("controller3.php",    
		{ 	action 	: "eliminar_resurtimiento_guardado",
			id_resurtir 	: id_resurtir
		}, end_eliminar_resurtimiento_guardado);	
}  
function end_eliminar_resurtimiento_guardado(xml){
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	 					
			llena_tabla_modal_resurtimientos_guardados();		
		}
	});
} 
 
  
function continuar_resurtimiento_guardado(id_resurtir){	
 
	$("#id_resurtir_historico").val(id_resurtir);
	 
	$("#btn-cerrar_modal_resurtimientos_guardados").click();	
		
	$("#loading").show();	
	setTimeout(function(){  
		iniciar_resurtir_activo();
		llenar_tabla_surtir_activo_tmp();
		$("#loading").hide();	
	}, 2000);	 		
	
}   

 


 


function agrega_producto_set(){
	
	var id_set 		= $("#nuevo_set_id").val();	
	var codigo 		= $("#agrega_producto_set_codigo").val();	
	var referencia 	= $("#agrega_producto_set_referencia").val();
	var lote 		= $("#agrega_producto_set_lote").val();
	var cantidad 	= $("#agrega_producto_set_cantidad").val();	
	 
	var id_resurtir_historico 	= $("#id_resurtir_historico").val();
	
	var continua = 1;    

	if(cantidad == "" || cantidad < 0 || cantidad == "0"){
		continua = 0;
		$("#respuesta_1").html('<div class="alert alert-danger">La cantidad a agregar debe ser mayor a cero</div>');				
		setTimeout(function(){  
			$("#respuesta_1").html("");    
		}, 2000);	 			
			
		return false;
	}
	if(codigo == "" && referencia == "" && lote == ""){
		continua = 0;
		
		$("#respuesta_1").html('<div class="alert alert-danger">Por favor ingrese código, referencia o lote del producto.</div>');				
		setTimeout(function(){  
			$("#respuesta_1").html("");    
		}, 2000);	
		
		return false;
	}
		
	   
	if(continua == 1){
		$('#loading').show();  
		$.post("controller.php", 
			{ 	action 		: "agrega_producto_set_tmp",
				id_set		: id_set, 
				codigo		: codigo,   
				referencia	: referencia,  
				lote		: lote,  
				cantidad	: cantidad,
				id_resurtir_historico : id_resurtir_historico				
			}, end_agrega_producto_set);  		  
	}else{
		alert("Ocurrio un error");
	}
 
}
function end_agrega_producto_set(xml){
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){	
			$("#agregar_set_form").trigger("reset");		
			//	llenar_tabla_productos_set();
			llenar_tabla_surtir_activo_tmp();
			$('#loading').hide();			 
			
			setTimeout(function(){  
				$("#agrega_producto_set_codigo").val("|");
			}, 500);	 
			
			setTimeout(function(){  
				$("#agrega_producto_set_codigo").val("");
			}, 1000);	 
			
			
			$("#agrega_producto_set_codigo").focus();
			
			
			$("#respuesta_1").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');				
			setTimeout(function(){  
				$("#respuesta_1").html("");    
			}, 1000);	 				
			
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
} 

