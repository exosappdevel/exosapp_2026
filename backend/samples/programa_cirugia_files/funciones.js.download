function eliminar_vendedor_set_sub_todas(){       
	var id_vendedor 	= $("#id_vendedor").val();	
	
	swal({    
		title: "¿Desea continuar?",   
		text: "Esta acción eliminara todos los sistemas al vendedor.",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "red",     
		confirmButtonText: "Si, continuar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 		   
		
			$.post("controller2.php", 
			{ 	action 					: "eliminar_vendedor_set_sub_todas", 
				id_vendedor 			: id_vendedor, 
			}, end_agrega_vendedor_set_sub);  
	});
}  
function agrega_vendedor_set_sub_todas(){       
	var id_vendedor 	= $("#id_vendedor").val();	
	
	swal({    
		title: "¿Desea continuar?",   
		text: "Esta acción agregara todos los sistemas al vendedor.",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "green",     
		confirmButtonText: "Si, continuar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 		   
		
			$.post("controller2.php", 
			{ 	action 					: "agrega_vendedor_set_sub_todas", 
				id_vendedor 			: id_vendedor, 
			}, end_agrega_vendedor_set_sub);  
	});
}   
function agrega_vendedor_set_sub(){       
	var id_vendedor 			= $("#id_vendedor").val();	
	var id_set_subcategoria 	= $("#vendedor_set_subcategoria").val();	
	
	if(id_set_subcategoria != "0"){		   
		$.post("controller2.php", 
			{ 	action 					: "agrega_vendedor_set_sub", 
				id_vendedor 			: id_vendedor, 
				id_set_subcategoria 	: id_set_subcategoria 
			}, end_agrega_vendedor_set_sub);  
			
	}else{
		$("#respuesta").html('<div class="alert alert-danger">Seleccione una sucursal</div>');
		setTimeout(function(){  
			$("#respuesta").html("");   
		}, 2000);
	} 
}   
function end_agrega_vendedor_set_sub(xml){    
	$(xml).find("response").each(function(i){   
		if ($(this).find("result").text()=="ok"){	
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');	
			llenar_tabla_vendedor_set_sub();				
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');	
		}		
		setTimeout(function(){  
			$("#respuesta").html("");   
		}, 2000);	
	});
}
 


