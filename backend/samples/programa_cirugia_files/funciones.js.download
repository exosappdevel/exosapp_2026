function rellena_tablas(xml,$id_datatable,$id_tabla_mostrar_datos,$ocultamiento_columnas,$messageTop,$messageBottom,$orden_row,$orden_type){
	
	if($orden_row == ""){
		$orden_row = 0; 
	}  
	if($orden_type == ""){ 
		$orden_type = "desc";
	}
	
	var regex = /<br\s*[\/]?>/gi;
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){
			/*Destruye la tabla y reinicializa valores*/
			$("#"+$id_tabla_mostrar_datos).html(""); 
			table = $('#'+$id_datatable+'').DataTable();
			table.buttons().destroy(); 
			//$(".dt-buttons").remove(); 
			table .clear() .draw(); 
			table.destroy(); 

			/* define $messageBottom if null*/
			if($messageBottom == ""){
				$messageBottom = 'Ruta de Impresión del Reporte: ' + window.location.href;
			}
			
			$("#"+$id_tabla_mostrar_datos).html($(this).find($id_tabla_mostrar_datos).text()); 
			/*inicializa la tabla y Carga los botones de Exportación con los datos extraidos*/	
			$('[data-toggle="tooltip"]').tooltip();
			/*table = $('#example').append('<caption style="caption-side: bottom">Ruta de Reporte: ' + window.location.href + '</caption>');*/
			table = $('#'+$id_datatable+'').DataTable({
				//	rowReorder: true,
				//	"order": [[ 0, "desc" ]], 
				"order": [[ $orden_row, $orden_type ]],    
				//dom: 'Bfrtip',
				dom: '<"top"Biflp<"clear">>rt<"bottom"iflp<"clear">>',
				pageLength : 25,
				buttons: [
					{  
						extend: 'excel',
						messageTop: $messageTop.replace(regex, "\n"),
						messageBottom: $messageBottom,
						exportOptions: {
							columns: function(idx, data, node) { 
								if ($(node).hasClass('noVis')) {
									return false;
								}
								return $('#'+$id_datatable+'').DataTable().column(idx).visible();
							}
						}
					},
					{
						extend: 'pdfHtml5',
						orientation: 'landscape',
						pageSize: 'LEGAL',
						messageTop: $messageTop.replace(regex, "\n"), 
						messageBottom: $messageBottom,
						exportOptions: {
							columns: function(idx, data, node) {
								if ($(node).hasClass('noVis')) {
									return false;
								}
								return $('#'+$id_datatable+'').DataTable().column(idx).visible();
							}							
						}
					},
					{
						extend: 'print',
						messageTop: $messageTop,
						messageBottom: $messageBottom,
						exportOptions: {
							columns: function(idx, data, node) {
								if ($(node).hasClass('noVis')) {
									return false;
								}
								return $('#'+$id_datatable+'').DataTable().column(idx).visible();
							}
						}
					},
					{
						extend: 'colvis',
						columns: ':gt(0)'
					}
				],
				columnDefs: [{targets:$ocultamiento_columnas,visible:false}], 
				//Manda a llamar el contenido de la variable global idioma_espanol con el objetivo de definir el lenguage para diferentes labels usados.
				language: idioma_espanol
			});
		}
	});
}

