function strip(key) {
    if (key.indexOf('-----') !== -1) {
        return key.split('-----')[2].replace(/\r?\n|\r/g, '');
    }
}

function return_fecha_hoy(){
	var meses = new Array ("Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre");
	var f=new Date();
	var fecha_hoy = (f.getDate() + " de " + meses[f.getMonth()] + " de " + f.getFullYear() + " - " + f.getHours() + ":" + f.getMinutes() + " Hrs");
	return fecha_hoy;
}


function default_fecha_hoy(){
	var meses = new Array ("Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre");
	var f=new Date();
	var fecha_hoy = (f.getDate() + " " + meses[f.getMonth()] + " " + f.getFullYear());
	
	
	$("#prestamo_set_fecha").val(fecha_hoy);
	 
	
}

 

function saltar(e,id){
	// Obtenemos la tecla pulsada
	(e.keyCode)?k=e.keyCode:k=e.which; 
	// Si la tecla pulsada es enter (codigo ascii 13)
	if(k==13){
		document.getElementById(id).focus();
	}
}

	
	
	