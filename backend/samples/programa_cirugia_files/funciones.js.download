function check_adicionales(id_producto_instrumental, id_cirugia){
	//alert(id_producto_instrumental);
	//alert(id_cirugia); 
	$.post("controller.php",  
		{ 	action : "check_adicionales" ,
			id_producto_instrumental : id_producto_instrumental,
			id_cirugia : id_cirugia
		});  	
}

function carga_menu(){
	$.post("controller.php", 
		{ 	action : "carga_menu"  
		}, end_carga_menu);  
} 
function end_carga_menu(xml){ 
	$(xml).find("response").each(function(i){	 	 
		if ($(this).find("result").text()=="ok"){ 			   
			$("#menu").html($(this).find("menu").text()); 			
			$('#menu').metisMenu('dispose'); 			
			setTimeout(function(){ 
				$('#menu').metisMenu();  
			}, 1000); 				 
		}else{ 
			//	alert("error menu");
				window.location.href  = "index.php"; 
		} 
	}); 
}  

function valida_pagina(){
	var pagina = $("#nombre_pagina_actual").val(); 
	//alert(pagina);
	$.post("controller.php",  
		{ 	action : "valida_pagina" ,
			pagina	: pagina
		}, end_valida_pagina);  
} 
function end_valida_pagina(xml){ 
	$(xml).find("response").each(function(i){	 	 
		if ($(this).find("result").text()=="ok"){
			return true;
		}else{ 
			//	window.location.href  = "index.php"; 
				window.location.href  = $(this).find("hrefs").text(); 
			//	alert("NO pagina no valida");
		} 
	}); 
}  

