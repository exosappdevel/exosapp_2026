	var id_equipo_poder = $("#id_equipo_poder").val();	
	var id_salida 		= $("#id_salida_almacen").val();	 
	var continua = 1;  
	if(id_equipo_poder == 0 || id_equipo_poder == ""){
		continua = 0;
		return false;
	}	
	if(continua == 1){  
		$('#loading').show();    
		$.post("controller.php", 
			{ 	action 		: "agrega_equipo_poder_salida",
				id_equipo_poder		: id_equipo_poder, 
				id_salida	: id_salida
			}, end_agrega_equipo_poder_salida);   		  
	} 
}
function end_agrega_equipo_poder_salida(xml){  
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	
			$("#agregar_equipo_poder_cirugia_form").trigger("reset");		
			llenar_tabla_equipo_salida(); 
			$('#loading').hide();			 
		}else{
			$('#loading').hide();
			swal("Alerta",$(this).find("result_text").text(),"error");
		}
		
		$("#id_equipo_poder").val("0"); 
		
	});
}


