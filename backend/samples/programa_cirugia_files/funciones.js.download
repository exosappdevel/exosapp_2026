function llenar_tabla_traspaso_detalle(){    
	var id_salida = $("#id_salida").val();
	$.post("controller3.php",   
		{ 	action :"llenar_tabla_traspaso_detalle",
			id_salida : id_salida
		}, end_llenar_tabla_traspaso_detalle);  
}   
function end_llenar_tabla_traspaso_detalle(xml){      
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){   

			$("#hoja").html($(this).find("hoja").text()); 
			
			var ocultamiento_columnas = [];	    
			var messageTop = "Reporte de Traspaso: " + $(this).find("hoja_plana").text() + " . <br/> " + "FECHA: " + return_fecha_hoy(); 
			rellena_tablas(xml,"example","table_traspaso",ocultamiento_columnas,messageTop,"","",""); 
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
	});  
}      
   
   
