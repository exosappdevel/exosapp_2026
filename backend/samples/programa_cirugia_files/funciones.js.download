/* prestamos de almacen - al finalizar se revisa lo que regresó y se hace consumo */
function iniciar_prestamo(){  

	var motivos = $("#nuevo_prestamo_comentarios").val(); 
	var cliente = $("#nuevo_prestamo_cliente").val(); 
	
	if(motivos == "" || cliente == ""){
		swal("Cuidado", "Por favor escriba algo en el campo comentarios y cliente", "error");
	}else{
		$.post("controller3.php",   
			{ 	action : "iniciar_prestamo",
				cliente : cliente, 
				motivos : motivos 
			}, end_iniciar_prestamo);  
	}
	
} 
function end_iniciar_prestamo(xml){  
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){ 
			$("#id_prestamo").val($(this).find("id_prestamo").text()); 			
			$("#btn-guardar_prestamo").removeClass("d-none");
			$("#btn-iniciar_prestamo").addClass("d-none");		
 
			$("#nuevo_prestamo_comentarios").prop('disabled', true);	
			
		}
	});
}

