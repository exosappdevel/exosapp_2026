	var cantidad_paso = "";  

	$( ".div_consumos" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad_ins]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo_ins]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo_ins.push(paso);
		}
		
	}); 
	
	var consumo_ins_string = consumo_ins.join(",");
 
	
	if(continua == 1){
		swal({   
				title: "Desea reportar sus consumos?",   
				text: "Una vez reportado no podrá regresar.",   
				/*type: "warning",    */
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true  
			}, function(){ 		  
					$.post("controller.php",  
					{ 	action :"reportar_consumos_instrumental",    
						consumo_ins_string 	: consumo_ins_string, 
						id_cirugia 		: id_cirugia					 
					},end_reportar_consumos_instrumental);
				});  
		
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
	  
} 
