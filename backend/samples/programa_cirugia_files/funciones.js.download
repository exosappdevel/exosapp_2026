function llenar_tabla_ventas(){  
	var mes = $("#mes").val(); 
	var anio = $("#anio").val(); 	
	if(mes == "0" || anio == "0"){
		alert("seleccione mes y año");
		return false;
	}	
	$.post("controller.php",
		{ 	action :"llenar_tabla_ventas", 
			mes : mes,
			anio : anio
		}, end_llenar_tabla_ventas);  
}
