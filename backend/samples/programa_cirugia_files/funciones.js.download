function valida_caducidad(){ 
	var caducidad 		= $("#nuevo_entrada_caducidad").val();
	var id_auditoria 	= $("#id_auditoria").val();

	//alert(id_auditoria);
	//return false;
	
	var fechaInicio = new Date().getTime();
	var fechaFin    = new Date(caducidad).getTime();

	var diff = fechaFin - fechaInicio;
	var dias_transcurridos = (diff/(1000*60*60*24) );
	
	if(dias_transcurridos < 365){
		swal({ 
			title: "Alerta",
			text: "La fecha de caducidad es menor a 1 año. Desea Continuar?",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, continuar",
			cancelButtonText: "No, Regresar",
			closeOnConfirm: true,
			closeOnCancel: true
		}, 
		function(isConfirm) {
			if (isConfirm) {
				if(id_auditoria === undefined){
					registrar_entrada_inventario();
				}else{
					registrar_auditoria_manual();
				}				
			} else {
				return false;
			} 
		});
	}else{
		if(id_auditoria === undefined){
			registrar_entrada_inventario();
		}else{
			registrar_auditoria_manual();
		}				
	}

	
}

function registrar_entrada_inventario(){ 
	
	//alert("entra");
	
	var id_inventario 	= $("#nuevo_entrada_id_inventario").val();
	var nueva_cantidad 	= $("#nuevo_entrada_nueva_cantidad").val();	
	var lote 			= $("#nuevo_entrada_lote").val();
	var caducidad 		= $("#nuevo_entrada_caducidad").val();
	var precio 			= $("#nuevo_entrada_precio").val();
	var area 			= $("#nuevo_entrada_area").val();
	var subarea 		= $("#nuevo_entrada_subarea").val();
	var nivel 			= $("#nuevo_entrada_nivel").val();
	var codigo_2 		= $("#nuevo_entrada_codigo_2").val();		
	var cantidad 		= $("#nuevo_entrada_cantidad").val();		
	var proveedor 		= $("#nuevo_entrada_proveedor").val();		
	var es_compra 		= $("#nuevo_entrada_compra").val();		
	var id_producto 	= $("#id_producto").val();
	
	var codigo_1 		= $("#buscar_producto_codigo").val();
	 
	var iniciar 		= $("#iniciar_registro").val();	 
	var id_entrada 		= $("#id_entrada_almacen").val(); 
		
	if(codigo_2 == "" || cantidad == "" || cantidad == "0" || lote == "" || caducidad == "" || area == "0" || subarea == "0"){
		swal("Ocurrio un error"," Por favor verifique los campos obligatorio","error");
		return false;
	}
	if(precio == "" || precio == "0"){
		alert("precio necesario");
		return false;
	}
		
		
	//alert(id_producto);
	
	if(iniciar == 0){
 
		swal({ 
			title: "No ha iniciado registro",
			text: "Desea iniciar un nuevo registro de Entrada de Almacen?",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, iniciarlo",
			cancelButtonText: "No, continuar sin iniciar",
			closeOnConfirm: false,
			closeOnCancel: true
		}, 
		function(isConfirm) {
			if (isConfirm) {
				$("#iniciar_registro").val("1");
					
					$("#btn-iniciar_registro").removeClass("btn-primary");
					$("#btn-iniciar_registro").addClass("btn-danger");
					$("#btn-iniciar_registro").html("Guardar Registro de Entrada");
					
					$("#btn-imprimir_pdf").removeClass("d-none");
					
					/*asigna un valor de ID a  id_entrada_almacen */
					if(proveedor > 0){
						$.post("controller.php", 
							{ 	action : "iniciar_registro_entrada" ,
								proveedor: proveedor
							}, end_iniciar_registro_entrada); 
					}else{
						swal.close();
						alert("seleccione fabrincante para iniciar el registro");
					}
					
			} else {
				$('#loading').show(); 
				$("#buscar_producto_codigo").prop( "disabled", true );
				$("#nuevo_entrada_codigo_2").prop( "disabled", true );
				
					$.post("controller.php", 
					{ 	action 			: "registrar_entrada_inventario",
						id_inventario	: id_inventario, 
						nueva_cantidad	: nueva_cantidad,
						lote			: lote,
						caducidad		: caducidad,
						precio			: precio,
						area			: area,
						subarea			: subarea,  
						nivel			: nivel,
						codigo_2		: codigo_2, 
						cantidad		: cantidad,  
						proveedor		: proveedor, 
						id_producto		: id_producto,
						iniciar			: iniciar,  
						id_entrada		: id_entrada,
						es_compra		: es_compra,
						codigo_1		: codigo_1
					}, end_registrar_entrada_inventario);  		
			} 
		});

	}else{
		$('#loading').show();  
		
		$("#buscar_producto_codigo").prop( "disabled", true );
				$("#nuevo_entrada_codigo_2").prop( "disabled", true );
				
		
		
		$.post("controller.php", 
			{ 	action 			: "registrar_entrada_inventario",
				id_inventario	: id_inventario, 
				nueva_cantidad	: nueva_cantidad,
				lote			: lote, 
				caducidad		: caducidad,
				precio			: precio, 
				area			: area,
				subarea			: subarea, 
				nivel			: nivel,
				codigo_2		: codigo_2, 
				cantidad		: cantidad, 
				proveedor		: proveedor, 
				id_producto		: id_producto,
				iniciar			: iniciar,  
				id_entrada		: id_entrada,
				es_compra		: es_compra,
				codigo_1		: codigo_1 
			}, end_registrar_entrada_inventario);  		 
	}
	
	
	//var continua = 1;  
	 
	/*if(continua == 1){ 
		  
	} */
}
