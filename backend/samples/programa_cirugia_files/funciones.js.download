/*cirugias*/  
/* busqueda de productos con filtro*/
function filtrar_cirugias(){ 
	var estatus = $("#cirugia_estatus").val();  
	/* aqui van las variables de busqueda */
	var fecha 		= $("#filtro_cirugia_fecha").val();
	var fecha_fin 	= $("#filtro_cirugia_fecha_fin").val();
	var hospital 	= $("#filtro_cirugia_hospital").val();
	var tecnico 	= $("#filtro_cirugia_tecnico").val();
	var subdistribuidor 	= $("#filtro_cirugia_socio").val();
	var vendedor 	= $("#filtro_cirugia_vendedor").val();
	var numero 		= $("#filtro_cirugia_numero").val();
	var codigo 		= $("#filtro_cirugia_codigo").val();
 
	$("#loading").show();
	  
	$.post("controller2.php",  
		{ 	action :"llenar_tabla_cirugias", 
			estatus 	: estatus,  
			fecha 		: fecha,
			fecha_fin 	: fecha_fin,
			tecnico 	: tecnico, 
			subdistribuidor 	: subdistribuidor, 
			hospital 	: hospital,
			vendedor 	: vendedor , 
			numero 		: numero,  
			codigo 		: codigo  
		}, end_llenar_tabla_cirugias); 
}
/* busqueda de productos con filtro*/
function filtrar_apoyo(){ 
	var almacen 	= $("#selecciona_almacen").val();  
	var estatus 	= $("#apoyo_estatus").val();
	var codigo 		= $("#apoyo_cirugia").val();
 
	$.post("controller3.php",
		{ 	action :"llenar_tabla_solicitud_apoyo", 
			almacen 	: almacen,  
			estatus 	: estatus,
			codigo 		: codigo   
		}, end_llenar_tabla_solicitud_apoyo); 
}

/* busqueda de productos con filtro*/
function filtrar_cirugias_procedimiento(){ 
	var categoria 		= $("#nuevo_instrumental_categoria").val();  
	var subcategoria 	= $("#nuevo_instrumental_subcategoria").val(); 
	var continua = 1;
	
	if(categoria == "0" || subcategoria == "0"){
		continua = 0;
	}
	
	if(continua == 1){
		$.post("controller2.php",
			{ 	action :"llenar_tabla_cirugias",  
				estatus 		: "aceptadayfinalizada",   
				categoria 		: categoria,   
				subcategoria 	: subcategoria  
			}, end_llenar_tabla_cirugias);
	}
	
}

function filtrar_cirugias_procedimiento_calendario(){    
	
	var categoria 		= $("#nuevo_instrumental_categoria").val();  
	var subcategoria 	= $("#nuevo_instrumental_subcategoria").val(); 
	var id_tipo_usuario 	= $("#id_tipo_usuario").val(); 
	var continua = 1;
	
	if(categoria == "0" || subcategoria == "0"){
		continua = 0;
	}
	if(continua == 1){
		var today = new Date();
		var calendarEl = document.getElementById('calendar');
		var calendar = new FullCalendar.Calendar(calendarEl, {
			monthNames: ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'],
			monthNamesShort: ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
			dayNames: ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'],
			dayNamesShort: ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'],
			headerToolbar: {
				left: 'prev,next today', 
				center: 'title',
				right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
			},
			initialView: 'dayGridMonth', 
			initialDate: today,
			navLinks: true, // can click day/week names to navigate views
			selectable: true,
			nowIndicator: true,
			editable: false, 
			businessHours: true,  
			dayMaxEvents: true, // allow "more" link when too many events // events: [{ title: 'All Day Event', start: '2022-06-04' },{ title: 'Long Event', start: '2020-09-07', end: '2020-09-10' }]		
			eventSources: [ { 
				//url: 'http://localhost/EXORTA/ERP//calendario_procedimiento.php?categoria=' + categoria + '&subcategoria=' + subcategoria + '&id_tipo_usuario=' + id_tipo_usuario,
				url: 'https://exorta.creaccionesweb.com/calendario_procedimiento.php?categoria=' + categoria + '&subcategoria=' + subcategoria, 
				failure: function() {
					//alert('there was an error while fetching events!');
					console.log("Error al cargar eventos");
				}
			}]
		});
		calendar.render();	
	}
		
	
	//window.location.href  = "calendario_procedimiento.php?categoria=" + categoria + "&subcategoria=" + subcategoria; 
}


