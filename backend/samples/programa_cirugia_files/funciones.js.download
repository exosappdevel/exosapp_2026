function load_calendario(){		

	var today = new Date();
	var calendarEl = document.getElementById('calendar');
	var calendar = new FullCalendar.Calendar(calendarEl, {
		monthNames: ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'],
		monthNamesShort: ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
		dayNames: ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'],
		dayNamesShort: ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'],
		headerToolbar: {
			left: 'prev,next today',
			center: 'title',
			right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
		},
		initialView: 'dayGridMonth',
		initialDate: today,
		navLinks: true, // can click day/week names to navigate views
		selectable: true,
		nowIndicator: true,
		editable: false,
		businessHours: true, 
		dayMaxEvents: true, // allow "more" link when too many events // events: [{ title: 'All Day Event', start: '2022-06-04' },{ title: 'Long Event', start: '2020-09-07', end: '2020-09-10' }]		
		eventSources: [ {
			//url: 'http://localhost/EXORTA/ERP/cargaeventos.php',
			url: 'https://exorta.creaccionesweb.com/cargaeventos.php', 
			failure: function() {
				//alert('there was an error while fetching events!');
				console.log("Error al cargar eventos");
			}
		}]
	});
	calendar.render();		
}

function carga_info_producto(){ 	
	var id_producto = $("#id_producto").val();	
	if(id_producto > 0)
	$.post("controller.php",  
		{ 	action : "carga_info_producto" , 
			id_producto	: id_producto 
		}, end_carga_info_producto); 		 
}
function end_carga_info_producto(xml){ 
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	
			$("#nombre").html($(this).find("nombre").text());
			$("#referencia").html($(this).find("referencia").text());
		}		
	});
}

function llenar_graficos_ventas_por_producto(){	
	var id_producto = $("#id_producto").val();	
	if(id_producto == "0"){
		return false;
	}		
	 var mes = [];
	 var vendido = [];
	 var comprado = [];
	 
                $.post("cargar_graficas_1.php", 
					{ id_producto: id_producto },
                function (datax)
                { 
					var fecha = new Date();
					var ano = fecha.getFullYear();

					
					const indicex = datax.findIndex((elemento, indicex) => {
						if (elemento.mes === '1') { elemento.mes = "Enero " + ano; }
						if (elemento.mes === '2') { elemento.mes = "Febrero " + ano; }
						if (elemento.mes === '3') { elemento.mes = "Marzo " + ano; }
						if (elemento.mes === '4') { elemento.mes = "Abril " + ano; }
						if (elemento.mes === '5') { elemento.mes = "Mayo " + ano; }
						if (elemento.mes === '6') { elemento.mes = "Junio " + ano; }
						if (elemento.mes === '7') { elemento.mes = "Julio " + ano; }
						if (elemento.mes === '8') { elemento.mes = "Agosto " + ano; }
						if (elemento.mes === '9') { elemento.mes = "Septiembre " + ano; }
						if (elemento.mes === '10') { elemento.mes = "Octubre " + ano; }
						if (elemento.mes === '11') { elemento.mes = "Noviembre " + ano; }
						if (elemento.mes === '12') { elemento.mes = "Diciembre " + ano; }
					});
					
					
					for(i in datax)
					{                    
						mes.push([datax[i].mes]);          
						vendido.push([datax[i].vendido]);          
						comprado.push([datax[i].comprado]);           
					}          
		  
					console.log(datax);
					
					/*
					const indice = mes.findIndex((elemento, indice) => {
					if (elemento.nombre === 'fresa') {
						return true;
					}
					});
*/


					var ctx = document.getElementById("chart2").getContext('2d');
					var myChart = new Chart(ctx, {
						type: 'bar',
						data: { 
							/*labels: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul'],*/
							labels: mes,
							datasets: [{
								label: 'Cantidad Vendida',
								//data: [10, 8, 20, 4, 18, 29, 25],
								data: vendido,
								barPercentage: .5,
								backgroundColor: "green"
							},{
								label: 'Cantidad Comprada',
								//data: [10, 8, 20, 4, 18, 29, 25],
								data: comprado, 
								barPercentage: .5,
								backgroundColor: "red" 
							}
							]
						},
						options: { 
							maintainAspectRatio: false,
							legend: {
								display: true,
								labels: {
									fontColor: '#585757',
									boxWidth: 40
								}
							},
							tooltips: {
								enabled: true
							},
							scales: {
								xAxes: [{
									ticks: {
										beginAtZero: true,
										fontColor: '#333'
									},
									gridLines: {
										display: true,
										color: "rgba(0, 0, 0, 0.07)"
									},
								}],
								yAxes: [{
									ticks: {
										beginAtZero: true,
										fontColor: '#585757'
									},
									gridLines: {
										display: true,
										color: "rgba(0, 0, 0, 0.07)"
									},
								}]
							}
						}
					});
		 
                });

		 
}

