function registrar_prestamo_inventario(){	
	var id_prestamo 	= $("#id_prestamo").val();	 	 
	var codigo 			= $("#nuevo_prestamo_codigo").val();	 	 
	var referencia 		= $("#nuevo_prestamo_referencia").val();	 	 
	var lote 			= $("#nuevo_prestamo_lote").val();	 	 
	var cantidad 		= $("#nuevo_prestamo_cantidad").val(); 
	var continua = 1;   
	
	if(id_prestamo == "0"){ 
		continua = 0; 
		alert("Por favor inicie el registro de salida");
	}
	
	if(continua == 1){
		$('#loading').show();  
		$.post("controller3.php",  
			{ 	action 		: "registrar_prestamo_inventario",
				id_prestamo	: id_prestamo,    
				codigo		: codigo,  
				referencia	: referencia,  
				lote		: lote,  
				cantidad	: cantidad 
			}, end_registrar_prestamo_inventario);  		 
	} 
}
function end_registrar_prestamo_inventario(xml){
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){			
			//$('#nuevo_salida_form').trigger("reset"); 
			$('#nuevo_prestamo_codigo').val("");
			$('#nuevo_prestamo_referencia').val("");
			$('#nuevo_prestamo_lote').val(""); 
			$('#nuevo_prestamo_cantidad').val("1");
			$('#nuevo_prestamo_codigo').focus();
			$('#loading').hide();		

			$("#respuesta").html("");  
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			
			setTimeout(function(){  
				$("#respuesta").html("");  
			}, 5000);	

			/* llena la tabla*/ 
			llenar_tabla_prestamos_almacen();
			//llenar_tabla_salida_almacen_rapida();
			
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
}


