function valida_boton_reportar_consumos(){
	 
	var id_cirugia = $("#nuevo_cirugia_id").val();
	
	$.post("controller2.php",  
		{ 	action :"valida_boton_reportar_consumos",
			id_cirugia  : id_cirugia
		}, end_valida_boton_reportar_consumos);   
	
}   
function end_valida_boton_reportar_consumos(xml){	       
	$(xml).find("response").each(function(i){		  
		if ($(this).find("result").text()=="ok"){	
			if ($(this).find("accion").text()=="reportar"){	
				$("#btn-imprimir_pdf_consumos_exorta").hide();
				$("#btn-reportar_consumos_escaneado").show();
				
				$("#btn-volver_listado").show();
				$("#btn-volver").show();
			
			}else{
				$("#btn-reportar_consumos_escaneado").hide();
				$("#btn-imprimir_pdf_consumos_exorta").show();
				 
				$("#btn-volver_listado").hide();
				$("#btn-volver").hide();
				
			}			
		} 
	}); 
}  
