	var lote 				= $("#agregar_producto_cirugia_lote").val();
	var referencia 			= $("#agregar_producto_cirugia_referencia").val();
	var cantidad 			= $("#agregar_producto_cirugia_cantidad").val();
	 
	var continua = 1;  
   
	if((id_inventario == 0 || id_inventario == "") && lote == "" && referencia == ""){
		continua = 0;
		swal("Alerta","Ingrese codigo, lote o referencia","error");
		return false; 
	}
	 
	if(continua == 1){
		$('#loading').show();  
		$.post("controller3.php",  
			{ 	action 				: "agrega_producto_cirugia",
				id_inventario		: id_inventario, 
				lote				: lote,  
				referencia			: referencia, 
				id_cirugia			: id_cirugia,
				cantidad 			: cantidad
			}, end_agrega_producto_cirugia);   		  
	}
 
} 
function end_agrega_producto_cirugia(xml){
	$(xml).find("response").each(function(i){   
