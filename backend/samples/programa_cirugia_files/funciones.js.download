/* busqueda de productos con filtro*/
function filtrar_producto_reporte_excel(){ 
alert("uno");
	/* aqui van las variables de busqueda */
	var fabricante 	= $("#filtro_producto_fabricante").val();
	var marca 		= $("#filtro_producto_marca").val();
	var categoria 	= $("#filtro_producto_categoria").val();
	var nombre 		= $("#filtro_producto_nombre").val();
	var referencia 	= $("#filtro_producto_referencia").val();
	var inicio 		= $("#filtro_producto_inicio").val();
	var fin 		= $("#filtro_producto_fin").val();
 	
	var continua = 1;
	
	if(inicio == "" || fin == ""){
		continua = 0;
		alert("por favor selecciona fechas");
	}
	
	if(continua == 1){
		//$('#loading').show();  
		//$('#loading').hide(); 		
		$.post("filtrar_producto_reporte_excel.php",
		{	fabricante 	: fabricante,
			marca 		: marca,
			categoria 	: categoria, 
			nombre 		: nombre,
			referencia 	: referencia,
			inicio 		: inicio,
			fin 		: fin
		});
	}
	
} 

