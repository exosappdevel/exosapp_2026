function iniciar_auditoria_manual(){       	
	var iniciar 		= $("#iniciar_registro").val();	
	var comentarios 	= $("#auditoria_manual_comentarios").val();
	
	var continua = 1;	
	
	if(continua == 1){		
		if(iniciar == 0){  /* va a iniciar el registro */		
						
			$("#iniciar_registro").val("1");			
			$("#btn-iniciar_registro").removeClass("btn-primary");
			$("#btn-iniciar_registro").addClass("btn-danger");
			$("#btn-iniciar_registro").html("Guardar Registro de Entrada"); 			
			//$("#btn-imprimir_pdf").removeClass("d-none");		
						
			/*asigna un valor de ID a  id_entrada_almacen */
			$.post("controller3.php",  
				{ 	action 			: "iniciar_auditoria_manual",
					comentarios 	: comentarios  
				}, end_iniciar_auditoria_manual); 	 			
		}else if(iniciar == 1){  /* va a cerrar el registro */				
			var id_auditoria = $("#id_auditoria").val();			 
			$.post("controller3.php",   
				{ 	action : "guardar_auditoria_manual",  
					comentarios 	: comentarios ,
					id_auditoria 	: id_auditoria  
				}, end_guardar_auditoria_manual); 				
		}	 		
	}	 
}  
function end_iniciar_auditoria_manual(xml){ 
	swal.close();
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			 
			$("#id_auditoria").val($(this).find("id_auditoria").text());
		}
	});
}
function end_guardar_auditoria_manual(xml){   
	//swal.close()
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			
			/* abrir pdf*/ 		 
			$("#iniciar_registro").val("0"); 
			$("#id_auditoria").val("0"); 			
			$("#btn-imprimir_pdf").addClass("d-none");			
			$("#btn-iniciar_registro").removeClass("btn-danger");
			$("#btn-iniciar_registro").addClass("btn-primary");
			$("#btn-iniciar_registro").html("Iniciar Registro de Entrada");				
			//alert($("#id_entrada_almacen").val());
			$("#table_entrada_almacen").html("");			
			/* reset form*/
			$('#nuevo_entrada_form').trigger("reset");  

			$("#cant_articulos").html('0');		 	
			$("#monto_articulos").html('0');		 	
			
		}
	});
}

// registrar_entrada_inventario
function registrar_auditoria_manual(){ 
		
	var id_inventario 	= $("#nuevo_entrada_id_inventario").val();
	var nueva_cantidad 	= $("#nuevo_entrada_nueva_cantidad").val();	
	var lote 			= $("#nuevo_entrada_lote").val();
	var caducidad 		= $("#nuevo_entrada_caducidad").val();
	var precio 			= $("#nuevo_entrada_precio").val();
	var area 			= $("#nuevo_entrada_area").val();
	var subarea 		= $("#nuevo_entrada_subarea").val();
	var nivel 			= $("#nuevo_entrada_nivel").val();
	var codigo_2 		= $("#nuevo_entrada_codigo_2").val();		
	var cantidad 		= $("#nuevo_entrada_cantidad").val();		
	
	var comentarios 	= $("#auditoria_manual_comentarios").val();		
	 
	var id_producto 	= $("#id_producto").val();
	 
	var iniciar 		= $("#iniciar_registro").val();	 
	var id_auditoria 	= $("#id_auditoria").val(); 
	
	if(codigo_2 == "" || cantidad == "" || cantidad == "0" || lote == "" || caducidad == "" || area == "0" || subarea == "0"){
		swal("Ocurrio un error"," Por favor verifique los campos obligatorio","error");
		return false;
	}
	if(precio == "" || precio == "0"){
		alert("precio necesario");
		return false;
	}
	
	if(iniciar == 0){
 
		swal({ 
			title: "No ha iniciado registro",
			text: "Desea iniciar un nuevo registro de Auditoria Manual?",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, iniciarlo",
			cancelButtonText: "Cancelar registro",
			closeOnConfirm: false,
			closeOnCancel: true
		}, 
		function(isConfirm) {
			if (isConfirm) {
				$("#iniciar_registro").val("1");
					
					$("#btn-iniciar_registro").removeClass("btn-primary");
					$("#btn-iniciar_registro").addClass("btn-danger");
					$("#btn-iniciar_registro").html("Guardar Registro de Entrada");
					
					//$("#btn-imprimir_pdf").removeClass("d-none");
					
					$.post("controller3.php", 
							{ 	action : "iniciar_auditoria_manual" ,
								comentarios: comentarios
							}, end_iniciar_auditoria_manual); 
					
			} else {
				
				alert("Es necesario iniciar el registro");
				
				/*
				$('#loading').show(); 
					$.post("controller3.php",  
					{ 	action 			: "registrar_auditoria_manual",
						id_inventario	: id_inventario, 
						nueva_cantidad	: nueva_cantidad,
						lote			: lote,
						caducidad		: caducidad,
						precio			: precio,
						area			: area,
						subarea			: subarea,  
						nivel			: nivel,
						codigo_2		: codigo_2, 
						cantidad		: cantidad,  
						comentarios		: comentarios, 
						id_producto		: id_producto,
						iniciar			: iniciar,  
						id_auditoria	: id_auditoria
					}, end_registrar_auditoria_manual);  	

				*/					
			}  
		});

	}else{
		
		
		$('#loading').show();  
		
		
		$.post("controller3.php",  
			{ 	action 			: "registrar_auditoria_manual",
				id_inventario	: id_inventario, 
				nueva_cantidad	: nueva_cantidad,
				lote			: lote,
				caducidad		: caducidad,
				precio			: precio, 
				area			: area,
				subarea			: subarea, 
				nivel			: nivel,
				codigo_2		: codigo_2, 
				cantidad		: cantidad, 
				comentarios		: comentarios, 
				id_producto		: id_producto,
				iniciar			: iniciar,  
				id_auditoria	: id_auditoria
			}, end_registrar_auditoria_manual);  		 
	}
	
	
	//var continua = 1;  
	 
	/*if(continua == 1){ 
		 
	} */ 
}
function end_registrar_auditoria_manual(xml){  
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){			
			//$('#nuevo_entrada_form').trigger("reset"); 
			$('#nuevo_entrada_cantidad').val("1"); 
			$('#nuevo_entrada_codigo_2').val(""); 
			$('#nuevo_entrada_lote').val(""); 
			$('#nuevo_entrada_caducidad').val(""); 
			$('#buscar_producto_codigo').val(""); 
			$('#nuevo_entrada_referencia').val(""); 
			$('#nuevo_entrada_nombre').val("");  
			$('#nuevo_entrada_precio').val("0");  
			
			
			$('#loading').hide();	
			
   
			$("#id_auditoria").val($(this).find("id_auditoria").text());
			$("#cant_articulos").html($(this).find("cant_articulos").text());
			//llenar_tabla_entrada_almacen();
			$('#buscar_producto_codigo').focus();	
			//llenar_tabla_entrada_almacen_inventariotmp();   
			llenar_tabla_auditoria_manual();   
			
			//$("#nuevo_entrada_proveedor").val($(this).find("proveedor").text());
			 
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text() + " ::: Ultimo producto escaneado codigo 2: " + $(this).find("codigo_2").text(),"error");
		}
	});
}

