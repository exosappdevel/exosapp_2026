/* ****************************************************************** */
   
  
function valida_devolver_material(){  
	   
	var id_cirugia 		= $("#nuevo_cirugia_id").val(); 
	 
	$.post("controller3.php",  
			{ 	action 		:"valida_devolver_material",				 
				id_cirugia 	: id_cirugia 		 
			},end_valida_devolver_material);		
	
}       
function end_valida_devolver_material(xml){  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			// ya se entregó 		 
			$("#div_botones").show(); 
			$("#btn-recibir_material").hide();
			
			$( "#recibir_cirugia_tecnico" ).prop( "disabled", true );
			$( "#recibir_cirugia_vendedor" ).prop( "disabled", true );
			$( "#recibir_cirugia_folio" ).prop( "disabled", true );
			
		}else{ 
			$("#div_botones").hide(); 
			$("#btn-recibir_material").show();
			
			$( "#recibir_cirugia_tecnico" ).prop( "disabled", false );
			$( "#recibir_cirugia_vendedor" ).prop( "disabled", false );
			$( "#recibir_cirugia_folio" ).prop( "disabled", false );
		} 
	});
}    



function recibir_material(){ 
	   
	var id_cirugia 		= $("#nuevo_cirugia_id").val(); 
	var id_tecnico 		= $("#recibir_cirugia_tecnico").val(); 
	var id_vendedor 	= $("#recibir_cirugia_vendedor").val(); 
	var folio 			= $("#recibir_cirugia_folio").val(); 
	
	if(folio == ""){
		swal("Cuidado", "Por favor escriba un FOLIO", "error"); 
		return false;
	}
		
	if(id_cirugia == "0"){
		swal("Cuidado", "Por favor seleccione cirugia", "error"); 
	}else{
		if(id_tecnico == "0" && id_vendedor == "0"){
			swal("Cuidado", "Por favor seleccione un tecnico o un vendedor", "error"); 
		}else{
			
			swal({    
				title: "Confirmar Folio de Reporte : " + folio,   
				text: "¿Desea continuar con este folio?",   
				/*type: "warning",    */
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true 
			}, function(){ 		  
				$.post("controller.php",  
					{ 	action 		:"recibir_material",				 
						id_cirugia 	: id_cirugia,
						id_tecnico 	: id_tecnico,					 
						id_vendedor : id_vendedor,
						folio 		: folio	 		 		 
					},end_recibir_material);		 
			}); 		
		
		}		
	}	  
}      
function end_recibir_material(xml){  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			//$("#codigo_cirugia").val($(this).find("codigo").text());			 
			
			var mensaje_error = $(this).find("result_text").text();
			
			$("#div_botones").show(); 
			$("#btn-recibir_material").hide();
			
			$( "#recibir_cirugia_tecnico" ).prop( "disabled", true );
			$( "#recibir_cirugia_vendedor" ).prop( "disabled", true );
			$( "#recibir_cirugia_folio" ).prop( "disabled", true );
			
			$("#respuesta_05").html('<div class="alert alert-success">' + mensaje_error + '</div>');		

			setTimeout(function(){
				$("#respuesta_05").html("");
			}, 3000);	
			
			//swal("Correcto", "El material se registró correctamente.", "success");
		}else{
			
			var mensaje_error = $(this).find("result_text").text();
			
			$("#respuesta_05").html('<div class="alert alert-danger">' + mensaje_error + '</div>');		

			setTimeout(function(){
				$("#respuesta_05").html("");
			}, 3000);	
		
			//swal("Cuidado", "Por favor verifique la cirugia", "error");  
			//swal("Cuidado", codigo_error, "error"); 
		}
	});
}  
    
