		}, end_imprimir_qr_activos);   
	
}     
function end_imprimir_qr_activos(xml){	     
	$(xml).find("response").each(function(i){		  
		if ($(this).find("result").text()=="ok"){	
			 
			llenar_tabla_caja_activo();
			
			window.open(
				$(this).find("filepath").text(),
				'_blank'
			);
					
		} 
	}); 
} 


