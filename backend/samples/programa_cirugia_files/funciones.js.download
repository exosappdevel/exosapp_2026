function buscar_inventario(e){ 
	
	e.preventDefault();
	
	var fabricante 			= $("#buscar_inventario_proveedor").val();
	var nombre 				= $("#buscar_inventario_nombre").val();
	var referencia			= $("#buscar_inventario_referencia").val();
	var codigo_2 			= $("#buscar_inventario_codigo_2").val();
	var lote 				= $("#buscar_inventario_lote").val();
	var area 				= $("#buscar_inventario_area").val();
	var subarea 			= $("#buscar_inventario_subarea").val();
	var nivel 				= $("#buscar_inventario_nivel").val();
	var caducidad_option 	= $("#buscar_inventario_caducidad_option").val();
	var caducidad 			= $("#buscar_inventario_caducidad").val(); 
	var cantidad_option 	= $("#buscar_inventario_cantidad_option").val();
	var cantidad 			= $("#buscar_inventario_cantidad").val(); 
	var costo_option 		= $("#buscar_inventario_costo_option").val();
	var costo 				= $("#buscar_inventario_costo").val();  
	var cero 				= $("#buscar_inventario_cero").val();  
	var where 				= $("#where").val();  
	
	var continua = 1; 
	
	if(continua == 1){  
	
		$('#loading').show(); 
	
		$.post("controller.php", 
			{ 	action : "buscar_inventario",  
				fabricante: fabricante,
				nombre: nombre,
				referencia: referencia,
				codigo_2: codigo_2,
				lote: lote,
				area: area, 
				subarea: subarea,
				nivel: nivel,
				caducidad_option: caducidad_option,
				caducidad: caducidad,
				cantidad_option: cantidad_option,
				cantidad: cantidad,
				costo_option: costo_option,
				costo: costo, 
				cero: cero,
				where: where 
			}, end_llenar_tabla_inventarios);  		 
	}
}  

	
function buscar_referencia_por_codigo_lavado(){
	var codigo_1 = $("#agrega_producto_set_codigo").val();
	var continua = 1; 
	
	if(codigo_1 == ""){
		continua = 0;
		return false; 
	}	
	if(continua == 1){  
		$.post("controller.php",  
			{ 	action : "buscar_referencia_por_codigo",  
				codigo_1: codigo_1
			}, end_buscar_referencia_por_codigo_lavado);  		 
	}
}  
function end_buscar_referencia_por_codigo_lavado(xml){
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			 
			$("#agrega_producto_set_referencia").val($(this).find("referencia").text());
			$("#agrega_producto_set_lote").val($(this).find("lote").text());
			
			$("#agrega_producto_set_cantidad").val("1");
			
			
			$("#btn-agrega_producto_set_instrumental").trigger("click");
			
			
			$("#agrega_producto_set_codigo").focus();				
			
		}
	}); 
}	
function buscar_referencia_por_codigo(){
	var codigo_1 = $("#agrega_producto_set_codigo").val();
