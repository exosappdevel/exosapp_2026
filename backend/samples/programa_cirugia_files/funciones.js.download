				{ 	action 				: "traspasar_salida",
					id_salida 			: id_salida,	 				 
					sucursal_destino 	: sucursal_destino				 
				},end_traspasar_salida);		
		});  		
	}else{
		swal("Cuidado", "Por favor seleccione Sucursal Destino", "error");
	}
}      
function end_traspasar_salida(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			swal("Correcto", "El traspaso se realizó correctamente.", "success");
			llenar_tabla_salidas_almacen_detalle();
		}else{
			swal("Cuidado", "Ocurrio un error. Por favor verifique", "error");
		}
	});
} 
 
function obtiene_codigo_cirugia(){
	  
	var id_cirugia = $("#id_cirugia").val();  	

	$.post("controller.php",  
			{ 	action :"obtiene_codigo_cirugia",
				id_cirugia 		: id_cirugia					 
			},end_obtiene_codigo_cirugia);		
	 
}    
function end_obtiene_codigo_cirugia(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#codigo_cirugia").val($(this).find("codigo").text());			
		}
	});
} 
 
function acptar_material(){ 	  
  
	var id_cirugia 				= $("#nuevo_cirugia_id").val();  	
	var fecha_promesa_entrega 	= $("#fecha_promesa_entrega").val();  	
	var hora_promesa_entrega 	= $("#hora_promesa_entrega").val();  	
	var continua = 1;
		 
	var motivo_error = "Ocurrió un Error. Vuelva a intentar.";
	
	if(fecha_promesa_entrega == "" || hora_promesa_entrega == ""){
		continua = 0;
		motivo_error = "Especifique fecha y hora promesa de devolución de material.";
	}
	
	if(continua == 1){
		$.post("controller.php",     
			{ 	action :"acptar_material", 
				id_cirugia 					: id_cirugia,					 
				fecha_promesa_entrega 		: conviertefechasql(fecha_promesa_entrega),	 
				hora_promesa_entrega 		: hora_promesa_entrega					 
			},end_acptar_material);		
	}else{ 
		swal("Cuidado", motivo_error , "error");
	}	   
} 
function end_acptar_material(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');		

			setTimeout(function(){
				$("#respuesta").html("");  
				window.location.href  = "ver_cirugias.php"; 
			}, 1000);	

		
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
			
	});
} 

 
function finalizar_cirugia(){ 	  
 
	var id_cirugia = $("#nuevo_cirugia_id").val();  
	
	var continua = 1;		 
	var consumo = []; 
	var consumo_string = ""; 
	var paso = "";
	var cantidad_paso = "";
	
	/*
	$("#reportar_consumos input:checkbox[name=consumo]:checked").each(function(){     
		consumo.push($(this).val());
	});
	var consumo_string = consumo.join(",");
	*/
		
	$( ".div_consumos" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo.push(paso);
		}
		
	}); 
	
	var consumo_string = consumo.join(",");
	
	//console.log(consumo_string);
	
	//continua = 0;
	//return false;
	
	if(continua == 1){
		if(consumo_string == ""){
				swal({   
				title: "No se reportan Consumos",   
				text: "Desea continuar sin reportar consumos?",   
				/*type: "warning",    */
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true 
			}, function(){ 		  
					$.post("controller.php", 
					{ 	action :"finalizar_cirugia",   
						consumo_string 	: consumo_string, 
						id_cirugia 		: id_cirugia					 
					},end_finalizar_cirugia);
				});  
		}else{
			$.post("controller.php",  
				{ 	action :"finalizar_cirugia",   
					consumo_string 	: consumo_string, 
					id_cirugia 		: id_cirugia					 
				},end_finalizar_cirugia);
		}
		
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
	 
} 
function end_finalizar_cirugia(xml){ 
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);		
	});
} 

function reportar_consumos_tmp_bkup(){  	   
 
	var id_cirugia 		= $("#nuevo_cirugia_id").val();  
	var hora_inicio 	= $("#hora_real_inicio_cirugia").val();  
	var hora_fin 		= $("#hora_real_fin_cirugia").val();   
	
	var continua = 1;		 
	var consumo = []; 
	var consumo_ins = []; 
	var consumo_string = ""; 
	var consumo_ins_string = "";  
	var paso = "";
	var cantidad_paso = "";
	
	var consumo_tabla = []; 
	var consumo_tabla_ins = []; 
	var consumo_tabla_string = ""; 
	var consumo_tabla_ins_string = "";  	
	
	$("#nuevo_cirugia_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});	 
	
	/*
	$("#reportar_consumos input:checkbox[name=consumo]:checked").each(function(){     
		consumo.push($(this).val());
	});
	var consumo_string = consumo.join(",");
	*/
		
	$( ".div_consumos" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo.push(paso);
		}
		
	}); 
	
	$( ".div_consumos" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad_ins]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo_ins]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo_ins.push(paso);
		}
		
	}); 
	
	
	$( ".div_consumos_tabla" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo_tabla.push(paso);
		}		
	}); 
	$( ".div_consumos_tabla_ins" ).each(function( index ) {
		cantidad_paso = $(this).find("input[name=cantidad_ins]").val();
		if(cantidad_paso > 0){
			paso = ($(this).find("input[name=consumo_ins]").val()) + "|" + cantidad_paso;
			//console.log( index + ": " + paso );
			consumo_tabla_ins.push(paso); 
		}		
	}); 
	
	
	var consumo_string = consumo.join(",");
	var consumo_ins_string = consumo_ins.join(",");
	 
	var consumo_tabla_string = consumo_tabla.join(",");
	var consumo_tabla_ins_string = consumo_tabla_ins.join(",");
	
	//console.log("consumo:::" + consumo_string);
	console.log("consumo_tabla:::" + consumo_tabla_string);
	//console.log("consumo_ins:::" + consumo_ins_string);
	console.log("consumo_tabla_ins:::" + consumo_tabla_ins_string);
	//
	//continua = 0;
	//return false;
	
	if(continua == 1){
		if(consumo_tabla_string == ""){
			swal({   
				title: "No se reportan Consumos",   
				text: "Desea continuar sin reportar consumos? Una vez reportado no podrá regresar.",   
				/*type: "warning",    */
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true   
			}, function(){ 		  
					$.post("controller.php", 
					{ 	action :"reportar_consumos_tmp",    
						consumo_string 		: consumo_tabla_string, 
						consumo_ins_string 	: consumo_tabla_ins_string, 
						id_cirugia 			: id_cirugia,					 
						hora_inicio 		: hora_inicio,					 
						hora_fin 			: hora_fin					 
					},end_finalizar_cirugia);
				});  
		}else{
			swal({   
				title: "Desea reportar sus consumos?",   
				text: "Una vez reportado no podrá regresar.",   
				/*type: "warning",    */
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true  
			}, function(){ 		  
					$.post("controller.php",   
					{ 	action :"reportar_consumos_tmp",    
						consumo_string 		: consumo_tabla_string,  
						consumo_ins_string 	: consumo_tabla_ins_string, 
						id_cirugia 			: id_cirugia,				 
						hora_inicio 		: hora_inicio,					 
						hora_fin 			: hora_fin								
					},end_reportar_consumos_tmp);
				});  
				
			
		}
		
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
	  
} 
