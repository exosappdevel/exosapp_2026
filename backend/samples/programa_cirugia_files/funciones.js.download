function agregar_permiso_pagina(){	

	var id_tipo_usuario = $("#id_tipo_usuario").val();	
	var pagina 			= $("#permiso_pagina").val();
	var continua = 1;    
	var motivo_error = "";

	if(id_tipo_usuario == "" || id_tipo_usuario < 0 || id_tipo_usuario == "0"){
		continua = 0;
		return false;
		motivo_error = "No se definió el tipo de usuario";
	}
	if(pagina == "" || pagina < 0 || pagina == "0"){ 
		continua = 0;
		return false;
		motivo_error = "No se definió la ruta de la página"; 
	} 
	  
	if(continua == 1){
		$('#loading').show();  
		$.post("controller.php",  
			{ 	action 		: "agregar_permiso_pagina",
				id_tipo_usuario		: id_tipo_usuario, 
				pagina				: pagina
			}, end_agregar_permiso_pagina);  		  
	}else{
		$("#respuesta").html('<div class="alert alert-danger">' + motivo_error + '</div>');
			setTimeout(function(){  
				$("#respuesta").html("");    
			}, 2000);	
	}
  
} 
function end_agregar_permiso_pagina(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){	
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			setTimeout(function(){  
				$("#respuesta").html("");    
			}, 2000);	 		
			
			$("#permiso_pagina").val("");
			$("#permiso_pagina").focus();
			
			llenar_tabla_permisos_pagina();	 	 
		}else{
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	}); 
} 

