function imprimir_pdf_venta_directa(id_venta){    
	if(id_venta == 0){
		id_venta = $("#id_venta_directa").val();  
	}	 
	if(id_venta > 0){ 
		$.post("controller2.php", 
			{ 	action : "imprimir_pdf_venta_directa",  
				id_venta: id_venta  
			}, end_imprimir_pdf_venta_directa);   		 
	}
} 

function end_imprimir_pdf_venta_directa(xml){	  
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){ 				
			window.open( $(this).find("filepath").text(), '_blank' );		
		}else{
			swal("Error", "ocurrio un error al intentar imprimir el PDF", "error");
		}			
	});
} 

