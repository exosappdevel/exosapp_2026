/*hospital*/
function guardar_empleado(){ 	  
	var nuevo_empleado_id				= $("#nuevo_empleado_id").val(); 
	var nuevo_empleado_empresa			= $("#nuevo_empleado_empresa").val(); 
	var nuevo_empleado_sucursal			= $("#nuevo_empleado_sucursal").val(); 
	var nuevo_empleado_numero			= $("#nuevo_empleado_numero").val(); 
	var nuevo_empleado_nombre			= $("#nuevo_empleado_nombre").val(); 
	var nuevo_empleado_ingreso			= $("#nuevo_empleado_ingreso").val(); 
	var nuevo_empleado_dias_oficiales	= $("#nuevo_empleado_dias_oficiales").val(); 
	var nuevo_empleado_dias_utilizados	= $("#nuevo_empleado_dias_utilizados").val(); 
	var nuevo_empleado_jefe				= $("#nuevo_empleado_jefe").val(); 
	var nuevo_empleado_usuario			= $("#nuevo_empleado_usuario").val(); 
	var continua = 1;		
	
	$("#nuevo_empleado_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0; 
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			 	
	 $("#nuevo_empleado_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});				
	   
	if(continua == 1){
		$.post("controller5.php",  
			{ 	action :"guardar_empleado", 
				tipo 							: tipoguardado, /*global*/  
				nuevo_empleado_id 				: nuevo_empleado_id,
				nuevo_empleado_empresa 			: nuevo_empleado_empresa,
				nuevo_empleado_sucursal 		: nuevo_empleado_sucursal,
				nuevo_empleado_numero 			: nuevo_empleado_numero,
				nuevo_empleado_nombre 			: nuevo_empleado_nombre,
				nuevo_empleado_ingreso 			: nuevo_empleado_ingreso,
				nuevo_empleado_dias_oficiales 	: nuevo_empleado_dias_oficiales,
				nuevo_empleado_dias_utilizados 	: nuevo_empleado_dias_utilizados,
				nuevo_empleado_jefe 			: nuevo_empleado_jefe, 
				nuevo_empleado_usuario 			: nuevo_empleado_usuario
			},end_guardar_empleado);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
} 
function end_guardar_empleado(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			if(tipoguardado == "nuevo"){
				$('#nuevo_empleado_form').trigger("reset");
				$("#nuevo_empleado_id").val("0"); 
				$(".obligatorio_select").val("0").trigger('change');
			}else if(tipoguardado == "editar"){
				//$("#nuevo__nombre").attr("readonly", "readonly");  // se utiliza cuando algun campo NO puede ser modificado al editar
				$("#nuevo_empleado_id").val($(this).find("nuevo_empleado_id").text()); 
			}else if(tipoguardado == "nuevo_salir"){
				location.href ="ver_empleados.php"; 
			} 
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);		
	});
}
  
