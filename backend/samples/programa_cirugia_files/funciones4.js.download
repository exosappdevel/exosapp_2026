function reasignar_bulto_cirugia(){  
	 
	var id_bulto 		= $("#id_bulto").val();  	
	var codigo_cirugia 	= $("#codigo_nueva_cirugia").val();  	
	
	$.post("controller5.php",   
		{ 	action 			:"valida_reasignar_bulto_cirugia",  
			codigo_cirugia 	: codigo_cirugia,
			id_bulto 		: id_bulto
		},end_valida_reasignar_bulto_cirugia);			
}
function end_valida_reasignar_bulto_cirugia(xml){	 
	$(xml).find("response").each(function(i){		    
		if ($(this).find("result").text()=="ok"){
			
			var id_bulto 	= $("#id_bulto").val();   	
			var id_cirugia 	= $(this).find("id_cirugia").text();  	
			
			swal({    
				title: "¿Reasignar Cirugia?",   
				text: "Esta acción reasignará el bulto a la nueva cirugia. Desea Continuar?",   
				/*type: "warning",    */
				showCancelButton: true,     
				confirmButtonColor: "#DD6B55",   
				confirmButtonText: "Si, continuar",  
				cancelButtonText: "Regresar",   
				closeOnConfirm: true 
			}, function(){ 		  
				$.post("controller5.php",  
					{ 	action 			: "reasignar_bulto_cirugia", 
						id_bulto 		: id_bulto,
						id_cirugia 		: id_cirugia
					}, end_reasignar_bulto_cirugia);
			}); 
			
			
		}else{ 
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		
		setTimeout(function(){
			$("#respuesta").html('');
		}, 5000);	
			
			
	}); 
}  
 
