/* guardar formulario */
function guardar_cliente(){ 	  
	var nuevo_cliente_id		= $("#nuevo_cliente_id").val(); 
	//	var nuevo_cliente_alias		= $("#nuevo_cliente_alias").val(); 
	var nuevo_cliente_alias		= $("#nuevo_cliente_razon").val();  
	var nuevo_cliente_razon		= $("#nuevo_cliente_razon").val(); 
	var nuevo_cliente_rfc		= $("#nuevo_cliente_rfc").val(); 
	//	var nuevo_cliente_csf		= $("#nuevo_cliente_csf").val(); 
	var nuevo_cliente_csf		= $("#csv_file").val(); 
	var nuevo_cliente_credito	= $("#nuevo_cliente_credito").val(); 
	var nuevo_cliente_plazo		= $("#nuevo_cliente_plazo").val(); 
	var nuevo_cliente_estatus	= $("#nuevo_cliente_estatus").val(); 
	var continua = 1;		
	
	$("#nuevo_cliente_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0; 
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			  	
	 $("#nuevo_cliente_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});				
	  
	if(continua == 1){
		$.post("controller5.php",  
			{ 	action :"guardar_cliente", 
				tipo 					: tipoguardado, /*global*/  
				nuevo_cliente_id 		: nuevo_cliente_id,
				nuevo_cliente_alias 	: nuevo_cliente_alias,
				nuevo_cliente_razon 	: nuevo_cliente_razon,
				nuevo_cliente_rfc 		: nuevo_cliente_rfc,
				nuevo_cliente_csf 		: nuevo_cliente_csf,
				nuevo_cliente_credito 	: nuevo_cliente_credito,
				nuevo_cliente_plazo 	: nuevo_cliente_plazo,
				nuevo_cliente_estatus 	: nuevo_cliente_estatus
			},end_guardar_cliente);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	} 
} 
function end_guardar_cliente(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			if(tipoguardado == "nuevo"){
				$('#nuevo_cliente_form').trigger("reset");
				$("#nuevo_cliente_id").val("0"); 
				$(".obligatorio_select").val("0").trigger('change');
			}else if(tipoguardado == "editar"){
				//$("#nuevo__nombre").attr("readonly", "readonly");  // se utiliza cuando algun campo NO puede ser modificado al editar
				$("#nuevo_cliente_id").val($(this).find("nuevo_cliente_id").text()); 
			}else if(tipoguardado == "nuevo_salir"){
				location.href ="ver_clientes.php"; 
			} 
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);		
	});
}

/*set*/  
function llenar_formulario_cliente(){  
	var id_cliente = $("#nuevo_cliente_id").val();	
		
	$.post("controller5.php", 
