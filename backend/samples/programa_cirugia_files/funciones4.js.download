function guardar_comentarios_vacaciones(){
		
		var vacaciones_comentarios 	= $("#vacaciones_comentarios").val();
		var id_vacaciones 			= $("#id_vacaciones").val();
		
		$.post("controller5.php",   
				{ 	action 					: "guardar_comentarios_vacaciones", 
					vacaciones_comentarios 	: vacaciones_comentarios, 
					id_vacaciones 			: id_vacaciones
				},end_guardar_comentarios_vacaciones);
	}   
	function end_guardar_comentarios_vacaciones(xml){	  
		$(xml).find("response").each(function(i){		
			if ($(this).find("result").text()=="ok"){
				swal("Correcto","Comentarios guardados exitosamente","success");
				$("#cerrar_modal").trigger("click");
			}			
		});
	}
	
	 
function eliminar_empleado(id_empleado){
	swal({   
		title: "¿Eliminar?",   
		text: "Esta acción eliminará el Empleado definitivamente.",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "#DD6B55",   
		confirmButtonText: "Si, eliminar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true  
	}, function(){ 	
