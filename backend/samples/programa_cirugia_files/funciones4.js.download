function enteradas_vacaciones(id_vacaciones){
	
	swal({
		title: "DAR POR ENTERADAS ESTAS VACACIONES", 
			text: "Confirma con tu PIN que das por enteradas estas vacaciones",
			type: "input",
			showCancelButton: true,
			closeOnConfirm: false,
			inputPlaceholder: "PIN"
	}, function(inputValue) {
		if (inputValue === false) return false; // Si cancela
		if (inputValue === "") {
			swal.showInputError("POR FAVOR ESCRIBE TU PIN");
			return false; 
		}
		//	swal("¡Perfecto!", "Tu nombre es: " + inputValue, "success");
     
		$.post("controller5.php",
			{ 	action 	: "enteradas_vacaciones",
				id_vacaciones : id_vacaciones,
				pin : inputValue 
		}, end_enteradas_vacaciones);
	
	});
}
function end_enteradas_vacaciones(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			//	llenar_tabla_vacaciones();
			swal("Correcto", $(this).find("result_text").text(),"success");
			
			setTimeout(function(){ 
				swal.close();
			}, 2000);	
			
			
			llenar_tabla_vacaciones_enteradas();
			llenar_tabla_vacaciones_sin_enterar();
		}else{
			//	$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
			swal("Error", $(this).find("result_text").text(),"error");
		}
			
	});
} 
  
