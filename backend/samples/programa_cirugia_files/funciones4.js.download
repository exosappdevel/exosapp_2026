		}, end_permitir_programar_vendedor);    		 
}  
function end_permitir_programar_vendedor(xml){	     
	$(xml).find("response").each(function(i){	  	    
		if ($(this).find("result").text()=="ok"){			
			$("#loading").hide(); 
			swal("CORRECTO",$(this).find("aviso").text(),"success");
			llenar_tabla_vendedores();
		}else{
			$("#loading").hide();
		}
	}); 
}   




function valida_subdis_nvo_usuario(){	
 
	var id_subdistribuidor = $("#nuevo_usuario_subdis").val();
	
	$.post("controller6.php", 
		{ 	action 	:"valida_subdis_nvo_usuario",
			id_subdistribuidor : id_subdistribuidor
		}, end_valida_subdis_nvo_usuario);
}  
function end_valida_subdis_nvo_usuario(xml){  
	$(xml).find("response").each(function(i){	 	
		if ($(this).find("result").text()=="ok"){	/* NO seleccionar subdis */			
 			$("#nuevo_usuario_tipo").val("");
 			$("#nuevo_usuario_tipo").attr("disabled",true);	
 			$("#nuevo_usuario_almacen").val("");
 			$("#nuevo_usuario_almacen").attr("disabled",true);	
 			$("#nuevo_usuario_area").val("");
 			$("#nuevo_usuario_area").attr("disabled",true);
		}else{ /* subdis 01 NO REGISTRADO */
			$("#nuevo_usuario_tipo").val("0");
 			$("#nuevo_usuario_tipo").attr("disabled",false);	
 			$("#nuevo_usuario_almacen").val("0");  
 			$("#nuevo_usuario_almacen").attr("disabled",false);	
 			$("#nuevo_usuario_area").val("0");
 			$("#nuevo_usuario_area").attr("disabled",false);
		}
	}); 
}
 
function sugiere_usuario_nick(){	 
  
	var nombre = $("#nuevo_usuario_nombre").val();
	
	$.post("controller6.php", 
		{ 	action 	:"sugiere_usuario_nick",
			nombre : nombre
		}, end_sugiere_usuario_nick);
}   
function end_sugiere_usuario_nick(xml){  
	$(xml).find("response").each(function(i){	 	
		if ($(this).find("result").text()=="ok"){	/* NO seleccionar subdis */			
 			$("#nuevo_usuario_usuario").val($(this).find("nick").text());
 			
		}else{ /* subdis 01 NO REGISTRADO */
			swal("CUIDADO",$(this).find("result_text").text(),"error");
		}
	}); 
}


