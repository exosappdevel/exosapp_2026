			$("#nuevo_cliente_alias").val($(this).find("alias").text());	
			$("#nuevo_cliente_razon").val($(this).find("razon_social").text());	
			$("#nuevo_cliente_rfc").val($(this).find("rfc").text());	
			$("#nuevo_cliente_csf").val($(this).find("csf").text());	
			$("#nuevo_cliente_credito").val($(this).find("linea_credito").text());	
			$("#nuevo_cliente_plazo").val($(this).find("plazo_credito").text());	
			$("#nuevo_cliente_estatus").val($(this).find("estatus").text());	

		}
	});
}    
    
