/* subir constancia de situacion fiscal*/
function subir_pdf_csf(){ 	
	//	var id_carpeta	= $("#id_carpeta").val(); 
	var csv_file	= $("#csv_file").val(); 
	var continua = 1;		 	
	if(csv_file == "0" || csv_file == ""){
		continua = 0;
	}		
	if(continua == 1){ 			 
		$.post("controller5.php",   
			{ 	action :"subir_pdf_csf",  
				csv_file 	: csv_file
			},end_subir_pdf_csf);				
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
}  
function end_subir_pdf_csf(xml){	  
	$(xml).find("response").each(function(i){

		$("#btn-solicitar_resurtir_carpeta").removeClass("d-none");
		$("#btn-aceptar_resurtir_carpeta").addClass("d-none");
			
		if ($(this).find("result").text()=="ok"){			
			$("#respuesta_3").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');			 
			$("#files").html("");
			$("#csv_file").val("");	 
			
			$("#pdf_hoja_subido").html($(this).find("ruta_pdf").text());	 
		}else{			
			$("#respuesta_3").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');		
		}		
		setTimeout(function(){
			$("#respuesta_3").html("");
		}, 3000);				
	});
}

