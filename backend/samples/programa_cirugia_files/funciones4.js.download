function end_guardar_bulto(xml){	   
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$('#loading').show();	
			$("#codigo_cirugia").prop( "disabled", false );
			$("#codigo_cirugia").val("");
			  
			$("#inventario_inst_codigo").prop( "disabled", true );
			$("#inventario_inst_referencia").prop( "disabled", true );
			$("#inventario_inst_lote").prop( "disabled", true );
			$("#charola_codigo").prop( "disabled", true );
			
			$("#btn-iniciar_bulto").show();
			$("#btn-agrega_producto_bulto").hide();
			$("#btn-guardar_bulto").hide(); 
			$("#div_foto").hide(); 
			$("#id_bulto").val("0");
			
			$("#table_productos_bulto").html("");
			$("#table_charolas").html("");			
			
			    
			
			window.open(
					$(this).find("filepath").text(),
					'_blank'
				);	
				
			setTimeout(function(){
				$('#loading').hide();	
				window.location.reload();				
			}, 1000); 
			
			
		
		}else{
			swal("Ciudado",$(this).find("result_text").text(),"error");
		}	
	});
}
  
function guardar_carga_valida(){ 
	
	$(".contador").removeClass("d-none"); 
	$("#btn-guardar_carga_valida").addClass("d-none");	 
	document.getElementById("btn-guardar_carga_valida").disabled = true;
	
	var seconds = 8; 
	// Update the count down every 1 second
	xinterval = setInterval(function() { 
		// Display the result in the element with id="demo"
		document.getElementById("contador").innerHTML = seconds;		
		seconds--;
		// If the count down is finished, write some text
		if (seconds < 0) {  
			clearInterval(xinterval);   
			$("#btn-guardar_carga").removeClass("d-none");	 
			document.getElementById("contador").innerHTML = "";
			document.getElementById("btn-guardar_carga").disabled = false;
			$(".contador").addClass("d-none");
		}
	}, 1000);
	
}    


function guardar_carga(){ 
	
	var id_carga 		= $("#id_carga").val();
	var id_autoclave 	= $("#id_autoclave").val();
	
	$.post("controller5.php",    
			{ 	action 			: "guardar_carga", 
				id_carga 		: id_carga,
				id_autoclave 	: id_autoclave
			},end_guardar_carga);
}    
function end_guardar_carga(xml){	   
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$('#loading').show();	
			//	window.open(
			//			$(this).find("filepath").text(),
			//			'_blank'
			//		);	
				
			setTimeout(function(){
				$('#loading').hide();	
				window.location.href="ver_cargas_activas.php";				
			}, 1000); 
			
			
		
		}else{
			swal("Ciudado",$(this).find("result_text").text(),"error");
		}	
	});
}
  

function iniciar_bulto(){
	
	var codigo_cirugia 	= $("#codigo_cirugia").val();
	
	if(codigo_cirugia == ""){
		swal("Ciudado","Es necesario especificar una cirugia","error");
	}else{
		$.post("controller5.php",   
			{ 	action 			: "iniciar_bulto", 
				codigo_cirugia 	: codigo_cirugia
			},end_iniciar_bulto); 
	}
	
	
}   
function end_iniciar_bulto(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			
			$("#codigo_cirugia").prop( "disabled", true );
			  
			$("#inventario_inst_codigo").prop( "disabled", false );
			$("#inventario_inst_referencia").prop( "disabled", false );
			$("#inventario_inst_lote").prop( "disabled", false );
			$("#charola_codigo").prop( "disabled", false );
			
			$("#btn-iniciar_bulto").hide();
			$("#btn-agrega_producto_bulto").show();
			$("#btn-guardar_bulto").show(); 
			$("#div_foto").show(); 
			$("#id_bulto").val($(this).find("id_bulto").text());
		
		}else{
			swal("Ciudado",$(this).find("result_text").text(),"error");
		}	
	});
}
 
 
function iniciar_carga(){
	
	var id_autoclave 	= $("#id_autoclave").val();
	
	$.post("controller5.php",   
			{ 	action 			: "iniciar_carga", 
				id_autoclave 	: id_autoclave
			},end_iniciar_carga);
}   
function end_iniciar_carga(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			
			$("#id_autoclave").prop( "disabled", true );
			  
			$("#bulto_codigo").prop( "disabled", false );
			
			$("#btn-iniciar_carga").hide();
			$("#btn-agregar_bulto_carga").show();
			$("#btn-guardar_carga_valida").show(); 
			//	$("#btn-guardar_carga").show(); 
			//$("#div_foto").show(); 
			$("#id_carga").val($(this).find("id_carga").text());
		
		}else{
			swal("Ciudado",$(this).find("result_text").text(),"error");
		}	
	});
}

 
function agrega_producto_bulto(){ 
	
	var id_bulto 					= $("#id_bulto").val();
	var charola_codigo 				= $("#charola_codigo").val();
	var inventario_inst_codigo 		= $("#inventario_inst_codigo").val();
	var inventario_inst_referencia 	= $("#inventario_inst_referencia").val();
	var inventario_inst_lote 		= $("#inventario_inst_lote").val(); 
	
	$.post("controller5.php",    
			{ 	action 						: "agrega_producto_bulto", 
				id_bulto 					: id_bulto,
				charola_codigo 				: charola_codigo,
				inventario_inst_codigo 		: inventario_inst_codigo,
				inventario_inst_referencia 	: inventario_inst_referencia,
				inventario_inst_lote 		: inventario_inst_lote
			},end_agrega_producto_bulto);
}    
function end_agrega_producto_bulto(xml){	   
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			  
			$("#codigo_cirugia").prop( "disabled", true );
			  
			var tipo = $(this).find("tipo").text();
			
			$("#inventario_inst_codigo").val("");
			$("#inventario_inst_referencia").val("");
			$("#inventario_inst_lote").val("");
			$("#charola_codigo").val("");
			
			if(tipo == "charola"){ 
				$("#charola_codigo").focus();
			}else{  
				$("#inventario_inst_codigo").focus();
			}
 
			$("#respuesta_1").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			$('#loading').hide();	
			setTimeout(function(){
				$("#respuesta_1").html("");  
			}, 2000); 
		
			var cantidad_bultos =  $(this).find("cantidad_bultos").text();
			if(cantidad_bultos > 2){
				swal("Atención !!","Se han añadido más de 2 Charolas/Activos en este bulto. Por favor, verifique que la información sea correcta antes de continuar","warning");
			}  
			  
			 
			llenar_tabla_bulto_charola_tmp();
			llenar_tabla_producto_bulto_tmp();
		
		}else{
			swal("Ciudado",$(this).find("result_text").text(),"error");
		}	
	});
}

