} 
 
function end_llenar_tabla_empleados(xml){  
	$(xml).find("response").each(function(i){	
		
		$("#loading").hide();
		
		if ($(this).find("result").text()=="ok"){				
 			var ocultamiento_columnas = [];	
			var messageTop = "Reporte de Carpetas. <br/> " + "FECHA: " + return_fecha_hoy(); 
			rellena_tablas(xml,"example","table_empleados",ocultamiento_columnas,messageTop,"","1","");
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
	});  
}
    
