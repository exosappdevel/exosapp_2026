function finalizar_soporte(){ 
 
	var id_carga 	= $("#id_carga").val();  	
	var biologico 	= $("#biologico").val(); 
	var humedad 	= $("#humedad").val(); 
	
	if(biologico == 1){
		biologico_text = "POSITIVO";
	}else{
		biologico_text = "NEGATIVO";
	}
	if(humedad == 1){
		humedad_texto = "SECOS"; 
	}else{
		humedad_texto = "MOJADOS";
	}
	
	swal({    
		title: "Desea finalizar el soporte para esta carga?",   
		text: "Usted declara que el Resultado Biologico es " + biologico_text + " y que la humedad es " + humedad_texto,   
		/*type: "warning",    */ 
		showCancelButton: true,    
		confirmButtonColor: "#DD6B55",   
		confirmButtonText: "Si, continuar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 	
	
		$("#loading").show();
		 
	$.post("controller5.php",  
		{ 	action 		:"finalizar_soporte", 
			id_carga 	: id_carga,
			biologico 	: biologico,
			humedad 	: humedad
		},end_finalizar_soporte);					
	}); 	
} 
function end_finalizar_soporte(xml){	 
	$(xml).find("response").each(function(i){		  
		if ($(this).find("result").text()=="ok"){				
			setTimeout(function(){
				$("#loading").hide();
				window.location.href="ver_cargas_historico.php";
			}, 2000); 
						
		}else{			
			var motivo_error = $(this).find("result_text").text();			
			setTimeout(function(){
				$("#loading").hide();
				swal("Error", motivo_error, "error");
			}, 2000);	
		}
	}); 
}
 
