/* guardar formulario */
function guardar_categoria_carpeta(){ 	  
	var nuevo_categoria_id		= $("#nuevo_categoria_id").val(); 
	var nuevo_categoria_almacen	= $("#nuevo_categoria_almacen").val(); 
	var nuevo_categoria_nombre	= $("#nuevo_categoria_nombre").val(); 
	var continua = 1;		
	
	$("#nuevo_categoria_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0; 
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			  	
	 $("#nuevo_categoria_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});				  
	  
	if(continua == 1){ 
		$.post("controller5.php",  
			{ 	action :"guardar_categoria_carpeta", 
				tipo 					: tipoguardado, /*global*/  
				nuevo_categoria_id 		: nuevo_categoria_id,
				nuevo_categoria_almacen : nuevo_categoria_almacen,
				nuevo_categoria_nombre 	: nuevo_categoria_nombre
			},end_guardar_categoria_carpeta);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	} 
} 
function end_guardar_categoria_carpeta(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			if(tipoguardado == "nuevo"){
				$('#nuevo_categoria_form').trigger("reset");
				$("#nuevo_categoria_id").val("0");  
				$(".obligatorio_select").val("0").trigger('change');
			}else if(tipoguardado == "editar"){
				//$("#nuevo__nombre").attr("readonly", "readonly");  // se utiliza cuando algun campo NO puede ser modificado al editar
				$("#nuevo_categoria_id").val($(this).find("nuevo_categoria_id").text()); 
			}else if(tipoguardado == "nuevo_salir"){
				location.href ="ver_categoria_carpeta.php"; 
			} 
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);		
	});
}


 

