function solicita_cancelar_vacaciones(id_vacaciones){	

	swal({    
		title: "Cancelar Solicitud de Vacaciones",   
		text: "Desea continuar?",   
		/*type: "warning",    */ 
		showCancelButton: true,    
		confirmButtonColor: "#DD6B55",   
		confirmButtonText: "Si, continuar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 		
		$.post("controller5.php", 
			{ 	action 			: "solicita_cancelar_vacaciones",
				id_vacaciones 	: id_vacaciones
			}, end_solicita_cancelar_vacaciones);	
	});
}  
function end_solicita_cancelar_vacaciones(xml){    
	$(xml).find("response").each(function(i){	 		
		if ($(this).find("result").text()=="ok"){				
 			llenar_tabla_mis_vacaciones();
			swal("CORRECTO",$(this).find("result_text").text(),"success"); 
		}else{
			swal("La solicitud NO fue procesada",$(this).find("result_text").text(),"error");
		}		
	}); 
}
function solicitar_vacaciones(){		

	var id_empleado 	= $("#id_empleado").val();
	var fecha_inicio 	= $("#fecha_inicio").val();
	var fecha_fin 		= $("#fecha_fin").val();
	var medio_dia 		= $("#medio_dia").val();
	var toma_sueldo 	= $("#toma_sueldo").val();
	var continua = 1;
	
	
	var fecha_inicio_sql 	= conviertefechasql(fecha_inicio);
	var fecha_fin_sql 		= conviertefechasql(fecha_fin);
	
	if(fecha_inicio_sql > fecha_fin_sql){
		
		continua = 0;
		
		$("#respuesta").html('<div class="alert alert-danger">La Fecha Inicio NO puede ser posterior a la Fecha Fin. Por favor verifique.</div>');		
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);		
		
	}else{
		
		$("#nuevo_vacaciones_form .obligatorio").each(function (index) {
			if($(this).val() == ""){
				$(this).addClass("form-control-danger");
				continua = 0;
			}else{ 
				$(this).removeClass("form-control-danger");
			}		
		});			  	
		$("#nuevo_vacaciones_form .obligatorio_select").each(function (index) {
			if($(this).val() == "0"){
				$(this).addClass("form-control-danger");
				continua = 0;
			}else{ 
				$(this).removeClass("form-control-danger");
			}		
		});	
		
		if(continua == 1){ 
			$.post("controller5.php", 
			{ 	action 			: "solicitar_vacaciones",
				id_empleado 	: id_empleado,
				fecha_inicio 	: fecha_inicio,
				fecha_fin 		: fecha_fin, 
				medio_dia 		: medio_dia,
				toma_sueldo 	: toma_sueldo
			}, end_solicitar_vacaciones);	
		}else{		
			$("#respuesta").html('<div class="alert alert-danger">Por favor llena los campos obligatorios</div>');		
			setTimeout(function(){
				$("#respuesta").html("");  
			}, 5000);		
		}
		
	}
	
	
}  
function end_solicitar_vacaciones(xml){  
	$(xml).find("response").each(function(i){	 		
		if ($(this).find("result").text()=="ok"){				
 			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			
			$("#nuevo_vacaciones_form").trigger("reset");
			
			
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);	
		
	}); 
}

