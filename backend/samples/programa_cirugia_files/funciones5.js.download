function guardar_factura_entrada(){		
		
	var fabricante 	= $("#nuevo_entrada_proveedor").val();
	var factura 	= $("#nuevo_entrada_factura").val();
	var cajas 		= $("#nuevo_entrada_cajas").val();
	var continua 	= 1;
	
	$("#nuevo_entrada_fa_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "Verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			 
	$("#nuevo_entrada_fa_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "Verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			 		 
	 
	if(cajas < 1){ 
		
		continua = 0;
		mensaje_error = "La Cantidad de CAJAS recibidas debe ser mayor a CERO. Verifique.";
		
	}	  
	
	//alert("vamos");
	
	if(continua == 1){	
		 
		$("#loading").show();  
			
		$.post("controller6.php", 
			{ 	action 		:"guardar_factura_entrada",
				fabricante 	: fabricante,
				factura 	: factura,
				cajas 		: cajas
			}, end_guardar_factura_entrada); 
				
		
	}else{
		$("#respuesta").html('<div class="alert alert-danger">' + mensaje_error + '</div>');
	}
	
} 
function end_guardar_factura_entrada(xml){  
	$(xml).find("response").each(function(i){			
		$("#loading").hide();  		
		if ($(this).find("result").text()=="ok"){
			
			$("#nuevo_entrada_fa_form").trigger("reset"); 
			
 			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			setTimeout(function(){
				$("#respuesta").html("");  
			}, 3000);			
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
			setTimeout(function(){
				$("#respuesta").html("");  
			}, 5000);		
		}
	}); 
}


function guardar_factura_entrada_registrar(){		
		
	var fabricante 	= $("#nuevo_entrada_proveedor").val();
	var factura 	= $("#nuevo_entrada_factura").val();
	var cajas 		= $("#nuevo_entrada_cajas").val();
	var continua 	= 1;
	
	$("#nuevo_entrada_fa_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "Verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			
	$("#nuevo_entrada_fa_form .obligatorio_select").each(function (index) {
		if($(this).val() == "0"){
			$(this).addClass("form-control-danger");
			continua = 0;
			mensaje_error = "Verifique los campos obligatorios";
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});			 		 
	if(cajas < 1){
		
		continua = 0;
		mensaje_error = "La Cantidad de CAJAS recibidas debe ser mayor a CERO. Verifique.";
		
	}	 
	
	//alert("vamos");
	
	if(continua == 1){	 
		  
		$("#loading").show();  
	
		$.post("controller6.php", 
			{ 	action 	:"guardar_factura_entrada",
				fabricante 	: fabricante,
				factura 	: factura,
				cajas 		: cajas
			}, end_guardar_factura_entrada_registrar); 
		
	}else{
		$("#respuesta").html('<div class="alert alert-danger">' + mensaje_error + '</div>');
	}
	
} 
function end_guardar_factura_entrada_registrar(xml){  
	$(xml).find("response").each(function(i){			
		$("#loading").hide();  		  
		if ($(this).find("result").text()=="ok"){				
 			window.location.href="nuevo_entrada_factura.php?id_entrada_factura=" + $(this).find("id_entrada_factura").text();
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
			setTimeout(function(){
				$("#respuesta").html("");  
			}, 5000);		
		}
	}); 
}
  






