/* ************* PERMISOS POR TIPO DE USUARIO  *********************** */
/* ******************************************************************* */
/* ******************************************************************* */
/* ******************************************************************* */
function agrega_usuario_tipo_permiso(){       
	var id_usuario 		= $("#id_usuario").val();	
	var id_almacen 		= $("#selecciona_almacen").val();	 
	var tipo_usuario 	= $("#selecciona_tipo_usuario").val();	
	 
	if(tipo_usuario != "0"){		   
		$.post("controller6.php",  
			{ 	action 			: "agrega_usuario_tipo_permiso", 
				id_usuario 		: id_usuario, 
				id_almacen 		: id_almacen, 
				tipo_usuario 	: tipo_usuario 
			}, end_agrega_usuario_tipo_permiso);  
			
	}else{
		$("#respuesta").html('<div class="alert alert-danger">Seleccione una sucursal</div>');
		setTimeout(function(){  
			$("#respuesta").html("");   
		}, 2000);
	}
}     
function end_agrega_usuario_tipo_permiso(xml){     
	$(xml).find("response").each(function(i){   
		if ($(this).find("result").text()=="ok"){	
			$("#selecciona_tipo_usuario").val("0");	
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');	
			llenar_tabla_usuario_tipo_permiso();				
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');	
		}		
		setTimeout(function(){  
			$("#respuesta").html("");   
		}, 2000);	
	});
} 

  
function llenar_tabla_usuario_tipo_permiso(){    
	var id_usuario 	= $("#id_usuario").val();
	$.post("controller6.php",  
		{ 	action :"llenar_tabla_usuario_tipo_permiso",
			id_usuario 		: id_usuario
		}, end_llenar_tabla_usuario_tipo_permiso);  
} 
function end_llenar_tabla_usuario_tipo_permiso(xml){      
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){    
		 
			var nombre_usuario = $(this).find("nombre_usuario").text();					
			$("#nombre_de_usuario").html(nombre_usuario);
			
			var ocultamiento_columnas = [];	  
			var messageTop = "Reporte de Sucursales por Usuario. <br/> " + "FECHA: " + return_fecha_hoy(); 
			rellena_tablas(xml,"example","table_usuario",ocultamiento_columnas,messageTop,"","",""); 
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
	});  
}  

/* RELACION USUARIO PERMISO POR TIPO */
function eliminar_usuario_permiso(id_permiso){    
	swal({    
		title: "¿Eliminar?",   
		text: "Esta acción es definitiva y no podrá revertirse.",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "#DD6B55",   
		confirmButtonText: "Si, eliminar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 		  
		$.post("controller6.php",
			{ 	action 		: "eliminar_usuario_permiso",  
				id_permiso 	: id_permiso
			}, end_eliminar_usuario_permiso);
	});
}   
function end_eliminar_usuario_permiso(xml){    
	$(xml).find("response").each(function(i){	 	   
		if ($(this).find("result").text()=="ok"){ 
			//$('[data-toggle="tooltip"]').tooltip("dispose"); 
			llenar_tabla_usuario_tipo_permiso();	    	  
		}else{		
			var mensaje = $(this).find("result_text").text();
			setTimeout(function(){
				swal("Error", "" + mensaje + "", "error");
				$('[data-toggle="tooltip"]').tooltip("dispose"); 
			}, 500);	
		}  
	});
}  

