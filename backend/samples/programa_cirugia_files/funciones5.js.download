function validar_entrada_factura(){   

	var id_entrada_factura = $("#id_entrada_factura").val(); 
	var caja = $("#id_caja").val(); 
	
	//alert("id_entrada_factura: " + id_entrada_factura);
	
	var continua = 1;
	
	if(id_entrada_factura == 0){
		continua = 0;
	}    
 
	if(continua == 1){  
		$.post("controller6.php", 
		{ 	action :"validar_entrada_factura", 
			id_entrada_factura : id_entrada_factura, 
			caja : caja 
		}, end_validar_entrada_factura);
	}
	
}
function end_validar_entrada_factura(xml){   
	$(xml).find("response").each(function(i){		 
