function cancelar_entrada_almacen_factura(id_entrada_factura){ 
	if(id_entrada_factura != "0"){  		
		swal({    
			title: "¿Eliminar TODOS este registro de ENTRADA?",   
			text: "Esta accion no podra deshacerse",   
			/*type: "warning",    */
			showCancelButton: true,    
			confirmButtonColor: "#DD6B55",   
			confirmButtonText: "Si, eliminar",  
			cancelButtonText: "Regresar",   
			closeOnConfirm: true 
		}, function(){ 		   
			$('#loading').show(); 
			$.post("controller6.php", 
			{ 	action 		: "cancelar_entrada_almacen_factura",  
				id_entrada_factura 	: id_entrada_factura   
			}, end_cancelar_entrada_almacen_factura); 
		}); 		
	}	
}   
function end_cancelar_entrada_almacen_factura(xml){     
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){
			llenar_tabla_entradas_factura(); 
			$('#loading').hide();
		}else{
			$('#loading').hide();
			alert($(this).find("result_text").text());
		}
	});
}   
 
