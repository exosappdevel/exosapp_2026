/* FUNCIONALIDAD AGREGAR MEDICOS VENDEDORES */
function agrega_subdis_vendedor(){ 
	
	var id_vendedor 		= $("#id_vendedor").val();	
	var id_subdistribuidor 	= $("#nuevo_subdis_vendedor").val();
	 
	var continua = 1;  

	if(id_vendedor == 0 || id_vendedor == ""){
		continua = 0;
		return false;
	} 
	if(id_subdistribuidor == 0 || id_subdistribuidor == ""){
		continua = 0;
		return false;
	}
	
	if(continua == 1){  
		$('#loading').show();  
		$.post("controller6.php", 
			{ 	action 		: "agrega_subdis_vendedor",
				id_vendedor	: id_vendedor, 
				id_subdistribuidor	: id_subdistribuidor
			}, end_agrega_subdis_vendedor);   		  
	}
 
}
function end_agrega_subdis_vendedor(xml){ 
	$(xml).find("response").each(function(i){ 
		if ($(this).find("result").text()=="ok"){	 
				
			llenar_tabla_subdis_vendedor(); 
			$('#loading').hide();			 
		}else{
			$('#loading').hide();
			swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
			
	});
}


