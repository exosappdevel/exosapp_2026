$("#btn-aceptar_consumo_remision_vd").click(guardar_consumo_remision_vd);
$("#btn-guardar_consumo_remision_vd").click(validar_consumo_remision_vd);
 
 
    
function validar_consumo_remision_vd(){	

	var remision_folio 	= $("#remision_folio").val();
		 
	var continua = 1;
	
	if(remision_folio == ""){
		continua = 0;
		swal("Error","Escriba Folio", "error");
		
	}
	
	if(continua == 1){
		
		// $("#disparamodal").click(); 
		document.getElementById("btn-aceptar_consumo_remision_vd").disabled = true;
	
		$("#btn-guardar_consumo_remision_vd").addClass("d-none");	 
		$("#btn-aceptar_consumo_remision_vd").removeClass("d-none");	 
		
		$(".contador").removeClass("d-none");
		
		var seconds = 8; 
		// Update the count down every 1 second
		xinterval = setInterval(function() { 
			// Display the result in the element with id="demo"
			document.getElementById("contador").innerHTML = seconds;
			 
			seconds--;
			// If the count down is finished, write some text
			if (seconds < 0) {   
				clearInterval(xinterval);  
				$("#btn-aceptar_consumo_remision_vd").removeClass("d-none");	 
				document.getElementById("contador").innerHTML = "";
				document.getElementById("btn-aceptar_consumo_remision_vd").disabled = false;
				$(".contador").addClass("d-none");
			}
		}, 1000);
		
	}
 
} 


function guardar_consumo_remision_vd(){       

	var remision_folio 	= $("#remision_folio").val();
	var id_solicitud 	= $("#id_solicitud").val();
	var id_cirugia 	= $("#id_cirugia").val();
		 
	var continua = 1;
	
	if(remision_folio == ""){
		continua = 0;
		swal("Error","Escriba Folio", "error");
		
	}
	
	if(continua == 1){
		
		swal({  
			title: "Reportar Consumos y Finalizar Cirugia?",
			text: "Si genera la remisión ya no podrá regresar. Desea Continuar?",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, continuar",
			cancelButtonText: "No, Regresar",
			closeOnConfirm: true,
			closeOnCancel: true  
		},  
		function(isConfirm) {  
			if (isConfirm) { 			 
				$('#loading').show();		 	
				$.post("controller6.php",    
					{ 	action 			: "guardar_consumo_remision_vd", 
						remision_folio 	: remision_folio, 
						id_cirugia 		: id_cirugia, 
						id_solicitud 	: id_solicitud 
					}, end_guardar_consumo_remision_vd); 
			} else {
				return false;
			}  
		});  
		
	} 
	
}         
function end_guardar_consumo_remision_vd(xml){	 
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){ 				   
			var id_cirugia = $(this).find("id_cirugia").text();
			var id_remision = $(this).find("id_remision").text();			
			window.location.href= "generar_remision.php?id_cirugia=" + id_cirugia + "&id_remision=" + id_remision;
		}else{
			$('#loading').hide();		 
			swal("Error", $(this).find("result_text").text(), "error");
		}
	});
}

/* ********************************* */
/* ******PIN************ */
/* ********************************* */
 
function cambiar_pin(){   	 

	var pin_actual 		= $("#pin_actual").val();
	var pin_nuevo 		= $("#pin_nuevo").val();
	var pin_confirma 	= $("#pin_confirma").val();	
	var continua = 1;
			
	if(pin_nuevo != pin_confirma){		
		swal("Cuidado","Los campos PIN NUEVO y CONFIRME PIN NUEVO son diferentes. Por favor verifique.","error");
		continua = 0;		
	}	
	 
	if(continua == 1){
		$.post("controller6.php",
			{ 	action 	:"cambiar_pin",
				pin_actual : pin_actual,
				pin_nuevo : pin_nuevo
			}, end_cambiar_pin);  		  
	}	  
}    
function end_cambiar_pin(xml){	      
	$(xml).find("response").each(function(i){	  
		if ($(this).find("result").text()=="ok"){ 
			swal("Correcto","Su PIN de 4 digitos fue actualizado correctamente.","success");
		}else{
			swal("Cuidado",$(this).find("result_text").text(),"error");
		}
		
		$("#pin_actual").val("");
		$("#pin_nuevo").val(""); 
		$("#pin_confirma").val("");
		
	}); 
}


 
function obtiene_tipo_usuario_nombre(){   	 
	var id_tipo_usuario = $("#id_tipo_usuario").val();	
	$.post("controller6.php",
		{ 	action 	:"obtiene_tipo_usuario_nombre",
			id_tipo_usuario : id_tipo_usuario
		}, end_obtiene_tipo_usuario_nombre);
}    
function end_obtiene_tipo_usuario_nombre(xml){	      
	$(xml).find("response").each(function(i){	   
		if ($(this).find("result").text()=="ok"){ 
			$("#tipo_usuario").html($(this).find("tipo_usuario").text());
		}	
	}); 
}



