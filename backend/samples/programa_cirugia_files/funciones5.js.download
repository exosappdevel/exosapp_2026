function filtrar_producto_excel(){
	
	var fabricante 	= $("#filtro_producto_fabricante").val();
	var marca 		= $("#filtro_producto_marca").val();
	var categoria 	= $("#filtro_producto_categoria").val();
	var nombre 		= $("#filtro_producto_nombre").val();
	var referencia 	= $("#filtro_producto_referencia").val();
	
	window.open("filtrar_producto_excel.php?fabricante=" + fabricante + "&marca=" + marca + "&categoria=" + categoria + "&nombre=" + nombre + "&referencia=" + referencia);		
	
} 
function buscar_inventario_exportar_excel(){
		
	window.open("buscar_inventario_exportar_excel.php");		
	
}

function activos_reporte_exportar_excel(){ 
	
	var tipo_reporte = $("#tipo_reporte").val();
	
	$("#btn-cancelar").trigger("click");  
	
	window.open("activos_reporte_exportar_excel.php?tipo_reporte=" + tipo_reporte);		
		
	
	
	
	
}

