/* almacenes */
function guardar_subdis(){ 	 
	var nuevo_subdis_id	 		= $("#nuevo_subdis_id").val();  
	var nuevo_subdis_nombre 	= $("#nuevo_subdis_nombre").val();
	var nuevo_subdis_codigo 	= $("#nuevo_subdis_codigo").val(); 
	var nuevo_subdis_socio 		= $("#nuevo_subdis_socio").val();
	//var nuevo_subdis_almacen 	= $("#nuevo_subdis_almacen").val();
	var continua = 1;		
	
	$("#nuevo_subdis_form .obligatorio").each(function (index) {
		if($(this).val() == ""){
			$(this).addClass("form-control-danger");
			continua = 0;
		}else{ 
			$(this).removeClass("form-control-danger");
		}		
	});		
	  
	if(continua == 1){    
		$.post("controller6.php",  
			{ 	action :"guardar_subdis", 
				tipo 					: tipoguardado, /*global*/  
				nuevo_subdis_id 		: nuevo_subdis_id,  
				nuevo_subdis_nombre 	: nuevo_subdis_nombre,
				nuevo_subdis_codigo 	: nuevo_subdis_codigo,
				nuevo_subdis_socio 		: nuevo_subdis_socio
			},end_guardar_subdis);
	}else{
		swal("Revisa el formulario", "Llena todos los campos marcados como OBLIGATORIO", "error");
	}
} 
function end_guardar_subdis(xml){	  
	$(xml).find("response").each(function(i){		
		if ($(this).find("result").text()=="ok"){
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');
			if(tipoguardado == "nuevo"){
				$("#nuevo_subdis_nombre").removeAttr("readonly"); 
				$('#nuevo_subdis_form').trigger("reset"); 
				$("#nuevo_subdis_id").val("0"); 
				$(".obligatorio_select").val("0").trigger('change');
			}else if(tipoguardado == "editar"){
				//$("#nuevo__nombre").attr("readonly", "readonly");  // se utiliza cuando algun campo NO puede ser modificado al editar
				$("#nuevo_subdis_id").val($(this).find("nuevo_subdis_id").text()); 
			}else if(tipoguardado == "nuevo_salir"){
				location.href ="ver_subdistribuidores.php"; 
			}
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
		}
		setTimeout(function(){
			$("#respuesta").html("");  
		}, 5000);		
	});
}
 

