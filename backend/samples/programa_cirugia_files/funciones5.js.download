function buscar_producto_inventario_factura(){
	
	var id_producto 	= $("#id_producto").val(); 
	var codigo_2 		= $("#nuevo_entrada_codigo_2").val(); 
	var cantidad 		= $("#nuevo_entrada_cantidad").val();
	var sugerir 		= $("#nuevo_entrada_sugerir").val();
	var caducidad 		= $("#nuevo_entrada_caducidad_automatica").val();
	
	var nuevo_entrada_proveedor 		= $("#nuevo_entrada_proveedor").val();
	
	var continua 		= 1; 
	var doscaracteres 	= ""; 
	
	if(codigo_2 == ""){ 
		continua = 0;
		//swal("Cuidado", "Por favor ingresa un codigo", "error");
		return false;
	}	
	if(cantidad == "0" || cantidad == ""){ 
		continua = 0;
		//swal("Cuidado", "Por favor ingresa una cantidad", "error");
		return false;
	}
	
	
	if(codigo_2 != "" && codigo_2 != undefined){ 
		doscaracteres = codigo_2.substr(0, 2);
	}
	
	doscaracteres = "NA";
	
	if(continua == 1){  
		if(doscaracteres == "01"){  
			/* de manera general el codigo 1 inicia con "01" y muchas veces el usuario por error escanea el codigo 1 */
			/* entonces si detectamos que el codigo 2 inicia en 01 vamos a avisar al usuario que revise */ 		
			swal({    
				title: "ATENCION",   
				text: "El código 2 inicia con 01  ¿Es correcto? ",   
				type: "warning",
				showCancelButton: true,    
				confirmButtonColor: "#DD6B55",    
				confirmButtonText: "Si, es correcto",  
				cancelButtonText: "Modificar",   
				closeOnConfirm: true 
			}, function(){ 		

				swal.close();
				
				
				$.post("controller.php", 
					{ 	action : "buscar_producto_inventario",
						id_producto: id_producto, 
						codigo_2: codigo_2, 
						cantidad: cantidad,  
						sugerir: sugerir,    
						caducidad: caducidad,  
						nuevo_entrada_proveedor: nuevo_entrada_proveedor	  
					}, end_buscar_producto_inventario);  
			});
		}else{
			$.post("controller.php", 
				{ 	action : "buscar_producto_inventario",
					id_producto: id_producto, 
					codigo_2: codigo_2, 
					cantidad: cantidad,  
					sugerir: sugerir,    
					caducidad: caducidad,
					nuevo_entrada_proveedor: nuevo_entrada_proveedor							
				}, end_buscar_producto_inventario);  
		}
	} 
	
	/*
	if(continua == 1){ 
		$.post("controller.php", 
			{ 	action : "buscar_producto_inventario",
				id_producto: id_producto, 
				codigo_2: codigo_2, 
				cantidad: cantidad,  
				sugerir: sugerir,    
				caducidad: caducidad    
			}, end_buscar_producto_inventario);  		 
	}*/
 
}  
function end_buscar_producto_inventario(xml){ 
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){
			 
			/*altas de almacen*/  
			/*$("#nuevo_entrada_nueva_cantidad").val($(this).find("lote").text()); */
			$("#id_producto").val($(this).find("id_producto").text()); 
			 			
			$("#nuevo_entrada_lote").val($(this).find("lote").text()); 
			$("#nuevo_entrada_caducidad").val($(this).find("fecha_cad").text());
			$("#nuevo_entrada_area").val($(this).find("area").text());  
			$("#nuevo_entrada_subarea").val($(this).find("subarea").text());
			$("#nuevo_entrada_nivel").val($(this).find("nivel").text());
			$("#nuevo_entrada_nueva_cantidad").val($(this).find("nueva_cantidad").text());
			$("#nuevo_entrada_precio").val($(this).find("precio").text());  
			
			var id_inventario = $(this).find("id_inventario").text();
			var id_inventario_tmp = $(this).find("id_inventario_tmp").text(); 
			
			//alert(id_inventario);
			//alert(id_inventario_tmp);
			
			if(id_inventario_tmp == "NA" || id_inventario_tmp == "0")  
				$("#nuevo_entrada_id_inventario").val($(this).find("id_inventario").text()); 
			if(id_inventario == "NA" || id_inventario == "0")
				$("#nuevo_entrada_id_inventario").val($(this).find("id_inventario_tmp").text());
						
			if($(this).find("guarda_automatico").text() == "1"){				
				//registrar_entrada_inventario(); 
				
				var nuevo_entrada_automatico = $("#nuevo_entrada_automatico").val();
				if(nuevo_entrada_automatico == "1"){
					valida_caducidad_ef(); 
				}
				
			}
			 
		}else{ 
			//$("#nuevo_entrada_lote").val(""); 
			//$("#nuevo_entrada_caducidad").val("");
			
			//$("#nuevo_entrada_area").val("");
			//$("#nuevo_entrada_nivel").val("");
			//$("#nuevo_entrada_subarea").val("");
			//$("#nuevo_entrada_id_inventario").val("0");
			//$("#nuevo_entrada_lote").val($(this).find("lote").text()); 
			//$("#nuevo_entrada_caducidad").val($(this).find("fecha_cad").text());
			//$("#nuevo_entrada_nueva_cantidad").val("0"); 
			
			$("#nuevo_entrada_lote").val($(this).find("lote").text()); 
			$("#nuevo_entrada_caducidad").val($(this).find("fecha_cad").text());
			$("#nuevo_entrada_area").val($(this).find("area").text());  
			$("#nuevo_entrada_subarea").val($(this).find("subarea").text());
			$("#nuevo_entrada_nivel").val($(this).find("nivel").text());
			$("#nuevo_entrada_nueva_cantidad").val($(this).find("nueva_cantidad").text());
			$("#nuevo_entrada_precio").val($(this).find("precio").text());  
			
			$("#respuesta").html("");  
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
			 
			var audio = document.getElementById("audio");
			audio.play();
			
			 
			document.getElementById('btn-registrar_entrada').focus();
			
			
			$("#id_producto").val("0");
			document.getElementById('buscar_producto_codigo').focus();
			 
			$("#buscar_producto_codigo").val("0");
			$("#nuevo_entrada_referencia").val("0");
			$("#nuevo_entrada_nombre").val("0");
			
			swal("Ocurrio un error","Ultimo producto escaneado - codigo 2: " + $(this).find("codigo_2").text(),"error");
			//saltar(event, "btn-registrar_entrada");
			
			
				
			/*
			setTimeout(function(){  
				$("#respuesta").html("");  
			}, 5000);	
			*/
			
			//swal("No hay inventario",$(this).find("result_text").text(),"warning");
		}
	});
}


function valida_caducidad_ef(){ 
	var caducidad 		= $("#nuevo_entrada_caducidad").val();
	var id_auditoria 	= $("#id_auditoria").val();

	//alert(id_auditoria);
	//return false;
	
	var fechaInicio = new Date().getTime();
	var fechaFin    = new Date(caducidad).getTime();

	var diff = fechaFin - fechaInicio;
	var dias_transcurridos = (diff/(1000*60*60*24) );
	
	if(dias_transcurridos < 365){
		swal({ 
			title: "Alerta",
			text: "La fecha de caducidad es menor a 1 año. Desea Continuar?",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, continuar",
			cancelButtonText: "No, Regresar",
			closeOnConfirm: true,
			closeOnCancel: true
		}, 
		function(isConfirm) { 
			if (isConfirm) {
				if(id_auditoria === undefined){
					registrar_entrada_inventario_factura();
				}else{
					registrar_auditoria_manual();
				}				
			} else {
				return false;
			} 
		});
	}else{
		if(id_auditoria === undefined){
			registrar_entrada_inventario_factura();
		}else{
			registrar_auditoria_manual();
		}				
	}

	
} 

