/*Entradas al almacen por ID entrada - muestra Inventario_tmp */ 
function imprimir_pdf_validar_entrada_factura(){   

	//	var id_entrada_factura = $("#id_entrada_factura").val(); 
	var id_entrada = $("#id_entrada_almacen").val(); 
	var caja = $("#id_caja").val(); 
	
	//alert("id_entrada_factura: " + id_entrada_factura);
	
	var continua = 1;  
	
	if(id_entrada_factura == 0){
		continua = 0;
	}     
 
	if(continua == 1){  
		$.post("controller6.php", 
		{ 	action :"imprimir_pdf_validar_entrada_factura", 
			id_entrada : id_entrada,  
			caja : caja 
		}, end_imprimir_pdf_validar_entrada_factura);
	}
	   
} 
function end_imprimir_pdf_validar_entrada_factura(xml){   
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){	    
			window.open( $(this).find("filepath").text(), '_blank' );  
			
			$("#btn-iniciar_registro").addClass("d-none");    
			$("#btn-firmar_validar_entrada_factura").removeClass("d-none"); 
			$("#btn-validar_entrada_factura").addClass("d-none");  
			$("#btn-imprimir_pdf_validar_entrada_factura").removeClass("d-none");
			
			$("#div-iniciar_registro").addClass("d-none");    
			$("#div-firmar_validar_entrada_factura").removeClass("d-none"); 
			$("#div-validar_entrada_factura").addClass("d-none");  
			$("#div-imprimir_pdf_validar_entrada_factura").removeClass("d-none");			
			
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
	});  
}  

//	    
/*Entradas al almacen por ID entrada - muestra Inventario_tmp */ 
function firmar_validar_entrada_factura(){     

	//	var id_entrada_factura = $("#id_entrada_factura").val(); 
	var pin 		= $("#pin").val(); 
	var id_entrada 	= $("#id_entrada_almacen").val(); 
	var caja 		= $("#id_caja").val(); 
	
	//alert("id_entrada_factura: " + id_entrada_factura);
	
	var continua = 1;  
	 
	if(pin == ""){ 
		swal("Error","Escriba su PIN para Continuar", "error");
		continua = 0;
	}
	
	if(id_entrada_factura == 0){
		continua = 0;
	}      
  
	if(continua == 1){   
		$.post("controller6.php", 
		{ 	action 		: "firmar_validar_entrada_factura", 
			pin 		: pin,  
			id_entrada 	: id_entrada,  
			caja 		: caja 
		}, end_firmar_validar_entrada_factura); 
	}
	   
}
function end_firmar_validar_entrada_factura(xml){   
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){	     
			
			$("#btn-iniciar_registro").addClass("d-none");    
			$("#btn-firmar_validar_entrada_factura").addClass("d-none"); 
			$("#btn-validar_entrada_factura").removeClass("d-none");  
			$("#btn-imprimir_pdf_validar_entrada_factura").addClass("d-none");
			
			$("#div-iniciar_registro").addClass("d-none");       
			$("#div-firmar_validar_entrada_factura").addClass("d-none"); 
			$("#div-validar_entrada_factura").removeClass("d-none");  
			$("#div-imprimir_pdf_validar_entrada_factura").addClass("d-none");			
			
			/* si el PIN es correcto, ejecuta el nuevo PDF */
			//	imprimir_pdf_validar_entrada_factura();
			
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
