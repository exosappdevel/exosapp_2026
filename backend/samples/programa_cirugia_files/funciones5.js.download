/* ******************************************************************* */
/* ******************************************************************* */
/* ********************* IMPRESION DE ETIQUETAS  ********************* */
/* ******************************************************************* */
/* ******************************************************************* */
/* ******************************************************************* */

/* **** AQUI VALIDAMOS LA CANTIDAD DE PRODUCTOS QUE SE REGISTRAR EN LA ENTRADA *** */
/* **** SI SE ELIGE IMPRIMIR ETIQUETAS, Y SE ESCRIBEN MÁS DE 5 PRODUCTOS, PREGUNTA SI DESEA CONTINUAR *** */
function valida_cantidad_etiquetas(){ 
	var imprimir 	= $("#imprimir_etiquetas").val();
	var cantidad 	= $("#nuevo_entrada_cantidad").val(); 


	console.log("CANTIDAD::: " + cantidad);
	
	if(imprimir == 1 && cantidad > 5){
		swal({ 
			title: "Alerta",
			text: "Eligió imprimir más de " + cantidad + " etiquetas. Desea continuar???",
			type: "warning",
			showCancelButton: true,
			confirmButtonClass: "btn-danger",
			confirmButtonText: "Si, continuar",
			cancelButtonText: "No, Regresar",
			closeOnConfirm: true,
			closeOnCancel: true
		}, 
		function(isConfirm) { 
			if (isConfirm) {
				
				//	swal.close();
				
				valida_caducidad_ef();
			} else {
				return false;
			}  
		});
	}else{
		
		//	swal.close();
		
		valida_caducidad_ef();
	}

	
} 


 
/* ******************************************************************* */
/* ******************************************************************* */
/* ************* MODULO CONTEO RAPDIO DE REFERENCIAS  **************** */
/* ******************************************************************* */
/* ******************************************************************* */
/* ******************************************************************* */

  
function eliminar_conteo_referencia(id_conteo_producto){     
	$.post("controller6.php",    
		{ 	action 		:"eliminar_conteo_referencia",
			id_conteo_producto 	: id_conteo_producto
		}, end_eliminar_conteo_referencia);  
}  
function end_eliminar_conteo_referencia(xml){      
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){    
		 	llenar_tabla_conteo_referencia();
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
	});  
}  

function llenar_tabla_conteo_referencia(){     
	var id_conteo 	= $("#id_conteo").val();
	$.post("controller6.php",    
		{ 	action 		:"llenar_tabla_conteo_referencia",
			id_conteo 	: id_conteo
		}, end_llenar_tabla_conteo_referencia);  
}  
function end_llenar_tabla_conteo_referencia(xml){      
	$(xml).find("response").each(function(i){		 
		if ($(this).find("result").text()=="ok"){    
		 
			$("#total_productos").html($(this).find("total_productos").text());
			
		 	var ocultamiento_columnas = [];	  
			var messageTop = "Reporte de Conteo Rápido de Productos por Referencia. <br/> " + "FECHA: " + return_fecha_hoy(); 
			rellena_tablas(xml,"example","table_conteo",ocultamiento_columnas,messageTop,"","",""); 
		}else{
			swal("Error",$(this).find("result_text").text(), "error");
		}
	});  
}  

function iniciar_conteo_referencia(){
	
	swal({    
		title: "¿Comenzar un nuevo conteo rápido?",   
		text: "Si tiene un conteo activo se perderá toda la informacion. ¿Continuar?",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "#DD6B55",   
		confirmButtonText: "Si, continuar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){ 		  
		$.post("controller6.php",
			{ 	action 		: "iniciar_conteo_referencia"
			}, end_iniciar_conteo_referencia);
	});
	
} 
function end_iniciar_conteo_referencia(xml){     
	$(xml).find("response").each(function(i){   
		if ($(this).find("result").text()=="ok"){	
			
			$("#id_conteo").val($(this).find("id_conteo").text());
			$("#table_conteo").html("");
			$("#total_productos").html(""); 
			
			$("#respuesta1").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');	
		}else{
			$("#respuesta1").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');	
		}		
		setTimeout(function(){  
			$("#respuesta1").html("");   
		}, 3000);	
	});
} 

function contar_producto(){ 
		 
	var id_conteo 		= $("#id_conteo").val();
	var conteo_codigo 	= $("#conteo_codigo").val();
	
	if(id_conteo == 0){
		
		swal("Error","Por favor inicie el conteo", "error");
		return false;
		
	}else{
		
		if(conteo_codigo != "0" && conteo_codigo != ""){		   
			$.post("controller6.php", 
				{ 	action 			: "contar_producto", 
					id_conteo 		: id_conteo,  
					conteo_codigo 	: conteo_codigo
				}, end_contar_producto);  
				
		}else{
			$("#respuesta").html('<div class="alert alert-danger">Por favor escanie un producto</div>');
			setTimeout(function(){  
				$("#respuesta").html("");   
			}, 2000);
		}
	}
	 
} 
function end_contar_producto(xml){     
	$(xml).find("response").each(function(i){   
		if ($(this).find("result").text()=="ok"){	
			
			$("#conteo_codigo").val(""); 
			$("#conteo_codigo").focus();
			
			llenar_tabla_conteo_referencia();
			
			$("#respuesta").html('<div class="alert alert-success">' + $(this).find("result_text").text() + '</div>');	
		}else{
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');	
		}		
		setTimeout(function(){  
			$("#respuesta").html("");   
		}, 3000);	
	});
} 
 
