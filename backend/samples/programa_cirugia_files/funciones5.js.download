function eliminar_subdistribuidor(id_subdistribuidor){	
	swal({   
		title: "¿Eliminar Subdistribuidor?",   
		text: "Esta acción es definitiva y no podrá revertirse.",   
		/*type: "warning",    */
		showCancelButton: true,    
		confirmButtonColor: "#DD6B55",   
		confirmButtonText: "Si, eliminar",  
		cancelButtonText: "Regresar",   
		closeOnConfirm: true 
	}, function(){   
		swal.close();	
		$.post("controller6.php",   
			{ 	action 		:"eliminar_subdistribuidor", 
				id_subdistribuidor 	: id_subdistribuidor						
			},end_eliminar_subdistribuidor); 
	});  		
} 
