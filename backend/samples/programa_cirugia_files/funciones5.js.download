function end_registrar_entrada_inventario_factura(xml){  
	$(xml).find("response").each(function(i){
		if ($(this).find("result").text()=="ok"){	

			
			$( "#buscar_producto_codigo" ).prop( "disabled", false );
			$( "#nuevo_entrada_codigo_2" ).prop( "disabled", false );
			
			$('#id_producto').val("0");  
			
			
			//$('#nuevo_entrada_form').trigger("reset"); 
			$('#nuevo_entrada_cantidad').val("1"); 
			$('#nuevo_entrada_codigo_2').val(""); 
			$('#nuevo_entrada_lote').val(""); 
			$('#nuevo_entrada_caducidad').val(""); 
			$('#buscar_producto_codigo').val(""); 
			$('#nuevo_entrada_referencia').val(""); 
			$('#nuevo_entrada_nombre').val("");  
			$('#nuevo_entrada_precio').val("0");  
			
			 
			    
			/* esconde botones*/
			$("#btn-iniciar_registro").addClass("d-none");    
			$("#btn-firmar_validar_entrada_factura").addClass("d-none"); 
			$("#btn-validar_entrada_factura").addClass("d-none");  
			$("#btn-imprimir_pdf_validar_entrada_factura").removeClass("d-none");
			
			$("#div-iniciar_registro").addClass("d-none");      
			$("#div-firmar_validar_entrada_factura").addClass("d-none"); 
			$("#div-validar_entrada_factura").addClass("d-none");   
			$("#div-imprimir_pdf_validar_entrada_factura").removeClass("d-none");	
		
		  
			$('#loading').hide();	 
			 
 
			$("#id_entrada_almacen").val($(this).find("id_entrada").text());
			//llenar_tabla_entrada_almacen();
			$('#buscar_producto_codigo').focus();	
			llenar_tabla_entrada_almacen_inventariotmp_factura();   
			 
			//	$("#nuevo_entrada_proveedor").val($(this).find("proveedor").text());
			 
			/* aqui se manda imprimir etiquetas */  
			var imprimir = $("#imprimir_etiquetas").val();
			
			console.log(imprimir);
			
			if (imprimir == 1){
				
				console.log("SI SE IMPRIME :::: " + imprimir);
				
				
				imprimir_ticket_regsan_por_producto($(this).find("id_producto").text(), $(this).find("cantidad").text());
			}else{
				
				console.log("NO SE IMPRIME :::: " + imprimir);
				
			}
			
		}else{
			
			
			$( "#buscar_producto_codigo" ).prop( "disabled", false );
			$( "#nuevo_entrada_codigo_2" ).prop( "disabled", false );
		
			$('#loading').hide();
			//alert("1");
			
			
			$("#id_producto").val("0");
			document.getElementById('buscar_producto_codigo').focus();
			 
			$("#buscar_producto_codigo").val("0");
			$("#nuevo_entrada_referencia").val("0");
			$("#nuevo_entrada_nombre").val("0");
			
			//$('#nuevo_entrada_form').trigger("reset"); 
			$('#nuevo_entrada_cantidad').val("1"); 
			$('#nuevo_entrada_codigo_2').val(""); 
			$('#nuevo_entrada_lote').val(""); 
			$('#nuevo_entrada_caducidad').val(""); 
			$('#buscar_producto_codigo').val(""); 
			$('#nuevo_entrada_referencia').val(""); 
			$('#nuevo_entrada_nombre').val("");  
			$('#nuevo_entrada_precio').val("0");  
			
			swal("Ocurrio un error",$(this).find("result_text").text() + " ::: Ultimo producto escaneado codigo 2: " + $(this).find("codigo_2").text(),"error");
			//swal("Ocurrio un error",$(this).find("result_text").text(),"error");
		}
	});
}


function iniciar_registro_entrada_por_factura(){       	
	var iniciar 	= $("#iniciar_registro").val();	
	var factura 	= $("#nuevo_entrada_factura").val();
	var caja	 	= $("#nuevo_entrada_caja").val();
	var continua = 1;	
	
	if(factura == "0" || caja == "0"){ 
		swal("por favor seleccione Factura y Caja");
		continua = 0; 
	}		 
	 
	if(continua == 1){		
		if(iniciar == 0){  /* va a iniciar el registro */		
					  
			$("#iniciar_registro").val("1");			
			
			//	$("#btn-iniciar_registro").removeClass("btn-primary");
			//	$("#btn-iniciar_registro").addClass("btn-danger");
			//	$("#btn-iniciar_registro").html("Guardar Registro de Entrada"); 			
						 
			$("#btn-iniciar_registro").addClass("d-none"); 
			$("#btn-firmar_validar_entrada_factura").addClass("d-none"); 
			$("#btn-validar_entrada_factura").addClass("d-none");  
			$("#btn-imprimir_pdf_validar_entrada_factura").removeClass("d-none");
			
			$("#div-iniciar_registro").addClass("d-none"); 
			$("#div-firmar_validar_entrada_factura").addClass("d-none");  
			$("#div-validar_entrada_factura").addClass("d-none");  
			$("#div-imprimir_pdf_validar_entrada_factura").removeClass("d-none");
			
			//$("#btn-validar_entrada_factura").removeClass("d-none"); 
			
			$("#nuevo_entrada_factura").prop('disabled', true);			
			$("#nuevo_entrada_caja").prop('disabled', true);		 	
			
			/*asigna un valor de ID a  id_entrada_almacen */ 
			$.post("controller6.php",  
				{ 	action 		: "iniciar_registro_entrada_por_factura",   
					factura 	: factura,  
					caja 		: caja  
				}, end_iniciar_registro_entrada_por_factura); 	 	 		
		}else if(iniciar == 1){  /* va a cerrar el registro */				
			var id_entrada = $("#id_entrada_almacen").val();
			var id_entrada_factura = $("#id_entrada_factura").val(); 
			
			$('#loading').show(); 
			  
			$.post("controller6.php",   
				{ 	action : "guardar_registro_entrada_factura",  
					id_entrada_factura : id_entrada_factura,
					id_entrada : id_entrada
				}, end_guardar_registro_entrada_factura); 				
		}	 		 
	}	 
}  
function end_iniciar_registro_entrada_por_factura(xml){ 
	swal.close();
	$(xml).find("response").each(function(i){    
		if ($(this).find("result").text()=="ok"){	 		  
			$("#id_caja").val($(this).find("id_caja").text());
			$("#id_entrada_almacen").val($(this).find("id_entrada").text());
			$("#id_entrada_factura").val($(this).find("id_entrada_factura").text());
			
			$("#nuevo_entrada_proveedor").val($(this).find("id_fabricante").text());
			
			$('#loading').show(); 
			setTimeout(function(){    
				$('#loading').hide(); 				
				llenar_tabla_entrada_almacen_inventariotmp_factura(); 
			}, 2000);	
			
		}
	}); 
}
function end_guardar_registro_entrada_factura(xml){   
	//swal.close() 
	$(xml).find("response").each(function(i){  
		if ($(this).find("result").text()=="ok"){			 
			/* abrir pdf*/ 		 
			$("#iniciar_registro").val("0"); 
			$("#id_entrada_almacen").val("0"); 			
					
			//	$("#btn-iniciar_registro").removeClass("btn-danger");
			//	$("#btn-iniciar_registro").addClass("btn-primary");
			//	$("#btn-iniciar_registro").html("Iniciar Registro de Entrada");				
			//alert($("#id_entrada_almacen").val()); 
			
			
			$("#btn-iniciar_registro").removeClass("d-none");
			$("#btn-firmar_validar_entrada_factura").addClass("d-none"); 
			$("#btn-validar_entrada_factura").addClass("d-none");  
			$("#btn-imprimir_pdf_validar_entrada_factura").addClass("d-none");
			
			$("#div-iniciar_registro").removeClass("d-none");
			$("#div-firmar_validar_entrada_factura").addClass("d-none");  
			$("#div-validar_entrada_factura").addClass("d-none");  
			$("#div-imprimir_pdf_validar_entrada_factura").addClass("d-none");
			
			
			
			
			$("#table_entrada_almacen").html("");			
			/* reset form*/
			$('#nuevo_entrada_form').trigger("reset");  
			 	
			$("#nuevo_entrada_factura").prop('enabled', true);		
			$("#nuevo_entrada_caja").prop('enabled', true);		
					
			$("#nuevo_entrada_factura").prop('disabled', false);			
			$("#nuevo_entrada_caja").prop('disabled', false);		
			
			$("#cant_articulos").html('0');		 	
			$("#monto_articulos").html('0');	
			
			$("#subtotal_articulos").html('0');	
			$("#iva_articulos").html('0');	


				/* creo que trigger reset no está funcionado al 100*/
				
			$("#id_producto").val("0");   
			
			setTimeout(function(){    
				$('#loading').hide(); 
				
				window.location.href = "nuevo_entrada_factura.php";
				
				
			}, 2000);		
			
			
		}
	});
}

 

