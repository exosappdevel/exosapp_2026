function buscar_id_cirugia_por_codigo(){   

	var codigo_cirugia 	= $("#codigo_cirugia").val();
	   
	$.post("controller6.php",    
		{ 	action 			: "buscar_id_cirugia_por_codigo",
			codigo_cirugia 	: codigo_cirugia
		}, end_buscar_id_cirugia_por_codigo);
}
function end_buscar_id_cirugia_por_codigo(xml){   
	$(xml).find("response").each(function(i){		   
		if ($(this).find("result").text()=="ok"){			
			$(".id_cirugia").val($(this).find("id_cirugia").text());
			$("#surtir_cirugia_fecha_programacion").val($(this).find("fecha_programacion").text());
			$("#surtir_cirugia_fecha_cirugia").val($(this).find("fecha_cirugia").text());
			
			$("#div_surtir_material_suelto").show(); 
			$("#btn-buscar_id_cirugia_por_codigo").hide(); 
			
			$("#codigo_cirugia").attr("readonly",true);
			
			  
			llenar_tabla_producto_cirugia();
			
		}else{
			$(".id_cirugia").val("0");
			$("#surtir_cirugia_fecha_programacion").val("");
			$("#surtir_cirugia_fecha_cirugia").val("");  
			$("#div_surtir_material_suelto").hide();
			$("#codigo_cirugia").attr("readonly",false);
			$("#btn-buscar_id_cirugia_por_codigo").show();
			
			$("#respuesta").html('<div class="alert alert-danger">' + $(this).find("result_text").text() + '</div>');
			setTimeout(function(){  
				$("#respuesta").html("");   
			}, 2000);
		}
	}); 
}   

