function llenar_tabla_entradas_factura_filtro(){  
	
	var buscar_entrada_id 			= $("#buscar_entrada_id").val();
	var id_fabricante 				= $("#select_fabricante").val();
	var buscar_entrada_fecha 		= $("#buscar_entrada_fecha").val();
	var buscar_entrada_fecha_fin 	= $("#buscar_entrada_fecha_fin").val();
	var buscar_entrada_referencia 	= $("#buscar_entrada_referencia").val();
	var buscar_entrada_lote 		= $("#buscar_entrada_lote").val();
	
	$.post("controller6.php",
		{ 	action 						:"llenar_tabla_entradas_factura",
			buscar_entrada_id 			: buscar_entrada_id,
			id_fabricante 				: id_fabricante,
			buscar_entrada_fecha 		: buscar_entrada_fecha,
			buscar_entrada_fecha_fin 	: buscar_entrada_fecha_fin,
			buscar_entrada_referencia 	: buscar_entrada_referencia,
			buscar_entrada_lote 		: buscar_entrada_lote
		}, end_llenar_tabla_entradas_factura);
} 
